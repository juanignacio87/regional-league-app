<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">RegionalLeagueApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Inicio
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="fixture">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Fixture
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="results">
                <span class="bi bi-check-square-fill-nav-menu" aria-hidden="true"></span> Resultados
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="standings">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Tabla
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="clubs">
                <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Clubes
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="scorers">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Goleadores
            </NavLink>
        </div>

        <AuthorizeView Roles="@AppRoles.Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin">
                        <span class="bi bi-lock-nav-menu" aria-hidden="true"></span> Admin
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized Context="auth">
                <div class="nav-item px-3">
                    <span class="nav-link">@auth.User.Identity?.Name</span>
                </div>
                <div class="nav-item px-3">
                    <form method="post" action="/account/logout">
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Salir
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Ingresar
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

