<header class="rl-navbar">
    <div class="rl-navbar__inner">
        <a class="rl-navbar__brand" href="">
            <span class="rl-navbar__brand-mark">RL</span>
            <span class="rl-navbar__brand-text">
                <strong>Regional League</strong>
                <small>Resultados y fixture</small>
            </span>
        </a>

        <input id="rl-navbar-toggle" type="checkbox" title="Navigation menu" class="rl-navbar__toggle-input" aria-hidden="true" tabindex="-1" />
        <label for="rl-navbar-toggle" class="rl-navbar__toggle-button" aria-label="Abrir menu">
            <span></span>
            <span></span>
            <span></span>
        </label>

        <nav class="rl-navbar__links" onclick="document.getElementById('rl-navbar-toggle')?.click()">
            <NavLink class="rl-navbar__link" href="" Match="NavLinkMatch.All">Inicio</NavLink>
            <NavLink class="rl-navbar__link" href="leagues">Ligas</NavLink>
            <NavLink class="rl-navbar__link" href="fixture">Fixture</NavLink>
            <NavLink class="rl-navbar__link" href="results">Resultados</NavLink>
            <NavLink class="rl-navbar__link" href="standings">Tabla</NavLink>
            <NavLink class="rl-navbar__link" href="clubs">Clubes</NavLink>
            <NavLink class="rl-navbar__link" href="scorers">Goleadores</NavLink>

            <AuthorizeView Roles="@AppRoles.Admin">
                <Authorized>
                    <NavLink class="rl-navbar__link rl-navbar__link--admin" href="admin">Admin</NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>

        <div class="rl-navbar__account">
            <AuthorizeView>
                <Authorized Context="auth">
                    <span class="rl-navbar__account-name">@auth.User.Identity?.Name</span>
                    <form method="post" action="/account/logout">
                        <button type="submit" class="rl-navbar__account-button">Salir</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="rl-navbar__account-button" href="login">Ingresar</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</header>
