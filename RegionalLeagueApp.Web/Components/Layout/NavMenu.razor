<header class="app-header">
    <div class="header-inner">
        <a class="brand" href="">
            <span class="brand-mark">RL</span>
            <span>
                <strong>Regional League</strong>
                <small>Resultados y fixture</small>
            </span>
        </a>

        <input id="nav-toggle" type="checkbox" title="Navigation menu" class="navbar-toggler" />
        <label for="nav-toggle" class="navbar-toggle-label" aria-label="Abrir menu">
            <span></span>
            <span></span>
            <span></span>
        </label>

        <nav class="nav-scrollable" onclick="document.getElementById('nav-toggle')?.click()">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Inicio</NavLink>
            <NavLink class="nav-link" href="fixture">Fixture</NavLink>
            <NavLink class="nav-link" href="results">Resultados</NavLink>
            <NavLink class="nav-link" href="standings">Tabla</NavLink>
            <NavLink class="nav-link" href="clubs">Clubes</NavLink>
            <NavLink class="nav-link" href="scorers">Goleadores</NavLink>

            <AuthorizeView Roles="@AppRoles.Admin">
                <Authorized>
                    <NavLink class="nav-link nav-link-admin" href="admin">Admin</NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>

        <div class="account-nav">
            <AuthorizeView>
                <Authorized Context="auth">
                    <span class="account-name">@auth.User.Identity?.Name</span>
                    <form method="post" action="/account/logout">
                        <button type="submit" class="account-button">Salir</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="account-button" href="login">Ingresar</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</header>
