<div class="ui-panel-header">
    <div class="ui-panel-header__content">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <p class="eyebrow">@Eyebrow</p>
        }
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <h2>@Title</h2>
        }
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p class="ui-panel-header__description">@Description</p>
        }
        @ChildContent
    </div>
    @if (Actions is not null || !string.IsNullOrWhiteSpace(Meta))
    {
        <div class="ui-panel-header__actions">
            @if (!string.IsNullOrWhiteSpace(Meta))
            {
                <span>@Meta</span>
            }
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Meta { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
