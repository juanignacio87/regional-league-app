<a class="match-card" href="matches/@Match.Id">
    <div class="match-meta">
        <span>@Match.Round?.Name</span>
        <span>@Match.StartsAt.LocalDateTime.ToString("dd/MM HH:mm")</span>
    </div>
    <div class="score-line">
        <span class="team-name team-name-with-logo">
            <ClubLogo Name="@HomeName" LogoPath="@Match.HomeTeam?.Club?.LogoPath" Class="club-logo-sm" />
            @HomeName
        </span>
        <b>@ScoreText</b>
        <span class="team-name team-name-with-logo team-name-with-logo-away">
            @AwayName
            <ClubLogo Name="@AwayName" LogoPath="@Match.AwayTeam?.Club?.LogoPath" Class="club-logo-sm" />
        </span>
    </div>
    <small class="status-pill @StatusClass">@Match.Status</small>
</a>

@code {
    [Parameter, EditorRequired] public Match Match { get; set; } = default!;

    private string HomeName => Match.HomeTeam?.Club?.ShortName ?? Match.HomeTeam?.Name ?? "Local";
    private string AwayName => Match.AwayTeam?.Club?.ShortName ?? Match.AwayTeam?.Name ?? "Visitante";

    private string ScoreText =>
        Match.HomeScore is null || Match.AwayScore is null
            ? "vs"
            : $"{Match.HomeScore}-{Match.AwayScore}";

    private string StatusClass => Match.Status is MatchStatus.Live or MatchStatus.HalfTime
        ? "status-live"
        : string.Empty;
}
