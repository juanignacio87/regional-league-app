<span class="club-logo @Class">
    @if (!string.IsNullOrWhiteSpace(LogoPath))
    {
        <img src="@LogoPath" alt="@($"{Name} logo")" />
    }
    else
    {
        <span>@Initials</span>
    }
</span>

@code {
    [Parameter] public string Name { get; set; } = "Club";
    [Parameter] public string? LogoPath { get; set; }
    [Parameter] public string? Class { get; set; }

    private string Initials => string.Concat(Name
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Take(2)
        .Select(x => x[0]))
        .ToUpperInvariant();
}
