@page "/standings"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Standings
@inject ApplicationDbContext Db
@inject IStandingsQueryService StandingsQueryService
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Tabla</PageTitle>

<PageBreadcrumb BackHref="@BreadcrumbBackHref" ParentHref="@BreadcrumbParentHref" ParentLabel="@BreadcrumbParentLabel" CurrentLabel="@BreadcrumbCurrentLabel" />

<div class="page-heading">
    <p class="eyebrow">Standings</p>
    <h1>@PageTitleText</h1>
</div>

<LeagueCompetitionFilter Path="/standings" LeagueId="@LeagueId" CompetitionId="@CompetitionId" />

@if (standings.Count == 0)
{
    <EmptyState Text="@EmptyText" />
}
else
{
    @foreach (var group in standings.GroupBy(x => new { x.CompetitionId, x.CompetitionName }).OrderBy(x => x.Key.CompetitionName))
    {
        <section class="panel table-panel standings-table section-gap">
            <div class="standings-section-title">
                <h2>@group.Key.CompetitionName</h2>
                <span>@group.Count() equipos</span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Pos</th>
                        <th>Club</th>
                        <th>PJ</th>
                        <th>PG</th>
                        <th>PE</th>
                        <th>PP</th>
                        <th>GF</th>
                        <th>GC</th>
                        <th>DG</th>
                        <th>PTS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in group.OrderBy(x => x.Position))
                    {
                        <tr class="@(row.Position == 1 ? "leader-row" : string.Empty)">
                            <td><strong>@row.Position</strong></td>
                            <td>
                                <a class="standings-club-link" href="clubs/@row.ClubId">
                                    <ClubLogo Name="@row.ClubName" LogoPath="@row.ClubLogoPath" Class="club-logo-xs" />
                                    <span>
                                        @row.ClubName
                                        @if (standings.Select(x => x.ClubId).Distinct().Count() != standings.Count)
                                        {
                                            <small>@row.CompetitionName</small>
                                        }
                                    </span>
                                </a>
                            </td>
                            <td>@row.Played</td>
                            <td>@row.Won</td>
                            <td>@row.Drawn</td>
                            <td>@row.Lost</td>
                            <td>@row.GoalsFor</td>
                            <td>@row.GoalsAgainst</td>
                            <td>@row.GoalDifference</td>
                            <td><strong>@row.Points</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
}

@code {
    private IReadOnlyList<StandingRowDto> standings = [];
    private Func<Task>? reloadHandler;
    private string? leagueName;
    private string? competitionName;

    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }
    [SupplyParameterFromQuery] public Guid? CompetitionId { get; set; }

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Tabla de posiciones"
        : $"Tabla de posiciones - {leagueName}";

    private string EmptyText => CompetitionId is not null
        ? "No hay tabla disponible para esta competencia."
        : "No hay tabla disponible.";

    private string BreadcrumbBackHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentLabel => LeagueId is null ? "Inicio" : leagueName ?? "Liga";

    private string BreadcrumbCurrentLabel => string.IsNullOrWhiteSpace(competitionName)
        ? "Tabla"
        : $"{competitionName} / Tabla";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        competitionName = CompetitionId is null
            ? null
            : await Db.Competitions
                .AsNoTracking()
                .Where(x => x.Id == CompetitionId && x.IsActive)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var loadedStandings = await StandingsQueryService.GetStandingsAsync(LeagueId);
        standings = CompetitionId is null
            ? loadedStandings
            : loadedStandings.Where(x => x.CompetitionId == CompetitionId).ToList();
    }
}
