@page "/standings"
@using RegionalLeagueApp.Application.Standings
@inject IStandingsQueryService StandingsQueryService

<PageTitle>Tabla</PageTitle>

<div class="page-heading">
    <p class="eyebrow">Standings</p>
    <h1>Tabla de posiciones</h1>
</div>

@if (standings.Count == 0)
{
    <EmptyState Text="No hay tabla disponible." />
}
else
{
    <section class="panel table-panel standings-table">
        <table>
            <thead>
                <tr>
                    <th>Pos</th>
                    <th>Club</th>
                    <th>PJ</th>
                    <th>PG</th>
                    <th>PE</th>
                    <th>PP</th>
                    <th>GF</th>
                    <th>GC</th>
                    <th>DG</th>
                    <th>PTS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in standings)
                {
                    <tr class="@(row.Position == 1 ? "leader-row" : string.Empty)">
                        <td><strong>@row.Position</strong></td>
                        <td><a href="clubs/@row.ClubId">@row.ClubName</a></td>
                        <td>@row.Played</td>
                        <td>@row.Won</td>
                        <td>@row.Drawn</td>
                        <td>@row.Lost</td>
                        <td>@row.GoalsFor</td>
                        <td>@row.GoalsAgainst</td>
                        <td>@row.GoalDifference</td>
                        <td><strong>@row.Points</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private IReadOnlyList<StandingRowDto> standings = [];

    protected override async Task OnInitializedAsync()
    {
        standings = await StandingsQueryService.GetStandingsAsync();
    }
}
