@page "/admin/leagues/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Moderator")]
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Fixtures
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IFixtureCsvImportService FixtureCsvImportService
@inject IFixtureGeneratorService FixtureGeneratorService
@inject IFixtureRulesService FixtureRulesService
@inject ToastService ToastService
@inject ILogger<AdminLeagueDetail> Logger

<ToastContainer />

<PageTitle>Administrar liga</PageTitle>

@if (league is null)
{
    <EmptyState Text="Liga no encontrada." />
}
else
{
    <PageBreadcrumb BackHref="/admin" ParentHref="/admin" ParentLabel="Admin" CurrentLabel="@league.Name" />

    <section class="admin-league-header">
        <div>
            <p class="eyebrow">Administracion deportiva</p>
            <h1>@league.Name</h1>
            <p>@LocationText(league.Region, league.Country)</p>
        </div>
        <div class="admin-league-header__actions">
            <a class="leagues-button leagues-button--muted" href="/leagues/@league.Id">Vista publica</a>
            <a class="leagues-button leagues-button--muted" href="/admin">Admin general</a>
        </div>
    </section>

    <FormMessage Message="@statusMessage" Variant="@(isSuccessMessage ? "success" : "danger")" />

    <section class="leagues-summary admin-league-summary">
        <article>
            <strong>@DisplaySeasons.Count</strong>
            <span>Temporadas</span>
        </article>
        <article>
            <strong>@competitions.Count</strong>
            <span>Competencias</span>
        </article>
        <article>
            <strong>@participants.Count</strong>
            <span>Clubes/equipos</span>
        </article>
    </section>

    @if (canManage)
    {
        <section class="admin-league-dashboard">
            <div class="admin-league-toolbar">
                <div>
                    <p class="eyebrow">Operaciones</p>
                    <h2>Estructura deportiva</h2>
                    <span>Gestion compacta de temporadas, competencias, equipos y partidos.</span>
                </div>
            </div>

            <div class="admin-league-sections">
                <LeagueSeasonManager
                    Seasons="@DisplaySeasons"
                    IsSaving="@isSaving"
                    @bind-NewSeasonName="@newSeasonName"
                    @bind-NewSeasonStartsOn="@newSeasonStartsOn"
                    @bind-NewSeasonEndsOn="@newSeasonEndsOn"
                    @bind-NewSeasonIsActive="@newSeasonIsActive"
                    CreateSeason="@CreateSeasonAsync" />

                <LeagueCompetitionManager
                    Seasons="@DisplaySeasons"
                    Competitions="@competitions"
                    IsSaving="@isSaving"
                    @bind-NewCompetitionSeasonId="@newCompetitionSeasonId"
                    @bind-NewCompetitionName="@newCompetitionName"
                    @bind-NewCompetitionFormat="@newCompetitionFormat"
                    @bind-NewCompetitionIsActive="@newCompetitionIsActive"
                    CreateCompetition="@CreateCompetitionAsync" />

                <LeagueTeamManager
                    Participants="@participants"
                    CompetitionOptions="@competitionOptions"
                    ClubOptions="@clubOptions"
                    IsSaving="@isSaving"
                    @bind-NewTeamCompetitionId="@newTeamCompetitionId"
                    @bind-NewTeamClubId="@newTeamClubId"
                    @bind-NewTeamName="@newTeamName"
                    @bind-NewTeamCategory="@newTeamCategory"
                    AddTeam="@AddTeamAsync" />

                <LeagueFixtureManager
                    CompetitionOptions="@competitionOptions"
                    IsSaving="@isSaving"
                    @bind-NewMatchCompetitionId="@newMatchCompetitionId"
                    CompetitionChanged="@OnMatchCompetitionChangedAsync"
                    NewMatchRoundName="@newMatchRoundName"
                    RoundInput="@OnMatchRoundInput"
                    @bind-NewMatchStartsAt="@newMatchStartsAt"
                    @bind-NewMatchHomeTeamId="@newMatchHomeTeamId"
                    @bind-NewMatchAwayTeamId="@newMatchAwayTeamId"
                    AvailableHomeTeamOptions="@AvailableHomeTeamOptions"
                    AvailableAwayTeamOptions="@AvailableAwayTeamOptions"
                    CreateMatch="@CreateMatchAsync"
                    SelectedCompetitionMatches="@SelectedCompetitionMatches"
                    FilteredCompetitionMatches="@FilteredCompetitionMatches"
                    MatchRoundOptions="@MatchRoundOptions"
                    SelectedCompetitionLabel="@SelectedCompetitionLabel"
                    @bind-MatchStatusFilter="@matchStatusFilter"
                    @bind-MatchRoundFilter="@matchRoundFilter"
                    MatchTeamOptions="@matchTeamOptions"
                    EditingMatchId="@editingMatchId"
                    GetMatchEdit="@GetMatchEdit"
                    BeginMatchEdit="@BeginMatchEdit"
                    CancelMatchEdit="@CancelMatchEdit"
                    SaveMatch="@SaveMatchAsync"
                    CancelExistingMatch="@CancelExistingMatchAsync"
                    @bind-CsvInput="@fixtureCsvInput"
                    CsvPreview="@fixtureCsvPreview"
                    PreviewCsv="@PreviewFixtureCsvAsync"
                    ConfirmCsv="@ConfirmFixtureCsvImportAsync"
                    @bind-GeneratorStartDate="@fixtureGeneratorStartDate"
                    @bind-GeneratorDaysBetweenRounds="@fixtureGeneratorDaysBetweenRounds"
                    @bind-GeneratorDefaultTime="@fixtureGeneratorDefaultTime"
                    @bind-GeneratorHomeAndAway="@fixtureGeneratorHomeAndAway"
                    GeneratorPreview="@fixtureGeneratorPreview"
                    PreviewGeneratedFixture="@PreviewGeneratedFixtureAsync"
                    ConfirmGeneratedFixture="@ConfirmGeneratedFixtureAsync"
                    ParticipantCount="@matchTeamOptions.Count"
                    ExistingMatchCount="@SelectedCompetitionMatches.Count"
                    SafeDeletableMatchCount="@safeDeletableMatchCount"
                    ClearFixture="@ClearFixtureAsync"
                    RegenerateFixture="@RegenerateFixtureAsync" />
            </div>
        </section>
    }

    <section class="league-structure admin-league-structure">
        @if (DisplaySeasons.Count == 0)
        {
            <EmptyState Text="No hay temporadas activas para esta liga." />
        }
        else
        {
            @foreach (var season in DisplaySeasons)
            {
                var seasonEdit = GetSeasonEdit(season.Id);
                <article class="panel league-season-card">
                    <div class="league-section-title">
                        <div>
                            <p class="eyebrow">Temporada</p>
                            <h2>@season.Name</h2>
                            <span>@season.StartsOn.ToString("dd/MM/yyyy") - @season.EndsOn.ToString("dd/MM/yyyy")</span>
                        </div>
                        <span class="leagues-status @(season.IsActive ? "leagues-status--active" : "leagues-status--archived")">@(season.IsActive ? "Activa" : "Archivada")</span>
                    </div>

                    @if (canManage)
                    {
                        <div class="league-inline-edit">
                            <input class="form-control" value="@seasonEdit.Name" @oninput="e => seasonEdit.Name = e.Value?.ToString() ?? string.Empty" />
                            <input class="form-control" type="date" value="@seasonEdit.StartsOn" @oninput="e => seasonEdit.StartsOn = e.Value?.ToString() ?? string.Empty" />
                            <input class="form-control" type="date" value="@seasonEdit.EndsOn" @oninput="e => seasonEdit.EndsOn = e.Value?.ToString() ?? string.Empty" />
                            <button type="button" class="leagues-button leagues-button--muted" @onclick="() => UpdateSeasonAsync(season.Id)">Guardar</button>
                            <button type="button" class="leagues-button leagues-button--muted" @onclick="() => SetSeasonActiveAsync(season.Id, !season.IsActive)">@(season.IsActive ? "Archivar" : "Reactivar")</button>
                        </div>
                    }

                    @foreach (var competition in season.Competitions.Where(x => canManage || x.IsActive).OrderBy(x => x.Name))
                    {
                        var competitionEdit = GetCompetitionEdit(competition.Id);
                        <section class="league-competition-card">
                            <div class="league-section-title">
                                <div>
                                    <p class="eyebrow">Competencia</p>
                                    <h3>@competition.Name</h3>
                                    <span>@competition.Format</span>
                                </div>
                                <span class="leagues-status @(competition.IsActive ? "leagues-status--active" : "leagues-status--archived")">@(competition.IsActive ? "Activa" : "Archivada")</span>
                            </div>

                            @if (canManage)
                            {
                                <div class="league-inline-edit">
                                    <input class="form-control" value="@competitionEdit.Name" @oninput="e => competitionEdit.Name = e.Value?.ToString() ?? string.Empty" />
                                    <input class="form-control" value="@competitionEdit.Format" @oninput="e => competitionEdit.Format = e.Value?.ToString() ?? string.Empty" />
                                    <button type="button" class="leagues-button leagues-button--muted" @onclick="() => UpdateCompetitionAsync(competition.Id)">Guardar</button>
                                    <button type="button" class="leagues-button leagues-button--muted" @onclick="() => SetCompetitionActiveAsync(competition.Id, !competition.IsActive)">@(competition.IsActive ? "Archivar" : "Reactivar")</button>
                                </div>
                            }

                            <div class="league-competition-grid">
                                <div>
                                    <h4>Equipos participantes</h4>
                                    @if (!competition.Teams.Any(x => x.IsActive))
                                    {
                                        <EmptyState Text="No hay equipos en esta competencia." />
                                    }
                                    else
                                    {
                                        <div class="leagues-participants">
                                            @foreach (var team in competition.Teams.Where(x => x.IsActive && x.Club is not null && x.Club.IsActive).OrderBy(x => x.Club!.Name))
                                            {
                                                <a class="leagues-participant" href="/clubs/@team.ClubId">
                                                    <ClubLogo Name="@team.Club!.Name" LogoPath="@team.Club.LogoPath" />
                                                    <div><strong>@team.Club.Name</strong><span>@team.Name - @team.Category</span></div>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                                <div>
                                    <h4>Partidos</h4>
                                    @if (!competition.Matches.Any())
                                    {
                                        <EmptyState Text="No hay partidos cargados." />
                                    }
                                    else
                                    {
                                        <div class="league-match-list">
                                            @foreach (var match in competition.Matches.OrderBy(x => x.StartsAt).Take(8))
                                            {
                                                <a href="/matches/@match.Id">
                                                    <span>@(match.Round?.Name ?? "Fecha")</span>
                                                    <strong>@(match.HomeTeam?.Club?.ShortName ?? "LOC") vs @(match.AwayTeam?.Club?.ShortName ?? "VIS")</strong>
                                                    <small>@match.StartsAt.LocalDateTime.ToString("dd/MM HH:mm") - @match.Status</small>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </section>
                    }
                </article>
            }
        }
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private League? league;
    private List<CompetitionItem> competitions = [];
    private List<ParticipantItem> participants = [];
    private List<ClubOption> clubOptions = [];
    private List<CompetitionOption> competitionOptions = [];
    private List<TeamOption> matchTeamOptions = [];
    private readonly Dictionary<Guid, SeasonEditModel> seasonEdits = [];
    private readonly Dictionary<Guid, CompetitionEditModel> competitionEdits = [];
    private readonly Dictionary<Guid, MatchEditModel> matchEdits = [];
    private bool canManage;
    private bool isSaving;
    private bool isSuccessMessage;
    private int safeDeletableMatchCount;
    private Guid? editingMatchId;
    private string? statusMessage;
    private string newSeasonName = string.Empty;
    private string newSeasonStartsOn = string.Empty;
    private string newSeasonEndsOn = string.Empty;
    private bool newSeasonIsActive = true;
    private Guid? newCompetitionSeasonId;
    private string newCompetitionName = string.Empty;
    private string newCompetitionFormat = "League";
    private bool newCompetitionIsActive = true;
    private Guid? newTeamCompetitionId;
    private Guid? newTeamClubId;
    private string newTeamName = string.Empty;
    private string newTeamCategory = "Primera";
    private Guid? newMatchCompetitionId;
    private Guid? newMatchHomeTeamId;
    private Guid? newMatchAwayTeamId;
    private string newMatchRoundName = string.Empty;
    private string newMatchStartsAt = string.Empty;
    private string fixtureCsvInput = string.Empty;
    private string fixtureGeneratorStartDate = DateTime.Today.ToString("yyyy-MM-dd");
    private string fixtureGeneratorDaysBetweenRounds = "7";
    private string fixtureGeneratorDefaultTime = "15:00";
    private bool fixtureGeneratorHomeAndAway;
    private string matchStatusFilter = string.Empty;
    private string matchRoundFilter = string.Empty;
    private FixtureCsvPreviewResult? fixtureCsvPreview;
    private FixtureGeneratorPreviewResult? fixtureGeneratorPreview;

    private List<Season> DisplaySeasons => league?.Seasons
        .Where(x => canManage || x.IsActive)
        .OrderByDescending(x => x.IsActive)
        .ThenByDescending(x => x.StartsOn)
        .ToList() ?? [];

    private List<Match> SelectedCompetitionMatches => newMatchCompetitionId is null || league is null
        ? []
        : league.Seasons
            .SelectMany(x => x.Competitions)
            .Where(x => x.Id == newMatchCompetitionId)
            .SelectMany(x => x.Matches)
            .OrderBy(x => x.StartsAt)
            .ThenBy(x => x.HomeTeam?.Club?.Name ?? string.Empty)
            .ToList();

    private List<Match> FilteredCompetitionMatches => SelectedCompetitionMatches
        .Where(x => string.IsNullOrWhiteSpace(matchStatusFilter) || x.Status.ToString() == matchStatusFilter)
        .Where(x => string.IsNullOrWhiteSpace(matchRoundFilter) || (x.Round?.Name ?? "Fecha") == matchRoundFilter)
        .ToList();

    private List<string> MatchRoundOptions => SelectedCompetitionMatches
        .Select(x => x.Round?.Name ?? "Fecha")
        .Distinct()
        .OrderBy(x => RoundSortValue(x))
        .ToList();

    private string SelectedCompetitionLabel => newMatchCompetitionId is null
        ? "Sin competencia seleccionada"
        : competitionOptions.FirstOrDefault(x => x.Id == newMatchCompetitionId)?.Label ?? "Competencia seleccionada";

    private List<TeamOption> AvailableHomeTeamOptions => matchTeamOptions
        .Where(team => !OccupiedTeamIdsForSelectedRound.Contains(team.Id) && team.Id != newMatchAwayTeamId)
        .ToList();

    private List<TeamOption> AvailableAwayTeamOptions => matchTeamOptions
        .Where(team => !OccupiedTeamIdsForSelectedRound.Contains(team.Id) && team.Id != newMatchHomeTeamId)
        .ToList();

    private HashSet<Guid> OccupiedTeamIdsForSelectedRound
    {
        get
        {
            var roundName = MatchRoundName();
            if (newMatchCompetitionId is null || string.IsNullOrWhiteSpace(roundName) || league is null)
            {
                return [];
            }

            return league.Seasons
                .SelectMany(x => x.Competitions)
                .Where(x => x.Id == newMatchCompetitionId)
                .SelectMany(x => x.Matches)
                .Where(x => string.Equals(x.Round?.Name, roundName, StringComparison.OrdinalIgnoreCase))
                .SelectMany(x => new[] { x.HomeTeamId, x.AwayTeamId })
                .ToHashSet();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        canManage = authState.User.IsInRole(AppRoles.Admin) || authState.User.IsInRole(AppRoles.Moderator);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        league = await Db.Leagues
            .AsNoTracking()
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Teams)
                        .ThenInclude(item => item.Club)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.Round)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.HomeTeam)!.ThenInclude(item => item!.Club)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.AwayTeam)!.ThenInclude(item => item!.Club)
            .FirstOrDefaultAsync(item => item.Id == Id && (item.IsActive || canManage));

        if (league is null)
        {
            competitions = [];
            participants = [];
            return;
        }

        competitions = league.Seasons
            .Where(season => canManage || season.IsActive)
            .SelectMany(season => season.Competitions.Where(competition => canManage || competition.IsActive).Select(competition => new CompetitionItem(
                competition.Id,
                competition.Name,
                season.Name,
                competition.Format,
                competition.Teams.Count(team => team.IsActive && team.Club is not null && team.Club.IsActive))))
            .OrderBy(item => item.SeasonName)
            .ThenBy(item => item.Name)
            .ToList();

        participants = league.Seasons
            .SelectMany(season => season.Competitions)
            .Where(competition => canManage || competition.IsActive)
            .SelectMany(competition => competition.Teams)
            .Where(team => team.IsActive && team.Club is not null && team.Club.IsActive)
            .GroupBy(team => new { team.ClubId, ClubName = team.Club!.Name, team.Club.LogoPath, team.Name })
            .Select(group => new ParticipantItem(group.Key.ClubId, group.Key.ClubName, group.Key.LogoPath, group.Key.Name))
            .OrderBy(item => item.ClubName)
            .ThenBy(item => item.TeamName)
            .ToList();

        clubOptions = await Db.Clubs
            .AsNoTracking()
            .Where(x => x.IsActive)
            .OrderBy(x => x.Name)
            .Select(x => new ClubOption(x.Id, x.Name))
            .ToListAsync();

        competitionOptions = competitions
            .Select(x => new CompetitionOption(x.Id, $"{x.SeasonName} - {x.Name}"))
            .ToList();

        PrepareEditModels();
        await LoadMatchTeamOptionsAsync();
        await LoadFixtureSafetyCountsAsync();
    }

    private void PrepareEditModels()
    {
        seasonEdits.Clear();
        foreach (var season in DisplaySeasons)
        {
            seasonEdits[season.Id] = new SeasonEditModel(season.Name, season.StartsOn.ToString("yyyy-MM-dd"), season.EndsOn.ToString("yyyy-MM-dd"));
        }

        competitionEdits.Clear();
        foreach (var competition in league?.Seasons.SelectMany(x => x.Competitions) ?? [])
        {
            competitionEdits[competition.Id] = new CompetitionEditModel(competition.Name, competition.Format);
        }

        matchEdits.Clear();
        foreach (var match in league?.Seasons.SelectMany(x => x.Competitions).SelectMany(x => x.Matches) ?? [])
        {
            matchEdits[match.Id] = new MatchEditModel(
                match.Round?.Name ?? "Fecha 1",
                match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"),
                match.HomeTeamId,
                match.AwayTeamId,
                match.Status);
        }
    }

    private async Task CreateSeasonAsync()
    {
        if (!canManage || isSaving)
        {
            return;
        }

        if (!TryParseSeason(newSeasonName, newSeasonStartsOn, newSeasonEndsOn, out var name, out var startsOn, out var endsOn, out var error))
        {
            SetMessage(error, false);
            return;
        }

        if (await Db.Seasons.AnyAsync(x => x.LeagueId == Id && x.Name == name))
        {
            SetMessage("Ya existe una temporada con ese nombre.", false);
            return;
        }

        isSaving = true;
        try
        {
            Db.Seasons.Add(new Season(Id, name, startsOn, endsOn, newSeasonIsActive));
            await Db.SaveChangesAsync();
            newSeasonName = string.Empty;
            newSeasonStartsOn = string.Empty;
            newSeasonEndsOn = string.Empty;
            SetMessage("Temporada creada correctamente.", true);
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UpdateSeasonAsync(Guid seasonId)
    {
        var edit = GetSeasonEdit(seasonId);
        if (!TryParseSeason(edit.Name, edit.StartsOn, edit.EndsOn, out var name, out var startsOn, out var endsOn, out var error))
        {
            SetMessage(error, false);
            return;
        }

        var season = await Db.Seasons.FirstOrDefaultAsync(x => x.Id == seasonId && x.LeagueId == Id);
        if (season is null)
        {
            SetMessage("Temporada no encontrada.", false);
            return;
        }

        season.UpdateDetails(name, startsOn, endsOn);
        await Db.SaveChangesAsync();
        SetMessage("Temporada actualizada.", true);
        await LoadAsync();
    }

    private async Task SetSeasonActiveAsync(Guid seasonId, bool isActive)
    {
        var season = await Db.Seasons.FirstOrDefaultAsync(x => x.Id == seasonId && x.LeagueId == Id);
        if (season is null)
        {
            return;
        }

        season.SetActive(isActive);
        await Db.SaveChangesAsync();
        SetMessage(isActive ? "Temporada reactivada." : "Temporada archivada.", true);
        await LoadAsync();
    }

    private async Task CreateCompetitionAsync()
    {
        if (newCompetitionSeasonId is null || string.IsNullOrWhiteSpace(newCompetitionName))
        {
            SetMessage("Temporada y nombre de competencia son obligatorios.", false);
            return;
        }

        var name = newCompetitionName.Trim();
        var format = string.IsNullOrWhiteSpace(newCompetitionFormat) ? "League" : newCompetitionFormat.Trim();
        if (await Db.Competitions.AnyAsync(x => x.SeasonId == newCompetitionSeasonId && x.Name == name))
        {
            SetMessage("Ya existe una competencia con ese nombre en la temporada.", false);
            return;
        }

        var competition = new Competition(newCompetitionSeasonId.Value, name, format);
        competition.SetActive(newCompetitionIsActive);
        Db.Competitions.Add(competition);
        await Db.SaveChangesAsync();
        newCompetitionName = string.Empty;
        newCompetitionFormat = "League";
        SetMessage("Competencia creada correctamente.", true);
        await LoadAsync();
    }

    private async Task UpdateCompetitionAsync(Guid competitionId)
    {
        var edit = GetCompetitionEdit(competitionId);
        var name = edit.Name.Trim();
        var format = string.IsNullOrWhiteSpace(edit.Format) ? "League" : edit.Format.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            SetMessage("El nombre de competencia es obligatorio.", false);
            return;
        }

        var competition = await Db.Competitions.FirstOrDefaultAsync(x => x.Id == competitionId);
        if (competition is null)
        {
            SetMessage("Competencia no encontrada.", false);
            return;
        }

        competition.UpdateDetails(name, format);
        await Db.SaveChangesAsync();
        SetMessage("Competencia actualizada.", true);
        await LoadAsync();
    }

    private async Task SetCompetitionActiveAsync(Guid competitionId, bool isActive)
    {
        var competition = await Db.Competitions.FirstOrDefaultAsync(x => x.Id == competitionId);
        if (competition is null)
        {
            return;
        }

        competition.SetActive(isActive);
        await Db.SaveChangesAsync();
        SetMessage(isActive ? "Competencia reactivada." : "Competencia archivada.", true);
        await LoadAsync();
    }

    private async Task AddTeamAsync()
    {
        if (newTeamCompetitionId is null || newTeamClubId is null)
        {
            SetMessage("Selecciona competencia y club.", false);
            return;
        }

        var club = await Db.Clubs.AsNoTracking().FirstOrDefaultAsync(x => x.Id == newTeamClubId && x.IsActive);
        if (club is null)
        {
            SetMessage("Club no encontrado.", false);
            return;
        }

        var competitionIsActive = await Db.Competitions.AnyAsync(x => x.Id == newTeamCompetitionId && x.IsActive && x.Season!.LeagueId == Id);
        if (!competitionIsActive)
        {
            SetMessage("No se pueden agregar equipos a una competencia archivada o inexistente.", false);
            return;
        }

        var name = string.IsNullOrWhiteSpace(newTeamName) ? $"{club.ShortName} {newTeamCategory.Trim()}" : newTeamName.Trim();
        var category = string.IsNullOrWhiteSpace(newTeamCategory) ? "Primera" : newTeamCategory.Trim();
        if (await Db.Teams.AnyAsync(x => x.CompetitionId == newTeamCompetitionId && x.ClubId == newTeamClubId))
        {
            SetMessage("Ese club ya participa en la competencia.", false);
            return;
        }

        Db.Teams.Add(new Team(newTeamClubId.Value, newTeamCompetitionId.Value, name, category));
        await Db.SaveChangesAsync();
        newTeamName = string.Empty;
        SetMessage("Equipo agregado a la competencia.", true);
        await LoadAsync();
    }

    private async Task OnMatchCompetitionChangedAsync()
    {
        newMatchHomeTeamId = null;
        newMatchAwayTeamId = null;
        matchStatusFilter = string.Empty;
        matchRoundFilter = string.Empty;
        fixtureCsvPreview = null;
        fixtureGeneratorPreview = null;
        await LoadMatchTeamOptionsAsync();
        await LoadFixtureSafetyCountsAsync();
    }

    private void OnMatchRoundInput(ChangeEventArgs args)
    {
        newMatchRoundName = args.Value?.ToString() ?? string.Empty;
        ClearUnavailableMatchTeams();
    }

    private void ClearUnavailableMatchTeams()
    {
        var occupiedTeamIds = OccupiedTeamIdsForSelectedRound;
        if (newMatchHomeTeamId is not null && occupiedTeamIds.Contains(newMatchHomeTeamId.Value))
        {
            newMatchHomeTeamId = null;
        }

        if (newMatchAwayTeamId is not null && occupiedTeamIds.Contains(newMatchAwayTeamId.Value))
        {
            newMatchAwayTeamId = null;
        }
    }

    private async Task LoadMatchTeamOptionsAsync()
    {
        matchTeamOptions = newMatchCompetitionId is null
            ? []
            : await Db.Teams
                .AsNoTracking()
                .Where(x => x.CompetitionId == newMatchCompetitionId && x.IsActive && x.Club!.IsActive)
                .OrderBy(x => x.Club!.Name)
                .Select(x => new TeamOption(x.Id, $"{x.Club!.Name} - {x.Name}"))
                .ToListAsync();
    }

    private async Task LoadFixtureSafetyCountsAsync()
    {
        safeDeletableMatchCount = newMatchCompetitionId is null
            ? 0
            : (await FixtureRulesService.GetSafeDeletableMatchIdsAsync(newMatchCompetitionId.Value)).Count;
    }

    private async Task CreateMatchAsync()
    {
        if (newMatchCompetitionId is null || newMatchHomeTeamId is null || newMatchAwayTeamId is null)
        {
            SetMessage("Competencia, local y visitante son obligatorios.", false);
            ToastService.Warning("Competencia, local y visitante son obligatorios.");
            return;
        }

        if (!DateTime.TryParse(newMatchStartsAt, out var startsAtLocal))
        {
            SetMessage("Fecha/hora de partido invalida.", false);
            ToastService.Warning("Fecha/hora de partido invalida.");
            return;
        }

        var competitionIsActive = await Db.Competitions.AnyAsync(x => x.Id == newMatchCompetitionId && x.IsActive && x.Season!.LeagueId == Id);
        if (!competitionIsActive)
        {
            SetMessage("No se pueden crear partidos en una competencia archivada o inexistente.", false);
            ToastService.Error("No se pueden crear partidos en una competencia archivada o inexistente.");
            return;
        }

        var roundName = MatchRoundName();
        var startsAt = new DateTimeOffset(DateTime.SpecifyKind(startsAtLocal, DateTimeKind.Local)).ToUniversalTime();
        var validation = await FixtureRulesService.ValidateMatchCreationAsync(new FixtureMatchRulesRequest(
            newMatchCompetitionId.Value,
            roundName,
            RoundSortOrderOrNull(roundName),
            newMatchHomeTeamId.Value,
            newMatchAwayTeamId.Value,
            startsAt));
        if (!validation.IsValid)
        {
            SetMessage(validation.FirstError ?? "El partido no cumple las reglas de fixture.", false);
            ToastService.Warning(validation.FirstError ?? "El partido no cumple las reglas de fixture.");
            return;
        }

        var round = await Db.Rounds.FirstOrDefaultAsync(x => x.CompetitionId == newMatchCompetitionId && x.Name == roundName);
        if (round is null)
        {
            var nextSortOrder = await Db.Rounds
                .Where(x => x.CompetitionId == newMatchCompetitionId)
                .Select(x => (int?)x.SortOrder)
                .MaxAsync() ?? 0;
            round = new Round(newMatchCompetitionId.Value, roundName, nextSortOrder + 1);
            Db.Rounds.Add(round);
        }

        Db.Matches.Add(new Match(newMatchCompetitionId.Value, round.Id, newMatchHomeTeamId.Value, newMatchAwayTeamId.Value, startsAt, status: MatchStatus.Scheduled));
        await Db.SaveChangesAsync();
        newMatchHomeTeamId = null;
        newMatchAwayTeamId = null;
        newMatchStartsAt = string.Empty;
        SetMessage("Partido creado correctamente.", true);
        ToastService.Success("Partido creado correctamente.");
        await LoadAsync();
    }

    private async Task PreviewFixtureCsvAsync()
    {
        if (newMatchCompetitionId is null)
        {
            SetMessage("Selecciona una competencia antes de previsualizar el CSV.", false);
            ToastService.Warning("Selecciona una competencia antes de previsualizar el CSV.");
            return;
        }

        if (string.IsNullOrWhiteSpace(fixtureCsvInput))
        {
            SetMessage("Pega el contenido CSV para previsualizar.", false);
            ToastService.Info("Pega el contenido CSV para previsualizar.");
            return;
        }

        fixtureCsvPreview = await FixtureCsvImportService.PreviewAsync(newMatchCompetitionId.Value, fixtureCsvInput);
        SetMessage($"Preview generado: {fixtureCsvPreview.ValidCount} fila(s) valida(s) de {fixtureCsvPreview.Rows.Count}.", fixtureCsvPreview.ValidCount > 0);
        var previewMessage = $"Preview generado: {fixtureCsvPreview.ValidCount} fila(s) valida(s) de {fixtureCsvPreview.Rows.Count}.";
        if (fixtureCsvPreview.ValidCount == 0)
        {
            ToastService.Warning(previewMessage);
        }
        else if (fixtureCsvPreview.ValidCount < fixtureCsvPreview.Rows.Count)
        {
            ToastService.Warning(previewMessage);
        }
        else
        {
            ToastService.Info(previewMessage);
        }
    }

    private async Task ConfirmFixtureCsvImportAsync()
    {
        if (newMatchCompetitionId is null || fixtureCsvPreview is null)
        {
            SetMessage("Genera una previsualizacion antes de importar.", false);
            ToastService.Info("Genera una nueva previsualizacion antes de confirmar otra importacion.");
            return;
        }

        var validRows = fixtureCsvPreview.Rows
            .Where(x => x.Status == FixtureCsvRowStatus.Valid)
            .Select(x => x.RowNumber)
            .ToList();
        if (validRows.Count == 0)
        {
            SetMessage("No hay filas validas para importar.", false);
            ToastService.Warning("No hay filas validas para importar.");
            return;
        }

        var failedRows = fixtureCsvPreview.Rows.Count - validRows.Count;
        isSaving = true;
        try
        {
            var result = await FixtureCsvImportService.ImportAsync(newMatchCompetitionId.Value, validRows, fixtureCsvInput);
            fixtureCsvPreview = null;
            await SafeReloadAsync();
            var failedMessage = failedRows > 0 ? $" {failedRows} fila(s) fallaron y no se guardaron." : string.Empty;
            SetMessage($"Se importaron {result.ImportedCount} partido(s).{failedMessage} Genera una nueva previsualizacion para volver a importar.", true);
            if (failedRows > 0)
            {
                ToastService.Warning($"Se importaron {result.ImportedCount} partido(s), pero {failedRows} fila(s) fallaron.");
                ToastService.Info("Genera una nueva previsualizacion antes de confirmar otra importacion.");
            }
            else
            {
                ToastService.Success($"Se importaron {result.ImportedCount} partido(s).");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fixture CSV import failed after confirmation for competition {CompetitionId}.", newMatchCompetitionId);
            fixtureCsvPreview = null;
            await SafeReloadAsync();
            SetMessage("No se pudo completar la importacion. Si algunos partidos se guardaron, genera una nueva previsualizacion antes de intentar otra vez.", false);
            ToastService.Error("No se pudo completar la importacion.");
        }
        finally
        {
            isSaving = false;
        }
    }

    private Task PreviewGeneratedFixtureAsync()
    {
        if (newMatchCompetitionId is null)
        {
            SetMessage("Selecciona una competencia antes de generar fixture.", false);
            ToastService.Warning("Selecciona una competencia antes de generar fixture.");
            return Task.CompletedTask;
        }

        if (matchTeamOptions.Count < 2)
        {
            fixtureGeneratorPreview = null;
            SetMessage("La competencia necesita al menos dos equipos activos para generar fixture.", false);
            ToastService.Warning("La competencia necesita al menos dos equipos activos para generar fixture.");
            return Task.CompletedTask;
        }

        if (!DateOnly.TryParse(fixtureGeneratorStartDate, out var startDate))
        {
            fixtureGeneratorPreview = null;
            SetMessage("Fecha inicial invalida.", false);
            ToastService.Warning("Fecha inicial invalida.");
            return Task.CompletedTask;
        }

        if (!int.TryParse(fixtureGeneratorDaysBetweenRounds, out var daysBetweenRounds) || daysBetweenRounds < 1)
        {
            fixtureGeneratorPreview = null;
            SetMessage("Los dias entre jornadas deben ser un entero positivo.", false);
            ToastService.Warning("Los dias entre jornadas deben ser un entero positivo.");
            return Task.CompletedTask;
        }

        if (!TimeOnly.TryParse(fixtureGeneratorDefaultTime, out var defaultTime))
        {
            fixtureGeneratorPreview = null;
            SetMessage("Horario por defecto invalido.", false);
            ToastService.Warning("Horario por defecto invalido.");
            return Task.CompletedTask;
        }

        var request = new FixtureGeneratorRequest(
            matchTeamOptions.Select(team => new FixtureGeneratorTeam(team.Id, team.Label)).ToList(),
            startDate,
            daysBetweenRounds,
            defaultTime,
            fixtureGeneratorHomeAndAway);

        fixtureGeneratorPreview = FixtureGeneratorService.Preview(request);
        if (!fixtureGeneratorPreview.IsValid)
        {
            SetMessage("El fixture generado tiene conflictos. Revisa el preview antes de confirmar.", false);
            ToastService.Error("El fixture generado tiene conflictos. Revisa el preview antes de confirmar.");
            return Task.CompletedTask;
        }

        SetMessage($"Preview generado: {fixtureGeneratorPreview.RoundCount} jornada(s), {fixtureGeneratorPreview.MatchCount} partido(s).", fixtureGeneratorPreview.MatchCount > 0);
        ToastService.Info($"Preview generado: {fixtureGeneratorPreview.RoundCount} jornada(s), {fixtureGeneratorPreview.MatchCount} partido(s).");
        return Task.CompletedTask;
    }

    private async Task ConfirmGeneratedFixtureAsync()
    {
        if (newMatchCompetitionId is null || fixtureGeneratorPreview is null)
        {
            SetMessage("Genera una previsualizacion antes de confirmar el fixture.", false);
            ToastService.Info("Genera una previsualizacion antes de confirmar el fixture.");
            return;
        }

        if (fixtureGeneratorPreview.MatchCount == 0)
        {
            SetMessage("No hay partidos para generar.", false);
            ToastService.Warning("No hay partidos para generar.");
            return;
        }

        var validationError = await ValidateGeneratedFixtureForSaveAsync(newMatchCompetitionId.Value, fixtureGeneratorPreview);
        if (validationError is not null)
        {
            SetMessage(validationError, false);
            ToastService.Error(validationError);
            return;
        }

        isSaving = true;
        try
        {
            var importedCount = 0;
            foreach (var previewRound in fixtureGeneratorPreview.Rounds)
            {
                var round = await FindOrCreateRoundBySortOrderAsync(newMatchCompetitionId.Value, previewRound.RoundName, previewRound.RoundNumber);
                foreach (var previewMatch in previewRound.Matches.Where(match => !match.IsBye && match.AwayTeamId is not null))
                {
                    var startsAt = ToUtc(previewMatch.Date.ToDateTime(previewMatch.Time).ToString("yyyy-MM-ddTHH:mm"));
                    Db.Matches.Add(new Match(
                        newMatchCompetitionId.Value,
                        round.Id,
                        previewMatch.HomeTeamId,
                        previewMatch.AwayTeamId!.Value,
                        startsAt,
                        status: MatchStatus.Scheduled));
                    importedCount++;
                }
            }

            await Db.SaveChangesAsync();
            fixtureGeneratorPreview = null;
            await LoadFixtureSafetyCountsAsync();
            SetMessage($"Se generaron {importedCount} partido(s).", true);
            ToastService.Success($"Se generaron {importedCount} partido(s).");
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ClearFixtureAsync()
    {
        if (isSaving)
        {
            return;
        }

        if (newMatchCompetitionId is null)
        {
            SetMessage("Selecciona una competencia para limpiar fixture.", false);
            ToastService.Warning("Selecciona una competencia para limpiar fixture.");
            return;
        }

        isSaving = true;
        try
        {
            var matchIdsToDelete = await FixtureRulesService.GetSafeDeletableMatchIdsAsync(newMatchCompetitionId.Value);
            if (matchIdsToDelete.Count == 0)
            {
                SetMessage("No hay partidos programados seguros para eliminar.", false);
                ToastService.Info("No hay partidos programados seguros para eliminar.");
                await LoadFixtureSafetyCountsAsync();
                return;
            }

            var matchesToDelete = await Db.Matches
                .Where(match => matchIdsToDelete.Contains(match.Id))
                .ToListAsync();
            Db.Matches.RemoveRange(matchesToDelete);
            await Db.SaveChangesAsync();
            fixtureGeneratorPreview = null;
            SetMessage($"Se eliminaron {matchesToDelete.Count} partido(s) programado(s).", true);
            ToastService.Success($"Se eliminaron {matchesToDelete.Count} partido(s) programado(s).");
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RegenerateFixtureAsync()
    {
        if (isSaving)
        {
            return;
        }

        if (newMatchCompetitionId is null)
        {
            SetMessage("Selecciona una competencia para regenerar fixture.", false);
            ToastService.Warning("Selecciona una competencia para regenerar fixture.");
            return;
        }

        var hasBlockedMatches = await FixtureRulesService.HasBlockingMatchesForRegenerationAsync(newMatchCompetitionId.Value);

        if (hasBlockedMatches)
        {
            SetMessage("No se puede regenerar porque la competencia tiene partidos con eventos, resultados o estado avanzado.", false);
            ToastService.Error("No se puede regenerar: hay partidos con eventos o resultados.");
            return;
        }

        isSaving = true;
        try
        {
            var matchIdsToDelete = await FixtureRulesService.GetSafeDeletableMatchIdsAsync(newMatchCompetitionId.Value);
            if (matchIdsToDelete.Count > 0)
            {
                var matchesToDelete = await Db.Matches
                    .Where(match => matchIdsToDelete.Contains(match.Id))
                    .ToListAsync();
                Db.Matches.RemoveRange(matchesToDelete);
                await Db.SaveChangesAsync();
            }

            fixtureGeneratorPreview = null;
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }

        await PreviewGeneratedFixtureAsync();
    }

    private async Task<string?> ValidateGeneratedFixtureForSaveAsync(Guid competitionId, FixtureGeneratorPreviewResult preview)
    {
        if (!preview.IsValid)
        {
            return string.Join(" ", preview.ValidationErrors);
        }

        var batch = preview.Rounds
            .SelectMany(round => round.Matches
                .Where(match => !match.IsBye && match.AwayTeamId is not null)
                .Select(match => new FixtureBatchMatchRequest(
                    $"{round.RoundName} - {match.HomeTeamName} vs {match.AwayTeamName}",
                    round.RoundName,
                    round.RoundNumber,
                    match.HomeTeamId,
                    match.AwayTeamId!.Value,
                    ToUtc(match.Date.ToDateTime(match.Time).ToString("yyyy-MM-ddTHH:mm")))))
            .ToList();

        var validation = await FixtureRulesService.ValidateFixtureBatchAsync(competitionId, batch);
        return validation.IsValid ? null : validation.FirstError;
    }

    private async Task SafeReloadAsync()
    {
        try
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload league admin data after fixture CSV import.");
        }
    }

    private SeasonEditModel GetSeasonEdit(Guid seasonId) => seasonEdits.TryGetValue(seasonId, out var edit) ? edit : new SeasonEditModel();
    private CompetitionEditModel GetCompetitionEdit(Guid competitionId) => competitionEdits.TryGetValue(competitionId, out var edit) ? edit : new CompetitionEditModel();
    private MatchEditModel GetMatchEdit(Match match) => matchEdits.TryGetValue(match.Id, out var edit)
        ? edit
        : new MatchEditModel(match.Round?.Name ?? "Fecha 1", match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"), match.HomeTeamId, match.AwayTeamId, match.Status);

    private string MatchRoundName() => string.IsNullOrWhiteSpace(newMatchRoundName) ? "Fecha 1" : newMatchRoundName.Trim();

    private static int RoundSortValue(string roundName)
    {
        var digits = new string(roundName.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var value) ? value : int.MaxValue;
    }

    private static int? RoundSortOrderOrNull(string roundName)
    {
        var digits = new string(roundName.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var value) ? value : null;
    }

    private void BeginMatchEdit(Match match)
    {
        newMatchCompetitionId = match.CompetitionId;
        editingMatchId = match.Id;
        matchEdits[match.Id] = new MatchEditModel(
            match.Round?.Name ?? "Fecha 1",
            match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"),
            match.HomeTeamId,
            match.AwayTeamId,
            match.Status);
    }

    private void CancelMatchEdit()
    {
        editingMatchId = null;
    }

    private async Task SaveMatchAsync(Guid matchId)
    {
        if (newMatchCompetitionId is null || !matchEdits.TryGetValue(matchId, out var edit))
        {
            SetMessage("No se encontro la edicion del partido.", false);
            ToastService.Error("No se encontro la edicion del partido.");
            return;
        }

        var validation = await ValidateMatchEditAsync(newMatchCompetitionId.Value, edit, matchId);
        if (validation is not null)
        {
            SetMessage(validation, false);
            ToastService.Warning(validation);
            return;
        }

        var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == matchId && x.CompetitionId == newMatchCompetitionId);
        if (match is null)
        {
            SetMessage("Partido no encontrado.", false);
            ToastService.Error("Partido no encontrado.");
            return;
        }

        var roundName = string.IsNullOrWhiteSpace(edit.RoundName) ? "Fecha 1" : edit.RoundName.Trim();
        var round = await FindOrCreateRoundAsync(newMatchCompetitionId.Value, roundName);
        var startsAt = ToUtc(edit.StartsAt);

        isSaving = true;
        try
        {
            Db.Entry(match).Property(x => x.RoundId).CurrentValue = round.Id;
            Db.Entry(match).Property(x => x.HomeTeamId).CurrentValue = edit.HomeTeamId;
            Db.Entry(match).Property(x => x.AwayTeamId).CurrentValue = edit.AwayTeamId;
            Db.Entry(match).Property(x => x.StartsAt).CurrentValue = startsAt;
            Db.Entry(match).Property(x => x.Status).CurrentValue = edit.Status;
            await Db.SaveChangesAsync();
            editingMatchId = null;
            SetMessage("Partido actualizado correctamente.", true);
            ToastService.Success("Partido actualizado correctamente.");
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CancelExistingMatchAsync(Guid matchId)
    {
        var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == matchId);
        if (match is null)
        {
            SetMessage("Partido no encontrado.", false);
            return;
        }

        Db.Entry(match).Property(x => x.Status).CurrentValue = MatchStatus.Cancelled;
        await Db.SaveChangesAsync();
        SetMessage("Partido marcado como cancelado.", true);
        await LoadAsync();
    }

    private async Task<string?> ValidateMatchEditAsync(Guid competitionId, MatchEditModel edit, Guid currentMatchId)
    {
        if (!DateTime.TryParse(edit.StartsAt, out _))
        {
            return "Fecha/hora de partido invalida.";
        }

        var roundName = string.IsNullOrWhiteSpace(edit.RoundName) ? "Fecha 1" : edit.RoundName.Trim();
        var startsAt = ToUtc(edit.StartsAt);
        var validation = await FixtureRulesService.ValidateMatchUpdateAsync(currentMatchId, new FixtureMatchRulesRequest(
            competitionId,
            roundName,
            RoundSortOrderOrNull(roundName),
            edit.HomeTeamId,
            edit.AwayTeamId,
            startsAt));

        return validation.IsValid ? null : validation.FirstError;
    }

    private async Task<Round> FindOrCreateRoundAsync(Guid competitionId, string roundName)
    {
        var round = await Db.Rounds.FirstOrDefaultAsync(x => x.CompetitionId == competitionId && x.Name == roundName);
        if (round is not null)
        {
            return round;
        }

        var nextSortOrder = await Db.Rounds
            .Where(x => x.CompetitionId == competitionId)
            .Select(x => (int?)x.SortOrder)
            .MaxAsync() ?? 0;
        round = new Round(competitionId, roundName, nextSortOrder + 1);
        Db.Rounds.Add(round);
        return round;
    }

    private async Task<Round> FindOrCreateRoundBySortOrderAsync(Guid competitionId, string roundName, int sortOrder)
    {
        var round = await Db.Rounds.FirstOrDefaultAsync(x => x.CompetitionId == competitionId && x.SortOrder == sortOrder);
        if (round is not null)
        {
            return round;
        }

        round = new Round(competitionId, roundName, sortOrder);
        Db.Rounds.Add(round);
        return round;
    }

    private static DateTimeOffset ToUtc(string localDateTime)
    {
        var parsed = DateTime.Parse(localDateTime);
        return new DateTimeOffset(DateTime.SpecifyKind(parsed, DateTimeKind.Local)).ToUniversalTime();
    }

    private static bool TryParseSeason(string nameInput, string startsInput, string endsInput, out string name, out DateOnly startsOn, out DateOnly endsOn, out string error)
    {
        name = nameInput.Trim();
        startsOn = default;
        endsOn = default;
        if (string.IsNullOrWhiteSpace(name) || !DateOnly.TryParse(startsInput, out startsOn) || !DateOnly.TryParse(endsInput, out endsOn))
        {
            error = "Nombre, fecha de inicio y fecha de fin son obligatorios.";
            return false;
        }

        if (endsOn < startsOn)
        {
            error = "La fecha de fin no puede ser anterior al inicio.";
            return false;
        }

        error = string.Empty;
        return true;
    }

    private void SetMessage(string message, bool success)
    {
        statusMessage = message;
        isSuccessMessage = success;
    }

    private static string LocationText(string region, string country)
    {
        if (string.IsNullOrWhiteSpace(region))
        {
            return country;
        }

        if (string.IsNullOrWhiteSpace(country))
        {
            return region;
        }

        return $"{region}, {country}";
    }

