    private async Task CreateMatchAsync()
    {
        if (newMatchCompetitionId is null || newMatchHomeTeamId is null || newMatchAwayTeamId is null)
        {
            SetMessage("Competencia, local y visitante son obligatorios.", false);
            return;
        }

        if (newMatchHomeTeamId == newMatchAwayTeamId)
        {
            SetMessage("Local y visitante deben ser distintos.", false);
            return;
        }

        if (!DateTime.TryParse(newMatchStartsAt, out var startsAtLocal))
        {
            SetMessage("Fecha/hora de partido invalida.", false);
            return;
        }

        var competitionIsActive = await Db.Competitions.AnyAsync(x => x.Id == newMatchCompetitionId && x.IsActive && x.Season!.LeagueId == Id);
        if (!competitionIsActive)
        {
            SetMessage("No se pueden crear partidos en una competencia archivada o inexistente.", false);
            return;
        }

        var teamIds = await Db.Teams
            .AsNoTracking()
            .Where(x => x.CompetitionId == newMatchCompetitionId && x.IsActive && x.Club!.IsActive)
            .Select(x => x.Id)
            .ToListAsync();
        if (!teamIds.Contains(newMatchHomeTeamId.Value) || !teamIds.Contains(newMatchAwayTeamId.Value))
        {
            SetMessage("Ambos equipos deben pertenecer a la competencia.", false);
            return;
        }

        var roundName = MatchRoundName();
        if (await TeamAlreadyPlaysInRoundAsync(newMatchCompetitionId.Value, roundName, newMatchHomeTeamId.Value, newMatchAwayTeamId.Value, null))
        {
            SetMessage("Un equipo no puede jugar mas de un partido en la misma jornada de la competencia.", false);
            return;
        }

        var startsAt = new DateTimeOffset(DateTime.SpecifyKind(startsAtLocal, DateTimeKind.Local)).ToUniversalTime();
        var duplicateMatch = await Db.Matches.AnyAsync(x =>
            x.CompetitionId == newMatchCompetitionId &&
            x.HomeTeamId == newMatchHomeTeamId &&
            x.AwayTeamId == newMatchAwayTeamId &&
            x.StartsAt == startsAt);
        if (duplicateMatch)
        {
            SetMessage("Ya existe un partido con el mismo local, visitante y fecha/hora.", false);
            return;
        }

        var round = await Db.Rounds.FirstOrDefaultAsync(x => x.CompetitionId == newMatchCompetitionId && x.Name == roundName);
        if (round is null)
        {
            var nextSortOrder = await Db.Rounds
                .Where(x => x.CompetitionId == newMatchCompetitionId)
                .Select(x => (int?)x.SortOrder)
                .MaxAsync() ?? 0;
            round = new Round(newMatchCompetitionId.Value, roundName, nextSortOrder + 1);
            Db.Rounds.Add(round);
        }

        Db.Matches.Add(new Match(newMatchCompetitionId.Value, round.Id, newMatchHomeTeamId.Value, newMatchAwayTeamId.Value, startsAt, status: MatchStatus.Scheduled));
        await Db.SaveChangesAsync();
        newMatchHomeTeamId = null;
        newMatchAwayTeamId = null;
        newMatchStartsAt = string.Empty;
        SetMessage("Partido creado correctamente.", true);
        await LoadAsync();
    }

    private async Task PreviewFixtureCsvAsync()
    {
        if (newMatchCompetitionId is null)
        {
            SetMessage("Selecciona una competencia antes de previsualizar el CSV.", false);
            return;
        }

        if (string.IsNullOrWhiteSpace(fixtureCsvInput))
        {
            SetMessage("Pega el contenido CSV para previsualizar.", false);
            return;
        }

        fixtureCsvPreview = await FixtureCsvImportService.PreviewAsync(newMatchCompetitionId.Value, fixtureCsvInput);
        SetMessage($"Preview generado: {fixtureCsvPreview.ValidCount} fila(s) valida(s) de {fixtureCsvPreview.Rows.Count}.", fixtureCsvPreview.ValidCount > 0);
    }

    private async Task ConfirmFixtureCsvImportAsync()
    {
        if (newMatchCompetitionId is null || fixtureCsvPreview is null)
        {
            SetMessage("Genera una previsualizacion antes de importar.", false);
            return;
        }

        var validRows = fixtureCsvPreview.Rows
            .Where(x => x.Status == FixtureCsvRowStatus.Valid)
            .Select(x => x.RowNumber)
            .ToList();
        if (validRows.Count == 0)
        {
            SetMessage("No hay filas validas para importar.", false);
            return;
        }

        var failedRows = fixtureCsvPreview.Rows.Count - validRows.Count;
        isSaving = true;
        try
        {
            var result = await FixtureCsvImportService.ImportAsync(newMatchCompetitionId.Value, validRows, fixtureCsvInput);
            fixtureCsvPreview = null;
            await SafeReloadAsync();
            var failedMessage = failedRows > 0 ? $" {failedRows} fila(s) fallaron y no se guardaron." : string.Empty;
            SetMessage($"Se importaron {result.ImportedCount} partido(s).{failedMessage} Genera una nueva previsualizacion para volver a importar.", true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fixture CSV import failed after confirmation for competition {CompetitionId}.", newMatchCompetitionId);
            fixtureCsvPreview = null;
            await SafeReloadAsync();
            SetMessage("No se pudo completar la importacion. Si algunos partidos se guardaron, genera una nueva previsualizacion antes de intentar otra vez.", false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SafeReloadAsync()
    {
        try
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload league admin data after fixture CSV import.");
        }
    }

    private SeasonEditModel GetSeasonEdit(Guid seasonId) => seasonEdits.TryGetValue(seasonId, out var edit) ? edit : new SeasonEditModel();
    private CompetitionEditModel GetCompetitionEdit(Guid competitionId) => competitionEdits.TryGetValue(competitionId, out var edit) ? edit : new CompetitionEditModel();
    private MatchEditModel GetMatchEdit(Match match) => matchEdits.TryGetValue(match.Id, out var edit)
        ? edit
        : new MatchEditModel(match.Round?.Name ?? "Fecha 1", match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"), match.HomeTeamId, match.AwayTeamId, match.Status);

    private string MatchRoundName() => string.IsNullOrWhiteSpace(newMatchRoundName) ? "Fecha 1" : newMatchRoundName.Trim();

    private bool IsRoundOpen(IGrouping<string, Match> group)
    {
        if (editingMatchId is not null && group.Any(x => x.Id == editingMatchId))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(matchRoundFilter))
        {
            return true;
        }

        var nextActiveGroup = SelectedCompetitionMatchGroups
            .Where(x => x.Any(match => match.Status is MatchStatus.Scheduled or MatchStatus.Live or MatchStatus.HalfTime))
            .OrderBy(x => x.Min(match => match.StartsAt))
            .FirstOrDefault();

        return nextActiveGroup is null
            ? group == SelectedCompetitionMatchGroups.First()
            : group.Key == nextActiveGroup.Key;
    }

    private static string RoundDateRange(IEnumerable<Match> matches)
    {
        var ordered = matches.OrderBy(x => x.StartsAt).ToList();
        if (ordered.Count == 0)
        {
            return "Sin partidos";
        }

        var first = ordered.First().StartsAt.LocalDateTime;
        var last = ordered.Last().StartsAt.LocalDateTime;
        return first.Date == last.Date
            ? first.ToString("dd/MM/yyyy")
            : $"{first:dd/MM/yyyy} - {last:dd/MM/yyyy}";
    }

    private static int RoundSortValue(string roundName)
    {
        var digits = new string(roundName.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var value) ? value : int.MaxValue;
    }

    private void BeginMatchEdit(Match match)
    {
        newMatchCompetitionId = match.CompetitionId;
        editingMatchId = match.Id;
        matchEdits[match.Id] = new MatchEditModel(
            match.Round?.Name ?? "Fecha 1",
            match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"),
            match.HomeTeamId,
            match.AwayTeamId,
            match.Status);
    }

    private void CancelMatchEdit()
    {
        editingMatchId = null;
    }

    private async Task SaveMatchAsync(Guid matchId)
    {
        if (newMatchCompetitionId is null || !matchEdits.TryGetValue(matchId, out var edit))
        {
            SetMessage("No se encontro la edicion del partido.", false);
            return;
        }

        var validation = await ValidateMatchEditAsync(newMatchCompetitionId.Value, edit, matchId);
        if (validation is not null)
        {
            SetMessage(validation, false);
            return;
        }

        var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == matchId && x.CompetitionId == newMatchCompetitionId);
        if (match is null)
        {
            SetMessage("Partido no encontrado.", false);
            return;
        }

        var roundName = string.IsNullOrWhiteSpace(edit.RoundName) ? "Fecha 1" : edit.RoundName.Trim();
        var round = await FindOrCreateRoundAsync(newMatchCompetitionId.Value, roundName);
        var startsAt = ToUtc(edit.StartsAt);

        isSaving = true;
        try
        {
            Db.Entry(match).Property(x => x.RoundId).CurrentValue = round.Id;
            Db.Entry(match).Property(x => x.HomeTeamId).CurrentValue = edit.HomeTeamId;
            Db.Entry(match).Property(x => x.AwayTeamId).CurrentValue = edit.AwayTeamId;
            Db.Entry(match).Property(x => x.StartsAt).CurrentValue = startsAt;
            Db.Entry(match).Property(x => x.Status).CurrentValue = edit.Status;
            await Db.SaveChangesAsync();
            editingMatchId = null;
            SetMessage("Partido actualizado correctamente.", true);
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CancelExistingMatchAsync(Guid matchId)
    {
        var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == matchId);
        if (match is null)
        {
            SetMessage("Partido no encontrado.", false);
            return;
        }

        Db.Entry(match).Property(x => x.Status).CurrentValue = MatchStatus.Cancelled;
        await Db.SaveChangesAsync();
        SetMessage("Partido marcado como cancelado.", true);
        await LoadAsync();
    }

    private async Task<string?> ValidateMatchEditAsync(Guid competitionId, MatchEditModel edit, Guid currentMatchId)
    {
        if (edit.HomeTeamId == edit.AwayTeamId)
        {
            return "Local y visitante deben ser distintos.";
        }

        if (!DateTime.TryParse(edit.StartsAt, out _))
        {
            return "Fecha/hora de partido invalida.";
        }

        var teamIds = await Db.Teams
            .AsNoTracking()
            .Where(x => x.CompetitionId == competitionId && x.IsActive && x.Club!.IsActive)
            .Select(x => x.Id)
            .ToListAsync();
        if (!teamIds.Contains(edit.HomeTeamId) || !teamIds.Contains(edit.AwayTeamId))
        {
            return "Ambos equipos deben estar activos y pertenecer a la competencia.";
        }

        var roundName = string.IsNullOrWhiteSpace(edit.RoundName) ? "Fecha 1" : edit.RoundName.Trim();
        if (await TeamAlreadyPlaysInRoundAsync(competitionId, roundName, edit.HomeTeamId, edit.AwayTeamId, currentMatchId))
        {
            return "Un equipo no puede jugar mas de un partido en la misma jornada de la competencia.";
        }

        var startsAt = ToUtc(edit.StartsAt);
        var duplicateMatch = await Db.Matches.AnyAsync(x =>
            x.CompetitionId == competitionId &&
            x.Id != currentMatchId &&
            x.HomeTeamId == edit.HomeTeamId &&
            x.AwayTeamId == edit.AwayTeamId &&
            x.StartsAt == startsAt);
        return duplicateMatch ? "Ya existe un partido con el mismo local, visitante y fecha/hora." : null;
    }

    private async Task<bool> TeamAlreadyPlaysInRoundAsync(Guid competitionId, string roundName, Guid homeTeamId, Guid awayTeamId, Guid? currentMatchId)
    {
        return await Db.Matches.AnyAsync(x =>
            x.CompetitionId == competitionId &&
            (currentMatchId == null || x.Id != currentMatchId.Value) &&
            x.Round!.Name == roundName &&
            (x.HomeTeamId == homeTeamId ||
             x.AwayTeamId == homeTeamId ||
             x.HomeTeamId == awayTeamId ||
             x.AwayTeamId == awayTeamId));
    }

    private async Task<Round> FindOrCreateRoundAsync(Guid competitionId, string roundName)
    {
        var round = await Db.Rounds.FirstOrDefaultAsync(x => x.CompetitionId == competitionId && x.Name == roundName);
        if (round is not null)
        {
            return round;
        }

        var nextSortOrder = await Db.Rounds
            .Where(x => x.CompetitionId == competitionId)
            .Select(x => (int?)x.SortOrder)
            .MaxAsync() ?? 0;
        round = new Round(competitionId, roundName, nextSortOrder + 1);
        Db.Rounds.Add(round);
        return round;
    }

    private static DateTimeOffset ToUtc(string localDateTime)
    {
        var parsed = DateTime.Parse(localDateTime);
        return new DateTimeOffset(DateTime.SpecifyKind(parsed, DateTimeKind.Local)).ToUniversalTime();
    }

    private static bool TryParseSeason(string nameInput, string startsInput, string endsInput, out string name, out DateOnly startsOn, out DateOnly endsOn, out string error)
    {
        name = nameInput.Trim();
        startsOn = default;
        endsOn = default;
        if (string.IsNullOrWhiteSpace(name) || !DateOnly.TryParse(startsInput, out startsOn) || !DateOnly.TryParse(endsInput, out endsOn))
        {
            error = "Nombre, fecha de inicio y fecha de fin son obligatorios.";
            return false;
        }

        if (endsOn < startsOn)
        {
            error = "La fecha de fin no puede ser anterior al inicio.";
            return false;
        }

        error = string.Empty;
        return true;
    }

    private void SetMessage(string message, bool success)
    {
        statusMessage = message;
        isSuccessMessage = success;
    }

    private static string LocationText(string region, string country)
    {
        if (string.IsNullOrWhiteSpace(region))
        {
            return country;
        }

        if (string.IsNullOrWhiteSpace(country))
        {
            return region;
        }

        return $"{region}, {country}";
    }

