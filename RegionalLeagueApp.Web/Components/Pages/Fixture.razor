@page "/fixture"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Fixture</PageTitle>

<div class="page-heading">
    <p class="eyebrow">Fixture</p>
    <h1>Partidos programados</h1>
</div>

@if (matches.Count == 0)
{
    <EmptyState Text="No hay partidos programados." />
}
else
{
    @foreach (var group in matches.GroupBy(x => x.Round?.Name ?? "Sin fecha"))
    {
        <section class="panel section-gap">
            <h2>@group.Key</h2>
            <div class="match-list">
                @foreach (var match in group)
                {
                    <MatchSummary Match="match" />
                }
            </div>
        </section>
    }
}

@code {
    private List<Match> matches = [];
    private Func<Task>? reloadHandler;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        matches = await Db.Matches
            .AsNoTracking()
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == MatchStatus.Scheduled || x.Status == MatchStatus.Postponed)
            .OrderBy(x => x.Round!.SortOrder)
            .ThenBy(x => x.StartsAt)
            .ToListAsync();
    }
}
