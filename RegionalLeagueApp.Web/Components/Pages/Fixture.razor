@page "/fixture"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Fixture</PageTitle>

<PageBreadcrumb BackHref="@BreadcrumbBackHref" ParentHref="@BreadcrumbParentHref" ParentLabel="@BreadcrumbParentLabel" CurrentLabel="@BreadcrumbCurrentLabel" />

<div class="page-heading">
    <p class="eyebrow">Fixture</p>
    <h1>@PageTitleText</h1>
</div>

<LeagueCompetitionFilter Path="/fixture" LeagueId="@LeagueId" CompetitionId="@CompetitionId" />

@if (matches.Count == 0)
{
    <EmptyState Text="@EmptyText" />
}
else
{
    @foreach (var group in matches.GroupBy(MatchGroupLabel))
    {
        <section class="panel section-gap">
            <h2>@group.Key</h2>
            <div class="match-list">
                @foreach (var match in group)
                {
                    <MatchSummary Match="match" />
                }
            </div>
        </section>
    }
}

@code {
    private List<Match> matches = [];
    private Func<Task>? reloadHandler;
    private string? leagueName;
    private string? competitionName;

    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }
    [SupplyParameterFromQuery] public Guid? CompetitionId { get; set; }

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Partidos programados"
        : $"Fixture - {leagueName}";

    private string EmptyText => CompetitionId is not null
        ? "No hay partidos programados para esta competencia."
        : "No hay partidos programados.";

    private string BreadcrumbBackHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentLabel => LeagueId is null ? "Inicio" : leagueName ?? "Liga";

    private string BreadcrumbCurrentLabel => string.IsNullOrWhiteSpace(competitionName)
        ? "Fixture"
        : $"{competitionName} / Fixture";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        competitionName = CompetitionId is null
            ? null
            : await Db.Competitions
                .AsNoTracking()
                .Where(x => x.Id == CompetitionId && x.IsActive)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var query = Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)!.ThenInclude(x => x!.Season)
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x =>
                (x.Status == MatchStatus.Scheduled || x.Status == MatchStatus.Postponed) &&
                x.Competition!.IsActive &&
                x.Competition.Season!.League!.IsActive &&
                x.HomeTeam!.IsActive &&
                x.HomeTeam.Club!.IsActive &&
                x.AwayTeam!.IsActive &&
                x.AwayTeam.Club!.IsActive);

        if (LeagueId is not null)
        {
            query = query.Where(x => x.Competition!.Season!.LeagueId == LeagueId);
        }

        if (CompetitionId is not null)
        {
            query = query.Where(x => x.CompetitionId == CompetitionId);
        }

        var loadedMatches = await query
            .OrderBy(x => x.Round!.SortOrder)
            .ThenBy(x => x.StartsAt)
            .ToListAsync();

        matches = loadedMatches
            .DistinctBy(MatchDisplayKey)
            .ToList();
    }

    private static object MatchDisplayKey(Match match) => new
    {
        RoundName = match.Round?.Name ?? string.Empty,
        match.StartsAt,
        Home = match.HomeTeam?.Club?.Name ?? match.HomeTeam?.Name ?? string.Empty,
        Away = match.AwayTeam?.Club?.Name ?? match.AwayTeam?.Name ?? string.Empty,
        match.Status
    };

    private string MatchGroupLabel(Match match)
    {
        var competition = match.Competition?.Name ?? "Competencia";
        var round = match.Round?.Name ?? "Sin fecha";
        if (LeagueId is not null)
        {
            return $"{competition} - {round}";
        }

        var league = match.Competition?.Season?.League?.Name ?? "Liga";
        return $"{league} - {competition} - {round}";
    }
}
