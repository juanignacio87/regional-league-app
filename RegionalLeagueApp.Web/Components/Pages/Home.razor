@page "/"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Standings
@inject ApplicationDbContext Db
@inject IStandingsQueryService StandingsQueryService
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Liga Regional</PageTitle>

<section class="home-hero">
    <div class="home-hero__content">
        <p class="eyebrow">Liga Regional Norte</p>
        <h1>Partidos, tabla y protagonistas de la liga regional</h1>
        <p>Segui fixture, resultados, goleadores y clubes en una experiencia moderna preparada para carga colaborativa.</p>
        <div class="home-hero__actions">
            <a href="fixture">Ver partidos</a>
            <a href="standings">Ver tabla</a>
        </div>
    </div>
    <div class="home-hero__panel">
        <span>Temporada 2026</span>
        <strong>@HeroStat</strong>
        <small>partidos cargados</small>
    </div>
</section>

<section class="home-section home-live">
    <div class="home-section__title">
        <div>
            <p class="eyebrow">En vivo</p>
            <h2>Partidos destacados</h2>
        </div>
        <a href="fixture">Fixture completo</a>
    </div>

    @if (liveMatches.Count == 0)
    {
        <div class="home-empty">No hay partidos en vivo ahora.</div>
    }
    else
    {
        <div class="home-match-grid">
            @foreach (var match in liveMatches)
            {
                <MatchSummary Match="match" />
            }
        </div>
    }
</section>

<section class="home-main-grid">
    <article class="panel home-card">
        <div class="home-section__title">
            <div>
                <p class="eyebrow">Agenda</p>
                <h2>Proximos partidos</h2>
            </div>
            <a href="fixture">Ver todos</a>
        </div>
        @if (upcomingMatches.Count == 0)
        {
            <div class="home-empty">No hay partidos programados.</div>
        }
        else
        {
            <div class="home-match-list">
                @foreach (var match in upcomingMatches)
                {
                    <MatchSummary Match="match" />
                }
            </div>
        }
    </article>

    <article class="panel home-card">
        <div class="home-section__title">
            <div>
                <p class="eyebrow">Tabla rapida</p>
                <h2>Top 5</h2>
            </div>
            <a href="standings">Tabla completa</a>
        </div>
        @if (topStandings.Count == 0)
        {
            <div class="home-empty">No hay tabla disponible.</div>
        }
        else
        {
            <div class="home-standings-list">
                @foreach (var row in topStandings)
                {
                    <a class="home-standing-row" href="clubs/@row.ClubId">
                        <span>@row.Position</span>
                        <ClubLogo Name="@row.ClubName" LogoPath="@row.ClubLogoPath" Class="club-logo-xs" />
                        <strong>@row.ClubName</strong>
                        <b>@row.Points</b>
                    </a>
                }
            </div>
        }
    </article>
</section>

<section class="home-main-grid">
    <article class="panel home-card">
        <div class="home-section__title">
            <div>
                <p class="eyebrow">Goleadores</p>
                <h2>Destacados</h2>
            </div>
            <a href="scorers">Ranking</a>
        </div>
        @if (topScorers.Count == 0)
        {
            <div class="home-empty">Todavia no hay goles registrados.</div>
        }
        else
        {
            <div class="home-scorer-list">
                @foreach (var scorer in topScorers)
                {
                    <a class="home-scorer-row" href="@PlayerUrl(scorer)">
                        <span>@Initials(scorer.PlayerName)</span>
                        <div>
                            <strong>@scorer.PlayerName</strong>
                            <small>@scorer.TeamName</small>
                        </div>
                        <b>@scorer.Goals</b>
                    </a>
                }
            </div>
        }
    </article>

    <article class="panel home-card">
        <div class="home-section__title">
            <div>
                <p class="eyebrow">Clubes</p>
                <h2>Participantes</h2>
            </div>
            <a href="clubs">Ver clubes</a>
        </div>
        @if (featuredClubs.Count == 0)
        {
            <div class="home-empty">No hay clubes cargados.</div>
        }
        else
        {
            <div class="home-club-grid">
                @foreach (var club in featuredClubs)
                {
                    <a class="home-club-card" href="clubs/@club.Id">
                        <ClubLogo Name="@club.Name" LogoPath="@club.LogoPath" />
                        <strong>@club.ShortName</strong>
                        <small>@club.Name</small>
                    </a>
                }
            </div>
        }
    </article>
</section>

@code {
    private List<Match> liveMatches = [];
    private List<Match> upcomingMatches = [];
    private IReadOnlyList<StandingRowDto> topStandings = [];
    private List<HomeScorerRow> topScorers = [];
    private List<HomeClubRow> featuredClubs = [];
    private int totalMatches;
    private Func<Task>? reloadHandler;

    private string HeroStat => totalMatches.ToString();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        totalMatches = await Db.Matches.AsNoTracking().CountAsync();

        liveMatches = await MatchQuery()
            .Where(x => x.Status == MatchStatus.Live || x.Status == MatchStatus.HalfTime)
            .OrderBy(x => x.StartsAt)
            .Take(4)
            .ToListAsync();

        upcomingMatches = await MatchQuery()
            .Where(x => x.Status == MatchStatus.Scheduled)
            .OrderBy(x => x.StartsAt)
            .Take(6)
            .ToListAsync();

        topStandings = (await StandingsQueryService.GetStandingsAsync()).Take(5).ToList();
        topScorers = await LoadTopScorersAsync();
        featuredClubs = await Db.Clubs
            .AsNoTracking()
            .Where(x => x.IsActive)
            .OrderBy(x => x.Name)
            .Take(8)
            .Select(x => new HomeClubRow(x.Id, x.Name, x.ShortName, x.LogoPath))
            .ToListAsync();
    }

    private IQueryable<Match> MatchQuery() => Db.Matches
        .AsNoTracking()
        .Include(x => x.Round)
        .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
        .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
        .Where(x =>
            x.Competition!.IsActive &&
            x.Competition.Season!.League!.IsActive &&
            x.HomeTeam!.IsActive &&
            x.HomeTeam.Club!.IsActive &&
            x.AwayTeam!.IsActive &&
            x.AwayTeam.Club!.IsActive);

    private async Task<List<HomeScorerRow>> LoadTopScorersAsync()
    {
        var goalEvents = await Db.MatchEvents
            .AsNoTracking()
            .Where(x =>
                x.Type == MatchEventType.Goal &&
                (x.PlayerId != null || x.PlayerName != string.Empty) &&
                x.Team!.IsActive &&
                x.Team.Club!.IsActive &&
                (x.Player == null || x.Player.IsActive))
            .Select(x => new
            {
                x.PlayerId,
                PlayerName = x.PlayerName != string.Empty
                    ? x.PlayerName
                    : x.Player != null
                        ? x.Player.DisplayName
                        : string.Empty,
                TeamName = x.Team != null ? x.Team.Club!.Name : "Sin equipo"
            })
            .ToListAsync();

        return goalEvents
            .Where(x => !string.IsNullOrWhiteSpace(x.PlayerName))
            .GroupBy(x => new
            {
                PlayerKey = x.PlayerId?.ToString() ?? x.PlayerName.Trim().ToUpperInvariant(),
                x.TeamName
            })
            .Select(group => new HomeScorerRow(
                group.First().PlayerId,
                group.OrderByDescending(x => x.PlayerId != null).First().PlayerName,
                group.Key.TeamName,
                group.Count()))
            .OrderByDescending(x => x.Goals)
            .ThenBy(x => x.PlayerName)
            .Take(5)
            .ToList();
    }

    private static string PlayerUrl(HomeScorerRow scorer) =>
        scorer.PlayerId is null ? "scorers" : $"players/{scorer.PlayerId}";

    private static string Initials(string name)
    {
        var initials = string.Concat(name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0]));

        return string.IsNullOrWhiteSpace(initials) ? "JG" : initials.ToUpperInvariant();
    }

    private sealed record HomeScorerRow(Guid? PlayerId, string PlayerName, string TeamName, int Goals);

    private sealed record HomeClubRow(Guid Id, string Name, string ShortName, string? LogoPath);
}
