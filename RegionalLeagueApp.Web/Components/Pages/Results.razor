@page "/results"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Resultados</PageTitle>

<div class="page-heading">
    <p class="eyebrow">Resultados</p>
    <h1>@PageTitleText</h1>
</div>

@if (matches.Count == 0)
{
    <EmptyState Text="Todavia no hay resultados cargados." />
}
else
{
    @foreach (var group in matches.GroupBy(x => $"{x.Competition?.Name ?? "Competencia"} - {x.Round?.Name ?? "Sin fecha"}"))
    {
        <section class="panel section-gap">
            <h2>@group.Key</h2>
            <div class="match-list">
                @foreach (var match in group)
                {
                    <MatchSummary Match="match" />
                }
            </div>
        </section>
    }
}

@code {
    private List<Match> matches = [];
    private Func<Task>? reloadHandler;
    private string? leagueName;

    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Partidos finalizados"
        : $"Resultados - {leagueName}";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var query = Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)!.ThenInclude(x => x!.Season)
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x =>
                x.Status == MatchStatus.Finished &&
                x.Competition!.IsActive &&
                x.Competition.Season!.League!.IsActive &&
                x.HomeTeam!.IsActive &&
                x.HomeTeam.Club!.IsActive &&
                x.AwayTeam!.IsActive &&
                x.AwayTeam.Club!.IsActive);

        if (LeagueId is not null)
        {
            query = query.Where(x => x.Competition!.Season!.LeagueId == LeagueId);
        }

        matches = await query
            .OrderByDescending(x => x.StartsAt)
            .ToListAsync();
    }
}
