@page "/clubs/{Id:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(club?.Name ?? "Club")</PageTitle>

@if (club is null)
{
    <EmptyState Text="Club no encontrado." />
}
else
{
    <PageBreadcrumb BackHref="/clubs" ParentHref="/clubs" ParentLabel="Clubes" CurrentLabel="@club.Name" />

    <section class="club-profile-hero" style="border-color:@HeroAccentColor">
        <ClubLogo Name="@club.Name" LogoPath="@club.LogoPath" Class="club-logo-lg" />
        <div class="club-profile-hero__main">
            <p class="eyebrow">Perfil de club</p>
            <h1>@PublicClubName</h1>
            @if (!string.Equals(PublicClubName, club.Name, StringComparison.OrdinalIgnoreCase))
            {
                <p class="club-official-name">@club.Name</p>
            }
            <div class="club-profile-facts">
                <div>
                    <span>Ciudad</span>
                    <strong>@CityLabel</strong>
                </div>
                <div>
                    <span>Sede</span>
                    <strong>@VenueLabel</strong>
                </div>
                <div>
                    <span>Fundacion</span>
                    <strong>@FoundedLabel</strong>
                </div>
            </div>
        </div>
        <div class="club-profile-actions">
            @if (ClubHexColor is not null)
            {
                <span class="club-color-chip club-color-chip--swatch-only" title="Color del club">
                    <span style="background:@ClubHexColor"></span>
                </span>
            }
            @if (GoogleMapsUrl is not null)
            {
                <a class="leagues-button leagues-button--muted" href="@GoogleMapsUrl" target="_blank" rel="noopener noreferrer">Ver ubicacion</a>
            }
            @if (canManage)
            {
                <button type="button" class="leagues-button leagues-button--muted" @onclick="ToggleEditClub">
                    @(showEditClub ? "Cerrar edicion" : "Editar club")
                </button>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="leagues-message @(isSuccessMessage ? "leagues-message--success" : "leagues-message--error")">
            @statusMessage
        </div>
    }

    @if (canManage && showEditClub)
    {
        <section class="panel club-edit-panel">
            <div class="panel-title-row">
                <div>
                    <p class="eyebrow">Admin / Moderator</p>
                    <h2>Editar club</h2>
                </div>
                <span>Perfil individual</span>
            </div>

            <div class="clubs-form">
                <label>
                    Nombre
                    <input class="form-control" value="@editClub.Name" @oninput="eventArgs => editClub.Name = eventArgs.Value?.ToString() ?? string.Empty" maxlength="150" />
                </label>
                <label>
                    Nombre corto
                    <input class="form-control" value="@editClub.ShortName" @oninput="eventArgs => editClub.ShortName = eventArgs.Value?.ToString() ?? string.Empty" maxlength="30" />
                </label>
                <label>
                    Ciudad
                    <input class="form-control" value="@editClub.VenueCity" @oninput="eventArgs => editClub.VenueCity = eventArgs.Value?.ToString() ?? string.Empty" maxlength="120" />
                </label>
                <label>
                    Sede
                    <input class="form-control" value="@editClub.VenueName" @oninput="eventArgs => editClub.VenueName = eventArgs.Value?.ToString() ?? string.Empty" maxlength="150" />
                </label>
                <label>
                    Anio fundacion
                    <input class="form-control" value="@editClub.FoundedYear" @oninput="eventArgs => editClub.FoundedYear = eventArgs.Value?.ToString() ?? string.Empty" inputmode="numeric" placeholder="1922" maxlength="4" />
                </label>
                <label>
                    Color principal
                    <input class="form-control" value="@editClub.PrimaryColor" @oninput="eventArgs => editClub.PrimaryColor = eventArgs.Value?.ToString() ?? string.Empty" placeholder="#166534" maxlength="20" />
                </label>
                <label class="checkbox-line club-edit-checkbox">
                    <input type="checkbox" checked="@editClub.IsActive" @onchange="eventArgs => editClub.IsActive = eventArgs.Value is true" />
                    Activo
                </label>
                <button type="button" class="leagues-button" disabled="@isSaving" @onclick="SaveClubAsync">
                    @(isSaving ? "Guardando..." : "Guardar club")
                </button>
            </div>
        </section>
    }

    <section class="club-profile-grid">
        <article class="panel club-profile-section">
            <div class="panel-title-row">
                <div>
                    <p class="eyebrow">Equipos</p>
                    <h2>Equipos del club</h2>
                </div>
                <span>@ActiveTeams.Count equipo(s)</span>
            </div>

            @if (ActiveTeams.Count == 0)
            {
                <EmptyState Text="Todavia no hay equipos activos asociados a este club." />
            }
            else
            {
                <div class="club-team-list">
                    @foreach (var team in ActiveTeams)
                    {
                        <div class="club-team-row">
                            <strong>@TeamDisplayName(team)</strong>
                            <div class="club-team-meta">
                                <span>@TeamLeagueLabel(team)</span>
                                <span>@TeamCompetitionLabel(team)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="panel club-profile-section">
            <div class="panel-title-row">
                <div>
                    <p class="eyebrow">Estadisticas</p>
                    <h2>Estadisticas basicas</h2>
                </div>
            </div>

            <div class="club-stat-grid">
                <div class="club-stat-card">
                    <strong>@ActiveTeams.Count</strong>
                    <span>Equipos activos</span>
                </div>
                <div class="club-stat-card">
                    <strong>@ActivePlayers.Count</strong>
                    <span>Jugadores activos</span>
                </div>
                <div class="club-stat-card">
                    <strong>@CompetitionCount</strong>
                    <span>Competencias</span>
                </div>
                <div class="club-stat-card">
                    <strong>@(club.FoundedYear?.ToString() ?? "S/D")</strong>
                    <span>Fundacion</span>
                </div>
            </div>
        </article>
    </section>

    <section class="panel club-profile-section section-gap">
        <div class="panel-title-row">
            <div>
                <p class="eyebrow">Plantel</p>
                <h2>Jugadores del club</h2>
            </div>
            <span>@ActivePlayers.Count jugador(es)</span>
        </div>

        @if (ActivePlayers.Count == 0)
        {
            <EmptyState Text="Plantel pendiente de carga." />
        }
        else
        {
            @foreach (var team in ActiveTeams.Where(team => team.Players.Any(player => player.IsActive)))
            {
                <div class="club-player-section">
                    <h3>@TeamDisplayName(team)</h3>
                    <div class="player-grid">
                        @foreach (var player in team.Players.Where(x => x.IsActive).OrderBy(x => x.ShirtNumber ?? 999).ThenBy(x => x.DisplayName))
                        {
                            <a class="player-row" href="/players/@player.Id">
                                <strong>@(player.ShirtNumber?.ToString() ?? "-")</strong>
                                <span>@player.FullName</span>
                                <small>@PositionText(player.Position)</small>
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Club? club;
    private bool canManage;
    private bool isSaving;
    private bool isSuccessMessage;
    private bool showEditClub;
    private string? statusMessage;
    private ClubEditModel editClub = new();

    private string PublicClubName => string.IsNullOrWhiteSpace(club?.ShortName) ? club?.Name ?? "Club" : club.ShortName;

    private string? ClubHexColor => IsHexColor(club?.PrimaryColor) ? club!.PrimaryColor!.Trim() : null;

    private string HeroAccentColor => ClubHexColor ?? "#14532d";

    private string CityLabel => string.IsNullOrWhiteSpace(club?.Venue?.City) ? "Ciudad sin cargar" : club.Venue.City;

    private string VenueLabel => string.IsNullOrWhiteSpace(club?.Venue?.Name) ? "Sede sin cargar" : club.Venue.Name;

    private string FoundedLabel => club?.FoundedYear?.ToString() ?? "S/D";

    private string? GoogleMapsUrl => club?.Venue is null ||
        string.IsNullOrWhiteSpace(club.Venue.Name) ||
        string.IsNullOrWhiteSpace(club.Venue.City)
            ? null
            : $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString($"{club.Venue.Name} {club.Venue.City}")}";

    private List<Team> ActiveTeams => club is null
        ? []
        : club.Teams
            .Where(x => x.IsActive)
            .OrderBy(x => x.Competition?.Season?.League?.Name)
            .ThenBy(x => x.Competition?.Name)
            .ThenBy(x => x.Name)
            .ToList();

    private List<Player> ActivePlayers => ActiveTeams
        .SelectMany(team => team.Players)
        .Where(player => player.IsActive)
        .ToList();

    private int CompetitionCount => ActiveTeams
        .Select(team => team.CompetitionId)
        .Distinct()
        .Count();

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        canManage = authState.User.IsInRole(AppRoles.Admin) || authState.User.IsInRole(AppRoles.Moderator);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        club = await Db.Clubs
            .AsNoTracking()
            .Include(x => x.Venue)
            .Include(x => x.Teams)
                .ThenInclude(x => x.Players)
            .Include(x => x.Teams)
                .ThenInclude(x => x.Competition)!.ThenInclude(x => x!.Season)!.ThenInclude(x => x!.League)
            .FirstOrDefaultAsync(x => x.Id == Id && (x.IsActive || canManage));

        PrepareEditModel();
    }

    private void ToggleEditClub()
    {
        showEditClub = !showEditClub;
        if (showEditClub)
        {
            PrepareEditModel();
        }
    }

    private void PrepareEditModel()
    {
        if (club is null)
        {
            editClub = new ClubEditModel();
            return;
        }

        editClub = new ClubEditModel
        {
            Name = club.Name,
            ShortName = club.ShortName,
            VenueCity = club.Venue?.City ?? string.Empty,
            VenueName = club.Venue?.Name ?? string.Empty,
            FoundedYear = club.FoundedYear?.ToString() ?? string.Empty,
            PrimaryColor = club.PrimaryColor ?? string.Empty,
            IsActive = club.IsActive
        };
    }

    private async Task SaveClubAsync()
    {
        if (!canManage || club is null || isSaving)
        {
            return;
        }

        var name = editClub.Name.Trim();
        var shortName = editClub.ShortName.Trim();
        var venueCity = editClub.VenueCity.Trim();
        var venueName = editClub.VenueName.Trim();
        var primaryColor = string.IsNullOrWhiteSpace(editClub.PrimaryColor) ? null : editClub.PrimaryColor.Trim();

        if (!ValidateClubInput(name, shortName, venueName, venueCity, editClub.FoundedYear, out var foundedYear, out var error))
        {
            SetMessage(error, false);
            return;
        }

        if (await Db.Clubs.AnyAsync(x => x.Id != Id && (x.Name == name || x.ShortName == shortName)))
        {
            SetMessage("Ya existe otro club con ese nombre o nombre corto.", false);
            return;
        }

        isSaving = true;
        try
        {
            var selectedClub = await Db.Clubs.FirstOrDefaultAsync(x => x.Id == Id);
            if (selectedClub is null)
            {
                SetMessage("Club no encontrado.", false);
                return;
            }

            var venueId = await ResolveVenueIdAsync(venueName, venueCity);
            selectedClub.UpdateDetails(name, shortName, primaryColor, foundedYear, venueId);
            selectedClub.SetActive(editClub.IsActive);
            await Db.SaveChangesAsync();
            SetMessage("Club actualizado correctamente.", true);
            await LoadAsync();
        }
        catch (DbUpdateException)
        {
            SetMessage("No se pudo actualizar el club.", false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task<Guid?> ResolveVenueIdAsync(string venueName, string venueCity)
    {
        if (string.IsNullOrWhiteSpace(venueName) && string.IsNullOrWhiteSpace(venueCity))
        {
            return null;
        }

        var venue = await Db.Venues.FirstOrDefaultAsync(x => x.Name == venueName && x.City == venueCity);
        if (venue is null)
        {
            venue = new Venue(venueName, venueCity);
            Db.Venues.Add(venue);
        }

        return venue.Id;
    }

    private static bool ValidateClubInput(string name, string shortName, string venueName, string venueCity, string foundedYearText, out int? foundedYear, out string error)
    {
        foundedYear = null;
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(shortName))
        {
            error = "Nombre y nombre corto son obligatorios.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(venueName) != string.IsNullOrWhiteSpace(venueCity))
        {
            error = "Para cargar la sede, completa sede y ciudad.";
            return false;
        }

        if (!string.IsNullOrWhiteSpace(foundedYearText))
        {
            if (!int.TryParse(foundedYearText.Trim(), out var parsedYear) || parsedYear < 1800 || parsedYear > DateTime.UtcNow.Year)
            {
                error = "Ingresa solo el anio de fundacion, por ejemplo 1922.";
                return false;
            }

            foundedYear = parsedYear;
        }

        error = string.Empty;
        return true;
    }

    private static string TeamDisplayName(Team team)
    {
        if (string.IsNullOrWhiteSpace(team.Category) || team.Name.Contains(team.Category, StringComparison.OrdinalIgnoreCase))
        {
            return team.Name;
        }

        return $"{team.Name} - {team.Category}";
    }

    private static string TeamLeagueLabel(Team team) =>
        team.Competition?.Season?.League?.Name ?? "Liga sin cargar";

    private static string TeamCompetitionLabel(Team team)
    {
        var competition = team.Competition?.Name;
        return string.IsNullOrWhiteSpace(competition) ? "Competencia sin cargar" : competition;
    }

    private static string PositionText(PlayerPosition position) =>
        position == PlayerPosition.Unknown ? "Sin posicion" : position.ToString();

    private static bool IsHexColor(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var trimmed = value.Trim();
        if (trimmed.Length is not (4 or 7) || trimmed[0] != '#')
        {
            return false;
        }

        return trimmed.Skip(1).All(Uri.IsHexDigit);
    }

    private void SetMessage(string message, bool success)
    {
        statusMessage = message;
        isSuccessMessage = success;
    }

    private sealed class ClubEditModel
    {
        public string Name { get; set; } = string.Empty;
        public string ShortName { get; set; } = string.Empty;
        public string VenueCity { get; set; } = string.Empty;
        public string VenueName { get; set; } = string.Empty;
        public string FoundedYear { get; set; } = string.Empty;
        public string PrimaryColor { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}
