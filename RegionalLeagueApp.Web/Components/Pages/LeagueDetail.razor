@page "/leagues/{Id:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Liga</PageTitle>

@if (league is null)
{
    <EmptyState Text="Liga no encontrada." />
}
else
{
    <PageBreadcrumb BackHref="/leagues" ParentHref="/leagues" ParentLabel="Ligas" CurrentLabel="@league.Name" />

    <section class="page-hero leagues-hero">
        <div>
            <p class="eyebrow">@LocationText(league.Region, league.Country)</p>
            <h1>@league.Name</h1>
            <p>Temporadas, competencias, equipos participantes y accesos deportivos de la liga.</p>
            <div class="hero-actions">
                <a href="/fixture?leagueId=@league.Id">Fixture</a>
                <a href="/standings?leagueId=@league.Id">Tabla</a>
                <a href="/results?leagueId=@league.Id">Resultados</a>
                <a href="/clubs?leagueId=@league.Id">Clubes</a>
                <a href="/scorers?leagueId=@league.Id">Goleadores</a>
                @if (canManage)
                {
                    <a class="hero-actions__admin" href="/admin/leagues/@league.Id">Administrar liga</a>
                }
            </div>
        </div>
    </section>

    <section class="leagues-summary">
        <article>
            <strong>@DisplaySeasons.Count</strong>
            <span>Temporadas</span>
        </article>
        <article>
            <strong>@competitions.Count</strong>
            <span>Competencias</span>
        </article>
        <article>
            <strong>@participants.Count</strong>
            <span>Clubes/equipos</span>
        </article>
    </section>

    <section class="league-structure">
        @if (DisplaySeasons.Count == 0)
        {
            <EmptyState Text="No hay temporadas activas para esta liga." />
        }
        else
        {
            @foreach (var season in DisplaySeasons)
            {
                <article class="panel league-season-card">
                    <div class="league-section-title">
                        <div>
                            <p class="eyebrow">Temporada</p>
                            <h2>@season.Name</h2>
                            <span>@season.StartsOn.ToString("dd/MM/yyyy") - @season.EndsOn.ToString("dd/MM/yyyy")</span>
                        </div>
                        <span class="leagues-status @(season.IsActive ? "leagues-status--active" : "leagues-status--archived")">@(season.IsActive ? "Activa" : "Archivada")</span>
                    </div>

                    @foreach (var competition in season.Competitions.Where(x => x.IsActive).OrderBy(x => x.Name))
                    {
                        <section class="league-competition-card">
                            <div class="league-section-title">
                                <div>
                                    <p class="eyebrow">Competencia</p>
                                    <h3>@competition.Name</h3>
                                    <span>@competition.Format</span>
                                </div>
                                <span class="leagues-status @(competition.IsActive ? "leagues-status--active" : "leagues-status--archived")">@(competition.IsActive ? "Activa" : "Archivada")</span>
                            </div>

                            <div class="league-competition-grid">
                                <div>
                                    <h4>Equipos participantes</h4>
                                    @if (!competition.Teams.Any(x => x.IsActive))
                                    {
                                        <EmptyState Text="No hay equipos en esta competencia." />
                                    }
                                    else
                                    {
                                        <div class="leagues-participants">
                                            @foreach (var team in competition.Teams.Where(x => x.IsActive && x.Club is not null && x.Club.IsActive).OrderBy(x => x.Club!.Name))
                                            {
                                                <a class="leagues-participant" href="/clubs/@team.ClubId">
                                                    <ClubLogo Name="@team.Club!.Name" LogoPath="@team.Club.LogoPath" />
                                                    <div><strong>@team.Club.Name</strong><span>@team.Name - @team.Category</span></div>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                                <div>
                                    <h4>Partidos</h4>
                                    @if (!competition.Matches.Any())
                                    {
                                        <EmptyState Text="No hay partidos cargados." />
                                    }
                                    else
                                    {
                                        <div class="league-match-list">
                                            @foreach (var match in competition.Matches.OrderBy(x => x.StartsAt).Take(8))
                                            {
                                                <a href="/matches/@match.Id">
                                                    <span>@(match.Round?.Name ?? "Fecha")</span>
                                                    <strong>@(match.HomeTeam?.Club?.ShortName ?? "LOC") vs @(match.AwayTeam?.Club?.ShortName ?? "VIS")</strong>
                                                    <small>@match.StartsAt.LocalDateTime.ToString("dd/MM HH:mm") - @match.Status</small>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </section>
                    }
                </article>
            }
        }
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private League? league;
    private List<CompetitionItem> competitions = [];
    private List<ParticipantItem> participants = [];
    private bool canManage;

    private List<Season> DisplaySeasons => league?.Seasons
        .Where(x => x.IsActive)
        .OrderByDescending(x => x.StartsOn)
        .ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        canManage = authState.User.IsInRole(AppRoles.Admin) || authState.User.IsInRole(AppRoles.Moderator);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        league = await Db.Leagues
            .AsNoTracking()
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Teams)
                        .ThenInclude(item => item.Club)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.Round)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.HomeTeam)!.ThenInclude(item => item!.Club)
            .Include(item => item.Seasons)
                .ThenInclude(item => item.Competitions)
                    .ThenInclude(item => item.Matches)
                        .ThenInclude(item => item.AwayTeam)!.ThenInclude(item => item!.Club)
            .FirstOrDefaultAsync(item => item.Id == Id && (item.IsActive || canManage));

        if (league is null)
        {
            competitions = [];
            participants = [];
            return;
        }

        competitions = league.Seasons
            .Where(season => season.IsActive)
            .SelectMany(season => season.Competitions.Where(competition => competition.IsActive).Select(competition => new CompetitionItem(
                competition.Id,
                competition.Name,
                season.Name,
                competition.Format,
                competition.Teams.Count(team => team.IsActive && team.Club is not null && team.Club.IsActive))))
            .OrderBy(item => item.SeasonName)
            .ThenBy(item => item.Name)
            .ToList();

        participants = league.Seasons
            .SelectMany(season => season.Competitions)
            .Where(competition => competition.IsActive)
            .SelectMany(competition => competition.Teams)
            .Where(team => team.IsActive && team.Club is not null && team.Club.IsActive)
            .GroupBy(team => new { team.ClubId, ClubName = team.Club!.Name, team.Club.LogoPath, team.Name })
            .Select(group => new ParticipantItem(group.Key.ClubId, group.Key.ClubName, group.Key.LogoPath, group.Key.Name))
            .OrderBy(item => item.ClubName)
            .ThenBy(item => item.TeamName)
            .ToList();

    }

    private static string LocationText(string region, string country)
    {
        if (string.IsNullOrWhiteSpace(region))
        {
            return country;
        }

        if (string.IsNullOrWhiteSpace(country))
        {
            return region;
        }

        return $"{region}, {country}";
    }

    private sealed record CompetitionItem(Guid Id, string Name, string SeasonName, string Format, int TeamCount);
    private sealed record ParticipantItem(Guid ClubId, string ClubName, string? LogoPath, string TeamName);
}
