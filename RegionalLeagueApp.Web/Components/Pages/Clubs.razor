@page "/clubs"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Clubes</PageTitle>

<PageBreadcrumb BackHref="@BreadcrumbBackHref" ParentHref="@BreadcrumbParentHref" ParentLabel="@BreadcrumbParentLabel" CurrentLabel="@BreadcrumbCurrentLabel" />

<div class="page-heading">
    <p class="eyebrow">Clubes</p>
    <h1>@PageTitleText</h1>
</div>

<LeagueCompetitionFilter Path="/clubs" LeagueId="@LeagueId" CompetitionId="@CompetitionId" />

@if (clubs.Count == 0)
{
    <EmptyState Text="@EmptyText" />
}
else
{
    <section class="club-grid">
        @foreach (var club in clubs)
        {
            <a class="club-card" href="clubs/@club.Id">
                <ClubLogo Name="@DisplayClubName(club)" LogoPath="@club.LogoPath" />
                <strong>@DisplayClubName(club)</strong>
                @if (!string.IsNullOrWhiteSpace(CityLabel(club)))
                {
                    <small>@CityLabel(club)</small>
                }
            </a>
        }
    </section>
}

@code {
    private List<Club> clubs = [];
    private string? leagueName;
    private string? competitionName;

    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }
    [SupplyParameterFromQuery] public Guid? CompetitionId { get; set; }

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Clubes participantes"
        : $"Clubes - {leagueName}";

    private string EmptyText => LeagueId is null
        ? "No hay clubes cargados."
        : CompetitionId is null
            ? "No hay clubes asociados a esta liga."
            : "No hay clubes asociados a esta competencia.";

    private string BreadcrumbBackHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentLabel => LeagueId is null ? "Inicio" : leagueName ?? "Liga";

    private string BreadcrumbCurrentLabel => string.IsNullOrWhiteSpace(competitionName)
        ? "Clubes"
        : $"{competitionName} / Clubes";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        competitionName = CompetitionId is null
            ? null
            : await Db.Competitions
                .AsNoTracking()
                .Where(x => x.Id == CompetitionId && x.IsActive)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var query = Db.Clubs
            .AsNoTracking()
            .Include(x => x.Venue)
            .Where(x => x.IsActive)
            .AsQueryable();

        if (LeagueId is not null)
        {
            query = query.Where(x => x.Teams.Any(team => team.IsActive && team.Competition!.IsActive && team.Competition.Season!.LeagueId == LeagueId));
        }

        if (CompetitionId is not null)
        {
            query = query.Where(x => x.Teams.Any(team => team.IsActive && team.CompetitionId == CompetitionId));
        }

        clubs = await query
            .OrderBy(x => x.Name)
            .ToListAsync();
    }

    private static string DisplayClubName(Club club) => string.IsNullOrWhiteSpace(club.ShortName) ? club.Name : club.ShortName;

    private static string CityLabel(Club club) => club.Venue?.City ?? string.Empty;
}
