@page "/discipline"
@page "/suspensions"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Discipline
@inject ApplicationDbContext Db
@inject IDisciplineQueryService DisciplineQueryService

<PageTitle>Disciplina</PageTitle>

<PageBreadcrumb BackHref="@BreadcrumbBackHref" ParentHref="@BreadcrumbParentHref" ParentLabel="@BreadcrumbParentLabel" CurrentLabel="@BreadcrumbCurrentLabel" />

<div class="page-heading">
    <p class="eyebrow">Disciplina</p>
    <h1>@PageTitleText</h1>
</div>

<LeagueCompetitionFilter Path="/discipline" LeagueId="@LeagueId" CompetitionId="@CompetitionId" />

@if (rows.Count == 0)
{
    <EmptyState Text="@EmptyText" />
}
else
{
    @foreach (var group in rows.GroupBy(x => new { x.CompetitionId, x.CompetitionName }).OrderBy(x => x.Key.CompetitionName))
    {
        <section class="panel table-panel discipline-table section-gap">
            <div class="standings-section-title">
                <h2>@group.Key.CompetitionName</h2>
                <span>@group.Count() jugador(es)</span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Jugador</th>
                        <th>Club / equipo</th>
                        <th>Amarillas</th>
                        <th>Rojas</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in group.OrderByDescending(x => x.Status).ThenByDescending(x => x.YellowCards).ThenByDescending(x => x.RedCards).ThenBy(x => x.PlayerName))
                    {
                        <tr class="@DisciplineRowClass(row.Status)">
                            <td>
                                @if (row.PlayerId is { } playerId)
                                {
                                    <a href="players/@playerId">@row.PlayerName</a>
                                }
                                else
                                {
                                    @row.PlayerName
                                }
                            </td>
                            <td>
                                <a href="clubs/@row.ClubId">@ClubTeamLabel(row)</a>
                            </td>
                            <td><strong>@row.YellowCards</strong></td>
                            <td><strong>@row.RedCards</strong></td>
                            <td><StatusBadge DisciplineStatusValue="row.Status" Compact="true" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
}

@code {
    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }
    [SupplyParameterFromQuery] public Guid? CompetitionId { get; set; }

    private IReadOnlyList<DisciplineRowDto> rows = [];
    private string? leagueName;
    private string? competitionName;

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Sanciones y tarjetas"
        : $"Sanciones y tarjetas - {leagueName}";

    private string EmptyText => CompetitionId is not null
        ? "Todavia no hay tarjetas asociadas a jugadores en esta competencia."
        : "Todavia no hay tarjetas asociadas a jugadores.";

    private string BreadcrumbBackHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentLabel => LeagueId is null ? "Inicio" : leagueName ?? "Liga";

    private string BreadcrumbCurrentLabel => string.IsNullOrWhiteSpace(competitionName)
        ? "Disciplina"
        : $"{competitionName} / Disciplina";

    protected override async Task OnParametersSetAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        competitionName = CompetitionId is null
            ? null
            : await Db.Competitions
                .AsNoTracking()
                .Where(x => x.Id == CompetitionId && x.IsActive)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var loadedRows = await DisciplineQueryService.GetDisciplineAsync(LeagueId);
        rows = CompetitionId is null
            ? loadedRows
            : loadedRows.Where(x => x.CompetitionId == CompetitionId).ToList();
    }

    private static string DisciplineRowClass(DisciplineStatus status) => status switch
    {
        DisciplineStatus.Suspended => "discipline-row--suspended",
        DisciplineStatus.Warned => "discipline-row--warned",
        _ => string.Empty
    };

    private static string ClubTeamLabel(DisciplineRowDto row)
    {
        if (string.IsNullOrWhiteSpace(row.TeamName) || string.Equals(row.TeamName, row.ClubName, StringComparison.OrdinalIgnoreCase))
        {
            return row.ClubName;
        }

        if (row.TeamName.Contains(row.ClubName, StringComparison.OrdinalIgnoreCase))
        {
            return row.TeamName;
        }

        return $"{row.ClubName} / {row.TeamName}";
    }
}
