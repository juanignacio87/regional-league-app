@page "/scorers"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Goleadores</PageTitle>

<PageBreadcrumb BackHref="@BreadcrumbBackHref" ParentHref="@BreadcrumbParentHref" ParentLabel="@BreadcrumbParentLabel" CurrentLabel="@BreadcrumbCurrentLabel" />

<div class="page-heading">
    <p class="eyebrow">Goleadores</p>
    <h1>@PageTitleText</h1>
</div>

<LeagueCompetitionFilter Path="/scorers" LeagueId="@LeagueId" CompetitionId="@CompetitionId" />

@if (scorers.Count == 0)
{
    <EmptyState Text="@EmptyText" />
}
else
{
    <section class="panel table-panel">
        <table>
            <thead>
                <tr>
                    <th>Jugador</th>
                    <th>Equipo</th>
                    <th>Competencia</th>
                    <th>Goles</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var scorer in scorers)
                {
                    <tr>
                        <td>
                            @if (scorer.PlayerId is not null)
                            {
                                <a href="players/@scorer.PlayerId">@scorer.PlayerName</a>
                            }
                            else
                            {
                                @scorer.PlayerName
                            }
                        </td>
                        <td>@scorer.TeamName</td>
                        <td>@scorer.CompetitionName</td>
                        <td><strong>@scorer.Goals</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private List<ScorerRow> scorers = [];
    private Func<Task>? reloadHandler;
    private string? leagueName;
    private string? competitionName;

    [SupplyParameterFromQuery] public Guid? LeagueId { get; set; }
    [SupplyParameterFromQuery] public Guid? CompetitionId { get; set; }

    private string PageTitleText => string.IsNullOrWhiteSpace(leagueName)
        ? "Ranking de goleadores"
        : $"Goleadores - {leagueName}";

    private string EmptyText => CompetitionId is not null
        ? "Todavia no hay goles asociados a jugadores en esta competencia."
        : "Todavia no hay goles asociados a jugadores.";

    private string BreadcrumbBackHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentHref => LeagueId is null ? "/" : $"/leagues/{LeagueId}";

    private string BreadcrumbParentLabel => LeagueId is null ? "Inicio" : leagueName ?? "Liga";

    private string BreadcrumbCurrentLabel => string.IsNullOrWhiteSpace(competitionName)
        ? "Goleadores"
        : $"{competitionName} / Goleadores";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        leagueName = LeagueId is null
            ? null
            : await Db.Leagues
                .AsNoTracking()
                .Where(x => x.Id == LeagueId)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        competitionName = CompetitionId is null
            ? null
            : await Db.Competitions
                .AsNoTracking()
                .Where(x => x.Id == CompetitionId && x.IsActive)
                .Select(x => x.Name)
                .FirstOrDefaultAsync();

        var goalEvents = await Db.MatchEvents
            .AsNoTracking()
            .Where(x =>
                x.Type == MatchEventType.Goal &&
                (x.PlayerId != null || x.PlayerName != string.Empty) &&
                x.Team!.IsActive &&
                x.Team.Club!.IsActive &&
                x.Match!.Competition!.IsActive &&
                x.Match.Competition.Season!.League!.IsActive &&
                (LeagueId == null || x.Match.Competition.Season.LeagueId == LeagueId) &&
                (CompetitionId == null || x.Match.CompetitionId == CompetitionId) &&
                (x.Player == null || x.Player.IsActive))
            .Select(x => new
            {
                x.PlayerId,
                PlayerName = x.PlayerName != string.Empty
                    ? x.PlayerName
                    : x.Player != null
                        ? x.Player.DisplayName
                        : string.Empty,
                TeamName = x.Team != null ? x.Team.Club!.Name : "Sin equipo",
                CompetitionId = x.Match!.CompetitionId,
                CompetitionName = x.Match.Competition!.Name
            })
            .ToListAsync();

        scorers = goalEvents
            .Where(x => !string.IsNullOrWhiteSpace(x.PlayerName))
            .GroupBy(x => new
            {
                PlayerKey = x.PlayerId?.ToString() ?? x.PlayerName.Trim().ToUpperInvariant(),
                x.TeamName,
                x.CompetitionId,
                x.CompetitionName
            })
            .Select(group => new ScorerRow(
                group.First().PlayerId,
                group.OrderByDescending(x => x.PlayerId != null).First().PlayerName,
                group.Key.TeamName,
                group.Key.CompetitionName,
                group.Count()))
            .OrderByDescending(x => x.Goals)
            .ThenBy(x => x.PlayerName)
            .ToList();
    }

    private sealed record ScorerRow(Guid? PlayerId, string PlayerName, string TeamName, string CompetitionName, int Goals);
}
