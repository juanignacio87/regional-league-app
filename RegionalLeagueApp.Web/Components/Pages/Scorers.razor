@page "/scorers"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Goleadores</PageTitle>

<div class="page-heading">
    <p class="eyebrow">Goleadores</p>
    <h1>Ranking de goleadores</h1>
</div>

@if (scorers.Count == 0)
{
    <EmptyState Text="Todavia no hay goles asociados a jugadores." />
}
else
{
    <section class="panel table-panel">
        <table>
            <thead>
                <tr>
                    <th>Jugador</th>
                    <th>Equipo</th>
                    <th>Goles</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var scorer in scorers)
                {
                    <tr>
                        <td>@scorer.PlayerName</td>
                        <td>@scorer.TeamName</td>
                        <td><strong>@scorer.Goals</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private List<ScorerRow> scorers = [];
    private Func<Task>? reloadHandler;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        var goalEvents = await Db.MatchEvents
            .AsNoTracking()
            .Where(x => x.Type == MatchEventType.Goal && x.PlayerName != string.Empty)
            .Select(x => new
            {
                x.PlayerName,
                TeamName = x.Team != null ? x.Team.Club!.Name : "Sin equipo"
            })
            .ToListAsync();

        scorers = goalEvents
            .Where(x => !string.IsNullOrWhiteSpace(x.PlayerName))
            .GroupBy(x => new { x.PlayerName, x.TeamName })
            .Select(group => new ScorerRow(
                group.Key.PlayerName,
                group.Key.TeamName,
                group.Count()))
            .OrderByDescending(x => x.Goals)
            .ThenBy(x => x.PlayerName)
            .ToList();
    }

    private sealed record ScorerRow(string PlayerName, string TeamName, int Goals);
}
