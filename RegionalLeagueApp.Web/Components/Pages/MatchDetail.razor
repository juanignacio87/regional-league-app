@page "/matches/{Id:guid}"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Partido</PageTitle>

@if (match is null)
{
    <EmptyState Text="Partido no encontrado." />
}
else
{
    <section class="match-hero">
        <div>
            <small>@match.Round?.Name</small>
            <h1>@match.HomeTeam?.Club?.Name</h1>
        </div>
        <strong>@ScoreText(match)</strong>
        <div>
            <small>@match.Status</small>
            <h1>@match.AwayTeam?.Club?.Name</h1>
        </div>
    </section>

    <section class="content-grid two-col">
        <article class="panel">
            <h2>Datos del partido</h2>
            <dl class="detail-list">
                <div><dt>Fecha</dt><dd>@match.StartsAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</dd></div>
                <div><dt>Sede</dt><dd>@match.Venue?.Name, @match.Venue?.City</dd></div>
                <div><dt>Competencia</dt><dd>@match.Competition?.Name</dd></div>
                <div><dt>Estado</dt><dd>@match.Status</dd></div>
            </dl>
        </article>

        <article class="panel">
            <h2>Linea de tiempo</h2>
            @if (match.Events.Count == 0)
            {
                <EmptyState Text="No hay eventos cargados para este partido." />
            }
            else
            {
                <div class="timeline">
                    @foreach (var item in match.Events.OrderBy(x => x.Minute))
                    {
                        <div class="timeline-item">
                            <strong>@item.Minute'</strong>
                            <span>@EventLabel(item)</span>
                            <small>@item.Team?.Club?.ShortName @PlayerText(item) @item.Notes</small>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Match? match;
    private Func<Task>? reloadHandler;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        match = await Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)
            .Include(x => x.Round)
            .Include(x => x.Venue)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Events)!.ThenInclude(x => x.Team)!.ThenInclude(x => x!.Club)
            .Include(x => x.Events)!.ThenInclude(x => x.Player)
            .FirstOrDefaultAsync(x => x.Id == Id);
    }

    private static string ScoreText(Match item) =>
        item.HomeScore is null || item.AwayScore is null ? "vs" : $"{item.HomeScore}-{item.AwayScore}";

    private static string EventLabel(MatchEvent item) => item.Type switch
    {
        MatchEventType.Goal => "Gol",
        MatchEventType.OwnGoal => "Gol en contra",
        MatchEventType.PenaltyScored => "Penal convertido",
        MatchEventType.PenaltyMissed => "Penal errado",
        MatchEventType.YellowCard => "Tarjeta amarilla",
        MatchEventType.RedCard => "Tarjeta roja",
        MatchEventType.KickOff => "Inicio",
        MatchEventType.HalfTime => "Entretiempo",
        MatchEventType.SecondHalfStart => "Segundo tiempo",
        MatchEventType.FullTime => "Final",
        MatchEventType.Substitution => "Cambio",
        _ => item.Type.ToString()
    };

    private static string PlayerText(MatchEvent item) =>
        !string.IsNullOrWhiteSpace(item.PlayerName)
            ? item.PlayerName
            : item.Player?.FullName ?? string.Empty;
}
