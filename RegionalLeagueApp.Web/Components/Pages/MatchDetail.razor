@page "/matches/{Id:guid}"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Collaboration
@inject ApplicationDbContext Db
@inject IMatchAdministrationPermissionService PermissionService
@inject MatchUpdatesClient MatchUpdatesClient

<PageTitle>Partido</PageTitle>

@if (match is null)
{
    <EmptyState Text="Partido no encontrado." />
}
else
{
    <PageBreadcrumb BackHref="@MatchBackHref" ParentHref="@MatchBackHref" ParentLabel="@MatchParentLabel" CurrentLabel="@MatchTitle(match)" />

    <section class="match-center-hero">
        <div class="match-center-topbar">
            <div class="match-center-meta">
                <span>@LeagueName(match)</span>
                <span>@match.Competition?.Name</span>
                <span>@match.StartsAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</span>
            </div>

            @if (CanEditMatch)
            {
                <a class="match-center-edit" href="@EditMatchUrl">Administrar partido</a>
            }
        </div>

        <div class="match-center-scoreboard">
            <div class="match-center-team">
                <ClubLogo Name="@HomeClubName(match)" LogoPath="@match.HomeTeam?.Club?.LogoPath" Class="match-center-crest" />
                <h1>@HomeClubName(match)</h1>
                <small>Local</small>
            </div>

            <div class="match-center-score">
                <StatusBadge MatchStatusValue="match.Status" />
                <strong>@ScoreText(match)</strong>
                <small>@(match.Round?.Name ?? "Sin fecha")</small>
            </div>

            <div class="match-center-team match-center-team--away">
                <ClubLogo Name="@AwayClubName(match)" LogoPath="@match.AwayTeam?.Club?.LogoPath" Class="match-center-crest" />
                <h1>@AwayClubName(match)</h1>
                <small>Visitante</small>
            </div>
        </div>
    </section>

    <section class="match-center-grid">
        <article class="panel match-center-timeline">
            <PanelHeader Title="Timeline" Meta="@($"{TimelineEvents.Count} eventos")" />

            @if (TimelineEvents.Count == 0)
            {
                <EmptyState Text="No hay eventos cargados para este partido." />
            }
            else
            {
                <div class="match-timeline">
                    @foreach (var item in TimelineEvents)
                    {
                        <div class="match-timeline-event @(IsHomeEvent(item) ? "match-timeline-event--home" : "match-timeline-event--away")">
                            <div class="match-timeline-body">
                                <strong>@EventLabel(item)</strong>
                                @if (IsSecondYellowCard(item))
                                {
                                    <span class="second-yellow-badge">2da amarilla / expulsion</span>
                                }
                                <small>
                                    @if (item.PlayerId is not null)
                                    {
                                        <a href="players/@item.PlayerId">@PlayerText(item)</a>
                                    }
                                    else
                                    {
                                        @PlayerText(item)
                                    }
                                </small>
                            </div>
                            <span class="match-timeline-minute">@item.Minute'</span>
                            <MatchEventIcon EventType="item.Type" IsSecondYellow="IsSecondYellowCard(item)" />
                            <span class="match-timeline-team">@TeamShortName(item)</span>
                        </div>
                    }
                </div>
            }
        </article>

        <aside class="match-center-side">
            <article class="panel">
                <h2>Estadisticas</h2>
                <div class="match-stats">
                    <div class="match-stat-header">
                        <strong>@ShortHomeName(match)</strong>
                        <span></span>
                        <strong>@ShortAwayName(match)</strong>
                    </div>
                    <div class="match-stat-row">
                        <strong>@EventCount(match.HomeTeamId, MatchEventType.Goal)</strong>
                        <span>Goles</span>
                        <strong>@EventCount(match.AwayTeamId, MatchEventType.Goal)</strong>
                    </div>
                    <div class="match-stat-row">
                        <strong>@EventCount(match.HomeTeamId, MatchEventType.YellowCard)</strong>
                        <span>Amarillas</span>
                        <strong>@EventCount(match.AwayTeamId, MatchEventType.YellowCard)</strong>
                    </div>
                    <div class="match-stat-row">
                        <strong>@EventCount(match.HomeTeamId, MatchEventType.RedCard)</strong>
                        <span>Rojas</span>
                        <strong>@EventCount(match.AwayTeamId, MatchEventType.RedCard)</strong>
                    </div>
                    <div class="match-stat-row match-stat-row--total">
                        <strong>@TeamEventCount(match.HomeTeamId)</strong>
                        <span>Total eventos</span>
                        <strong>@TeamEventCount(match.AwayTeamId)</strong>
                    </div>
                </div>
            </article>

            <article class="panel">
                <h2>Datos del partido</h2>
                <dl class="detail-list">
                    <div><dt>Fecha</dt><dd>@match.StartsAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</dd></div>
                    <div><dt>Sede</dt><dd>@VenueText(match)</dd></div>
                    <div><dt>Competencia</dt><dd>@match.Competition?.Name</dd></div>
                    <div><dt>Estado</dt><dd>@StatusLabel(match.Status)</dd></div>
                </dl>
            </article>
        </aside>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Match? match;
    private MatchAdministrationAccess access = MatchAdministrationAccess.Empty;
    private Func<Task>? reloadHandler;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        reloadHandler = () => InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });

        await MatchUpdatesClient.SubscribeAsync(reloadHandler);
    }

    protected override async Task OnParametersSetAsync()
    {
        access = await PermissionService.GetAccessAsync();
        await LoadAsync();
    }

    public void Dispose()
    {
        if (reloadHandler is not null)
        {
            MatchUpdatesClient.Unsubscribe(reloadHandler);
        }
    }

    private async Task LoadAsync()
    {
        match = await Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)!.ThenInclude(x => x!.Season)!.ThenInclude(x => x!.League)
            .Include(x => x.Round)
            .Include(x => x.Venue)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Events)!.ThenInclude(x => x.Team)!.ThenInclude(x => x!.Club)
            .Include(x => x.Events)!.ThenInclude(x => x.Player)
            .FirstOrDefaultAsync(x => x.Id == Id);
    }

    private IReadOnlyList<MatchEvent> TimelineEvents => match?.Events
        .OrderBy(x => x.Minute)
        .ThenBy(x => x.CreatedAt)
        .ToList() ?? [];

    private bool CanEditMatch => match is not null && access.CanManageMatch(match.HomeTeamId, match.AwayTeamId);

    private string EditMatchUrl => $"/admin/matches/{Id}";

    private string MatchBackHref => match?.Status == MatchStatus.Finished ? "/results" : "/fixture";

    private string MatchParentLabel => match?.Status == MatchStatus.Finished ? "Resultados" : "Fixture";

    private static string MatchTitle(Match item) => $"{HomeClubName(item)} vs {AwayClubName(item)}";

    private static string ScoreText(Match item) =>
        item.HomeScore is null || item.AwayScore is null ? "vs" : $"{item.HomeScore}-{item.AwayScore}";

    private string EventLabel(MatchEvent item) => IsSecondYellowCard(item)
        ? "Second yellow"
        : item.Type switch
    {
        MatchEventType.Goal => "Goal",
        MatchEventType.YellowCard => "Yellow card",
        MatchEventType.RedCard => "Red card",
        _ => item.Type.ToString()
    };

    private bool IsSecondYellowCard(MatchEvent item)
    {
        if (item.Type != MatchEventType.YellowCard || item.PlayerId is null)
        {
            return false;
        }

        var orderedEvents = TimelineEvents;
        var itemIndex = orderedEvents.ToList().FindIndex(x => x.Id == item.Id);
        if (itemIndex < 0)
        {
            return false;
        }

        return orderedEvents
            .Take(itemIndex + 1)
            .Count(x => x.PlayerId == item.PlayerId && x.Type == MatchEventType.YellowCard) == 2;
    }

    private static string PlayerText(MatchEvent item) =>
        !string.IsNullOrWhiteSpace(item.PlayerName)
            ? item.PlayerName
            : item.Player?.FullName ?? string.Empty;

    private static string HomeClubName(Match item) => item.HomeTeam?.Club?.Name ?? "Local";

    private static string AwayClubName(Match item) => item.AwayTeam?.Club?.Name ?? "Visitante";

    private static string ShortHomeName(Match item) => item.HomeTeam?.Club?.ShortName ?? "LOC";

    private static string ShortAwayName(Match item) => item.AwayTeam?.Club?.ShortName ?? "VIS";

    private static string LeagueName(Match item) => item.Competition?.Season?.League?.Name ?? "Liga Regional";

    private static string VenueText(Match item) =>
        item.Venue is null ? "Sede a confirmar" : $"{item.Venue.Name}, {item.Venue.City}";

    private static string StatusLabel(MatchStatus status) => status switch
    {
        MatchStatus.Scheduled => "Scheduled",
        MatchStatus.Live or MatchStatus.HalfTime => "Live",
        MatchStatus.Finished => "Finished",
        _ => status.ToString()
    };

    private bool IsHomeEvent(MatchEvent item) => match?.HomeTeamId == item.TeamId;

    private string TeamShortName(MatchEvent item) => item.Team?.Club?.ShortName
        ?? (IsHomeEvent(item) ? "Local" : "Visitante");

    private int EventCount(Guid teamId, MatchEventType type) => match?.Events
        .Count(x => x.TeamId == teamId && x.Type == type) ?? 0;

    private int TeamEventCount(Guid teamId) => match?.Events
        .Count(x => x.TeamId == teamId) ?? 0;
}
