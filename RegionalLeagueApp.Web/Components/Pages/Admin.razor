    private static string? ValidateMatchEventOperation(Match? match, EventCreateModel model)
    {
        if (match is null)
        {
            return "No se encontro el partido seleccionado.";
        }

        if (match.HomeTeam is null || match.AwayTeam is null || !match.HomeTeam.IsActive || !match.AwayTeam.IsActive)
        {
            return "No se pueden cargar eventos en partidos con equipos archivados.";
        }

        if (model.EventType == MatchEventType.Goal && match.Status is MatchStatus.Cancelled or MatchStatus.Suspended or MatchStatus.Postponed)
        {
            return "No se pueden cargar goles en partidos cancelados, suspendidos o postergados.";
        }

        return null;
    }

    private async Task<string?> ValidatePlayerAvailabilityForEventAsync(
        Guid matchId,
        Guid? playerId,
        MatchEventType eventType,
        Guid? excludedEventId)
    {
        if (playerId is null)
        {
            return null;
        }

        var cardEvents = await Db.MatchEvents
            .AsNoTracking()
            .Where(x =>
                x.MatchId == matchId &&
                x.PlayerId == playerId &&
                (excludedEventId == null || x.Id != excludedEventId.Value) &&
                (x.Type == MatchEventType.YellowCard || x.Type == MatchEventType.RedCard))
            .Select(x => x.Type)
            .ToListAsync();

        var hasRedCard = cardEvents.Any(x => x == MatchEventType.RedCard);
        var yellowCards = cardEvents.Count(x => x == MatchEventType.YellowCard);

        if (hasRedCard)
        {
            return "El jugador ya fue expulsado en este partido.";
        }

        if (yellowCards >= 2)
        {
            return "El jugador ya tiene doble amarilla en este partido.";
        }

        if (eventType == MatchEventType.YellowCard && yellowCards >= 2)
        {
            return "No se puede cargar una tercera amarilla al mismo jugador.";
        }

        return null;
    }

    private static IEnumerable<Guid> ExpelledPlayerIdsFromEvents(IEnumerable<AdminMatchEventRow> events)
    {
        return events
            .Where(x => x.PlayerId is not null && (x.EventType == MatchEventType.YellowCard || x.EventType == MatchEventType.RedCard))
            .GroupBy(x => x.PlayerId!.Value)
            .Where(group =>
                group.Any(x => x.EventType == MatchEventType.RedCard) ||
                group.Count(x => x.EventType == MatchEventType.YellowCard) >= 2)
            .Select(group => group.Key);
    }

    private static string ScoreText(int? homeScore, int? awayScore) =>
        homeScore is null || awayScore is null ? "vs" : $"{homeScore}-{awayScore}";

    private static string StatusClass(MatchStatus status) => status is MatchStatus.Live or MatchStatus.HalfTime
        ? "status-live"
        : string.Empty;

    private static string EventLabel(MatchEventType eventType) => eventType switch
    {
        MatchEventType.Goal => "Gol",
        MatchEventType.YellowCard => "Tarjeta amarilla",
        MatchEventType.RedCard => "Tarjeta roja",
        _ => eventType.ToString()
    };

    private string EventLabel(AdminMatchEventRow item) => IsSecondYellowCard(item)
        ? "Doble amarilla"
        : EventLabel(item.EventType);

    private bool IsSecondYellowCard(AdminMatchEventRow item)
    {
        if (item.EventType != MatchEventType.YellowCard || item.PlayerId is null)
        {
            return false;
        }

        var itemIndex = selectedEvents.FindIndex(x => x.Id == item.Id);
        if (itemIndex < 0)
        {
            return false;
        }

        return selectedEvents
            .Take(itemIndex + 1)
            .Count(x => x.PlayerId == item.PlayerId && x.EventType == MatchEventType.YellowCard) == 2;
    }

    private static string ToJson<T>(T value) => JsonSerializer.Serialize(value, JsonOptions);

    private static T FromJson<T>(string json) =>
        JsonSerializer.Deserialize<T>(json, JsonOptions)
        ?? throw new InvalidOperationException("Payload de propuesta invalido.");

    private static string ProposalDescription(
        ProposalChangeType changeType,
        string payloadJson,
        MatchStatus? proposedStatus)
    {
        return changeType switch
        {
            ProposalChangeType.MatchStatusAndResult =>
                $"Cambiar estado a {proposedStatus}. El marcador se calcula desde goles.",
            ProposalChangeType.MatchEventAdd => EventAddDescription(payloadJson),
            ProposalChangeType.MatchEventDelete => EventDeleteDescription(payloadJson),
            _ => changeType.ToString()
        };
    }

    private static string EventAddDescription(string payloadJson)
    {
        var payload = FromJson<MatchEventAddProposalPayload>(payloadJson);
        return $"Agregar {EventLabel(payload.EventType)} - {payload.PlayerName} ({payload.Minute}')";
    }

    private static string EventDeleteDescription(string payloadJson)
    {
        var payload = FromJson<MatchEventDeleteProposalPayload>(payloadJson);
        return $"Eliminar {EventLabel(payload.EventType)} - {payload.PlayerName} ({payload.Minute}')";
    }

