@page "/admin"
@page "/admin/matches/{RouteMatchId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireContributor")]
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Collaboration
@using RegionalLeagueApp.Application.Discipline
@using RegionalLeagueApp.Application.Matches
@using RegionalLeagueApp.Domain.Collaboration
@using RegionalLeagueApp.Web.Hubs
@inject ApplicationDbContext Db
@inject IMatchAdministrationPermissionService PermissionService
@inject IMatchScoreRecalculationService MatchScoreRecalculationService
@inject IDisciplineQueryService DisciplineQueryService
@inject IHubContext<MatchUpdatesHub> MatchUpdates
@inject ILogger<Admin> Logger
@inject NavigationManager Navigation

<PageTitle>@(IsMatchAdminRoute ? "Administrar partido" : "Admin")</PageTitle>

@if (IsMatchAdminRoute)
{
    <PageBreadcrumb
        BackHref="@(editing is null ? "/admin" : $"/admin/leagues/{editing.LeagueId}")"
        ParentHref="/admin"
        ParentLabel="Admin"
        CurrentLabel="@AdminMatchBreadcrumbLabel" />
}

<div class="page-heading admin-heading">
    <div>
        <p class="eyebrow">Administracion</p>
        <h1>@(IsMatchAdminRoute ? "Gestion de partido" : "Panel general")</h1>
    </div>
    <span class="admin-badge">@access.RoleLabel</span>
</div>

@if (!IsMatchAdminRoute)
{
    <section class="panel admin-permissions">
        <div>
            <p class="eyebrow">Permisos actuales</p>
            <h2>@PermissionSummary</h2>
        </div>
        @if (access.IsContributor && !access.CanManageAllMatches)
        {
            <span>@access.AssignedTeamIds.Count equipo(s) asignado(s)</span>
        }
        else if (access.CanModerate)
        {
            <span>Puede moderar todos los partidos y eventos</span>
        }
    </section>

    @if (access.CanModerate)
    {
        <section class="panel admin-league-entry">
            <div>
                <p class="eyebrow">Estructura deportiva</p>
                <h2>Ligas, temporadas y competencias</h2>
                <span>Usa el contexto administrativo de cada liga para crear temporadas, competencias, equipos y partidos.</span>
            </div>
            <a class="leagues-button leagues-button--muted" href="/leagues">Gestionar ligas</a>
        </section>
    }
}

<FormMessage Message="@successMessage" Variant="success" />
<FormMessage Message="@errorMessage" Variant="danger" />

@if (!IsMatchAdminRoute && access.CanModerate)
{
    <section class="panel admin-proposals">
        <div class="panel-title-row">
            <div>
                <p class="eyebrow">Moderacion</p>
                <h2>Propuestas pendientes</h2>
            </div>
            <span>@pendingProposals.Count pendiente(s)</span>
        </div>

        @if (pendingProposals.Count == 0)
        {
            <EmptyState Text="No hay propuestas pendientes." />
        }
        else
        {
            <div class="admin-proposal-list">
                @foreach (var proposal in pendingProposals)
                {
                    <article class="admin-proposal-row">
                        <div>
                            <strong>@proposal.MatchLabel</strong>
                            <span>@proposal.Description</span>
                            <small>@proposal.ProposedBy - @proposal.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="admin-proposal-actions">
                            <button type="button" class="admin-link-button" disabled="@isReviewingProposal" @onclick="async () => await ApproveProposalAsync(proposal.Id)">Aprobar</button>
                            <button type="button" class="admin-link-button admin-link-button-muted" disabled="@isReviewingProposal" @onclick="async () => await RejectProposalAsync(proposal.Id)">Rechazar</button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
}

@if (IsMatchAdminRoute)
{
    @if (editing is null)
    {
        <EmptyState Text="No se pudo cargar el partido solicitado o no tenes permisos para gestionarlo." />
    }
    else
    {
        <section class="admin-match-shell">
            <MatchAdminHeader Match="@editing" ScoreText="@ScoreText(editing.HomeScore, editing.AwayScore)" />

            <section class="admin-match-layout">
                <MatchOperationalPanel
                    Match="@editing"
                    TeamOptions="@matchTeamOptions"
                    CanModerate="@access.CanModerate"
                    IsSaving="@isSaving"
                    Save="@SaveAsync" />

                <MatchTimelineAdmin
                    Match="@editing"
                    CreateModel="@eventForm"
                    Events="@selectedEvents"
                    CreatePlayers="@eventPlayers"
                    EventTypes="@AllowedEventTypes"
                    SelectedPlayerDiscipline="@selectedEventPlayerDiscipline"
                    EditingEventId="@editingEventId"
                    CanModerate="@access.CanModerate"
                    IsSavingEvent="@isSavingEvent"
                    GetEventEdit="@GetEventEdit"
                    EventPlayersForTeam="@EventPlayersForTeam"
                    EditDiscipline="@(eventId => eventEditDiscipline.GetValueOrDefault(eventId))"
                    EventLabel="@EventLabel"
                    EventTypeLabel="@EventLabel"
                    IsSecondYellow="@IsSecondYellowCard"
                    CreateEvent="@CreateEventAsync"
                    CreateTeamChanged="@OnEventTeamChangedAsync"
                    CreatePlayerChanged="@OnEventPlayerChanged"
                    BeginEdit="@BeginEventEditAsync"
                    Delete="@DeleteEventAsync"
                    SaveEdit="@SaveEventEditAsync"
                    CancelEdit="@CancelEventEdit"
                    EditTeamChanged="@OnEventEditTeamChanged"
                    EditPlayerChanged="@OnEventEditPlayerChangedAsync" />
            </section>
        </section>
    }
}
else
{
    <section class="panel admin-league-entry">
        <div>
            <p class="eyebrow">Partidos</p>
            <h2>Gestion por contexto</h2>
            <span>Para editar un partido, entra desde la liga administrativa o desde el Match Center publico. Esta vista ya no carga el fixture global.</span>
        </div>
        <a class="leagues-button leagues-button--muted" href="/leagues">Ir a ligas</a>
    </section>

    <section class="panel admin-league-entry">
        <div>
            <p class="eyebrow">Flujo recomendado</p>
            <h2>Liga -> competencia -> partido</h2>
            <span>La gestion operativa de eventos, estado y fecha vive en /admin/matches/{id}.</span>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid? RouteMatchId { get; set; }

    [SupplyParameterFromQuery(Name = "matchId")]
    public Guid? RequestedMatchId { get; set; }

    private readonly List<AdminMatchRow> matches = [];
    private AdminMatchEditModel? editing;
    private EventCreateModel eventForm = new();
    private readonly List<AdminMatchEventRow> selectedEvents = [];
    private readonly List<EventPlayerOption> eventPlayers = [];
    private readonly List<EventPlayerOption> allMatchEventPlayers = [];
    private readonly HashSet<Guid> unavailableEventPlayerIds = [];
    private readonly Dictionary<Guid, EventEditModel> eventEdits = [];
    private readonly Dictionary<Guid, DisciplineRowDto?> eventEditDiscipline = [];
    private readonly List<PendingProposalRow> pendingProposals = [];
    private readonly List<TeamOption> matchTeamOptions = [];
    private MatchAdministrationAccess access = MatchAdministrationAccess.Empty;
    private bool isSaving;
    private bool isSavingEvent;
    private bool isReviewingProposal;
    private Guid? editingEventId;
    private DisciplineRowDto? selectedEventPlayerDiscipline;
    private string? successMessage;
    private string? errorMessage;
    private string statusFilter = string.Empty;
    private string roundFilter = string.Empty;
    private string clubFilter = string.Empty;
    private static readonly MatchEventType[] AllowedEventTypes =
    [
        MatchEventType.Goal,
        MatchEventType.YellowCard,
        MatchEventType.RedCard
    ];
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    private bool IsMatchAdminRoute => RouteMatchId is not null;

    private string AdminMatchBreadcrumbLabel => editing is null
        ? "Partido"
        : $"{editing.LeagueName} / {editing.CompetitionName} / {editing.HomeTeamName} vs {editing.AwayTeamName}";

    private string PermissionSummary => access.CanManageAllMatches
        ? "Puede editar cualquier partido y moderar eventos."
        : access.IsContributor
            ? "Puede enviar propuestas de resultados y eventos en partidos asignados."
            : "No tiene permisos para administrar partidos.";

    private List<AdminMatchRow> FilteredMatches => matches
        .Where(match => string.IsNullOrWhiteSpace(statusFilter) || match.Status.ToString() == statusFilter)
        .Where(match => string.IsNullOrWhiteSpace(roundFilter) || match.RoundName == roundFilter)
        .Where(match => string.IsNullOrWhiteSpace(clubFilter) || match.HomeTeamName == clubFilter || match.AwayTeamName == clubFilter)
        .ToList();

    private List<string> RoundOptions => matches
        .Select(match => match.RoundName)
        .Distinct()
        .OrderBy(roundName => roundName)
        .ToList();

    private List<string> ClubOptions => matches
        .SelectMany(match => new[] { match.HomeTeamName, match.AwayTeamName })
        .Distinct()
        .OrderBy(clubName => clubName)
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        access = await PermissionService.GetAccessAsync();

        if (IsMatchAdminRoute && RouteMatchId is { } routeMatchId)
        {
            await LoadMatchesAsync();
            await SelectMatchAsync(routeMatchId);
            return;
        }

        await LoadPendingProposalsAsync();

        if (RequestedMatchId is { } matchId)
        {
            Navigation.NavigateTo($"/admin/matches/{matchId}", replace: true);
        }
    }

    private async Task LoadMatchesAsync()
    {
        matches.Clear();
        if (!IsMatchAdminRoute || RouteMatchId is null)
        {
            return;
        }

        matches.AddRange(await Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)!.ThenInclude(x => x!.Season)!.ThenInclude(x => x!.League)
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Id == RouteMatchId && (access.CanManageAllMatches || access.AssignedTeamIds.Contains(x.HomeTeamId) || access.AssignedTeamIds.Contains(x.AwayTeamId)))
            .OrderByDescending(x => x.StartsAt)
            .Select(x => new AdminMatchRow(
                x.Id,
                x.CompetitionId,
                x.Competition!.Season!.LeagueId,
                x.Competition.Season.League!.Name,
                x.Competition.Season.Name,
                x.Competition!.Name,
                x.RoundId,
                x.Round!.Name,
                x.HomeTeamId,
                x.HomeTeam!.Club!.Name,
                x.AwayTeamId,
                x.AwayTeam!.Club!.Name,
                x.StartsAt,
                x.Status,
                x.HomeScore,
                x.AwayScore))
            .ToListAsync());
    }

    private async Task LoadPendingProposalsAsync()
    {
        pendingProposals.Clear();

        if (!access.CanModerate)
        {
            return;
        }

        var proposals = await Db.MatchUpdateProposals
            .AsNoTracking()
            .Include(x => x.ProposedByUser)
            .Include(x => x.Match)!.ThenInclude(x => x!.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Match)!.ThenInclude(x => x!.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == ProposalStatus.Pending)
            .OrderBy(x => x.CreatedAt)
            .Select(x => new
            {
                x.Id,
                x.ChangeType,
                x.PayloadJson,
                x.ProposedStatus,
                x.CreatedAt,
                ProposedBy = x.ProposedByUser != null ? x.ProposedByUser.DisplayName : "Usuario",
                HomeTeamName = x.Match != null && x.Match.HomeTeam != null ? x.Match.HomeTeam.Club!.Name : "Local",
                AwayTeamName = x.Match != null && x.Match.AwayTeam != null ? x.Match.AwayTeam.Club!.Name : "Visitante"
            })
            .ToListAsync();

        pendingProposals.AddRange(proposals.Select(x => new PendingProposalRow(
            x.Id,
            $"{x.HomeTeamName} vs {x.AwayTeamName}",
            x.ProposedBy,
            x.CreatedAt,
            ProposalDescription(x.ChangeType, x.PayloadJson, x.ProposedStatus))));
    }

    private async Task SelectMatchAsync(Guid matchId)
    {
        successMessage = null;
        errorMessage = null;

        var match = matches.FirstOrDefault(x => x.Id == matchId);
        if (match is null || !access.CanManageMatch(match.HomeTeamId, match.AwayTeamId))
        {
            editing = null;
            selectedEvents.Clear();
            errorMessage = "No tenes permisos para editar este partido.";
            return;
        }

        editing = new AdminMatchEditModel
        {
            MatchId = match.Id,
            CompetitionId = match.CompetitionId,
            LeagueId = match.LeagueId,
            LeagueName = match.LeagueName,
            SeasonName = match.SeasonName,
            CompetitionName = match.CompetitionName,
            RoundId = match.RoundId,
            RoundName = match.RoundName,
            HomeTeamId = match.HomeTeamId,
            HomeTeamName = match.HomeTeamName,
            AwayTeamId = match.AwayTeamId,
            AwayTeamName = match.AwayTeamName,
            StartsAt = match.StartsAt,
            StartsAtInput = match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"),
            Status = match.Status,
            HomeScore = match.HomeScore,
            AwayScore = match.AwayScore
        };

        eventForm = new EventCreateModel
        {
            TeamId = match.HomeTeamId,
            EventType = MatchEventType.Goal
        };
        selectedEventPlayerDiscipline = null;

        await LoadMatchTeamOptionsAsync(match.CompetitionId);
        await LoadSelectedEventsAsync(match.Id);
        await LoadAllMatchEventPlayersAsync(match.HomeTeamId, match.AwayTeamId);
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private async Task LoadMatchTeamOptionsAsync(Guid competitionId)
    {
        matchTeamOptions.Clear();
        matchTeamOptions.AddRange(await Db.Teams
            .AsNoTracking()
            .Where(x => x.CompetitionId == competitionId && x.IsActive && x.Club!.IsActive)
            .OrderBy(x => x.Club!.Name)
            .ThenBy(x => x.Name)
            .Select(x => new TeamOption(x.Id, $"{x.Club!.Name} - {x.Name}"))
            .ToListAsync());
    }

    private void ClearFilters()
    {
        statusFilter = string.Empty;
        roundFilter = string.Empty;
        clubFilter = string.Empty;
    }

    private async Task OnEventTeamChangedAsync()
    {
        eventForm.PlayerId = null;
        eventForm.PlayerName = string.Empty;
        selectedEventPlayerDiscipline = null;
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private async Task OnEventPlayerChanged()
    {
        var selectedPlayer = eventPlayers.FirstOrDefault(x => x.Id == eventForm.PlayerId);
        eventForm.PlayerName = selectedPlayer?.DisplayName ?? string.Empty;
        selectedEventPlayerDiscipline = editing is not null && eventForm.PlayerId is { } playerId
            ? await DisciplineQueryService.GetPlayerDisciplineForMatchAsync(editing.MatchId, playerId)
            : null;
    }

    private List<EventPlayerOption> EventPlayersForTeam(Guid teamId, Guid? currentPlayerId = null) => allMatchEventPlayers
        .Where(x => x.TeamId == teamId)
        .Where(x => !unavailableEventPlayerIds.Contains(x.Id) || x.Id == currentPlayerId)
        .OrderBy(x => x.ShirtNumber ?? int.MaxValue)
        .ThenBy(x => x.DisplayName)
        .ToList();

    private EventEditModel GetEventEdit(AdminMatchEventRow item)
    {
        if (!eventEdits.TryGetValue(item.Id, out var edit))
        {
            edit = new EventEditModel
            {
                EventType = item.EventType,
                Minute = item.Minute,
                TeamId = item.TeamId ?? editing?.HomeTeamId ?? Guid.Empty,
                PlayerId = item.PlayerId,
                PlayerName = item.PlayerName,
                Notes = item.Notes ?? string.Empty
            };
            eventEdits[item.Id] = edit;
        }

        return edit;
    }

    private async Task BeginEventEditAsync(AdminMatchEventRow item)
    {
        editingEventId = item.Id;
        eventEdits[item.Id] = new EventEditModel
        {
            EventType = item.EventType,
            Minute = item.Minute,
            TeamId = item.TeamId ?? editing?.HomeTeamId ?? Guid.Empty,
            PlayerId = item.PlayerId,
            PlayerName = item.PlayerName,
            Notes = item.Notes ?? string.Empty
        };
        await LoadEventEditDisciplineAsync(item.Id, eventEdits[item.Id]);
    }

    private void CancelEventEdit()
    {
        editingEventId = null;
    }

    private void OnEventEditTeamChanged(EventEditModel edit)
    {
        edit.PlayerId = null;
        edit.PlayerName = string.Empty;
    }

    private async Task OnEventEditPlayerChangedAsync(Guid eventId, EventEditModel edit, ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        edit.PlayerId = Guid.TryParse(value, out var playerId) ? playerId : null;
        var selectedPlayer = allMatchEventPlayers.FirstOrDefault(x => x.Id == edit.PlayerId);
        edit.PlayerName = selectedPlayer?.DisplayName ?? string.Empty;
        await LoadEventEditDisciplineAsync(eventId, edit);
    }

    private Task OnEventEditPlayerChangedAsync(EventPlayerChangedArgs args) =>
        OnEventEditPlayerChangedAsync(args.EventId, args.Edit, args.Change);

    private async Task LoadEventEditDisciplineAsync(Guid eventId, EventEditModel edit)
    {
        eventEditDiscipline[eventId] = editing is not null && edit.PlayerId is { } playerId
            ? await DisciplineQueryService.GetPlayerDisciplineForMatchAsync(editing.MatchId, playerId)
            : null;
    }

    private async Task LoadEventPlayersAsync(Guid teamId)
    {
        eventPlayers.Clear();
        eventPlayers.AddRange(await Db.Players
            .AsNoTracking()
            .Where(x => x.TeamId == teamId && x.IsActive)
            .OrderBy(x => x.ShirtNumber ?? int.MaxValue)
            .ThenBy(x => x.DisplayName)
            .Select(x => new EventPlayerOption(
                x.Id,
                x.TeamId,
                x.DisplayName,
                x.ShirtNumber,
                x.ShirtNumber != null ? $"#{x.ShirtNumber} {x.DisplayName}" : x.DisplayName))
            .ToListAsync());

        eventPlayers.RemoveAll(x => unavailableEventPlayerIds.Contains(x.Id));
    }

    private async Task LoadAllMatchEventPlayersAsync(Guid homeTeamId, Guid awayTeamId)
    {
        allMatchEventPlayers.Clear();
        allMatchEventPlayers.AddRange(await Db.Players
            .AsNoTracking()
            .Where(x => (x.TeamId == homeTeamId || x.TeamId == awayTeamId) && x.IsActive)
            .OrderBy(x => x.TeamId)
            .ThenBy(x => x.ShirtNumber ?? int.MaxValue)
            .ThenBy(x => x.DisplayName)
            .Select(x => new EventPlayerOption(
                x.Id,
                x.TeamId,
                x.DisplayName,
                x.ShirtNumber,
                x.ShirtNumber != null ? $"#{x.ShirtNumber} {x.DisplayName}" : x.DisplayName))
            .ToListAsync());
    }

    private async Task SaveAsync()
    {
        if (editing is null || isSaving)
        {
            return;
        }

        successMessage = null;
        errorMessage = await ValidateMatchEditAsync(editing);
        if (errorMessage is not null)
        {
            return;
        }

        isSaving = true;
        try
        {
            var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == editing.MatchId);
            if (match is null)
            {
                errorMessage = "No se encontro el partido seleccionado.";
                return;
            }

            if (!access.CanManageMatch(match.HomeTeamId, match.AwayTeamId))
            {
                errorMessage = "No tenes permisos para guardar cambios en este partido.";
                return;
            }

            if (!access.CanModerate)
            {
                if (access.UserId is not { } userId)
                {
                    errorMessage = "No se pudo identificar el usuario actual.";
                    return;
                }

                var payload = new MatchStatusAndResultProposalPayload(editing.Status);
                Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchStatusAndResult(
                    editing.MatchId,
                    userId,
                    editing.Status,
                    null,
                    null,
                    ToJson(payload)));

                await Db.SaveChangesAsync();
                await LoadPendingProposalsAsync();
                successMessage = "Propuesta enviada para revision.";
                return;
            }

            if (!DateTime.TryParse(editing.StartsAtInput, out var startsAtLocal))
            {
                errorMessage = "Fecha/hora de partido invalida.";
                return;
            }

            var startsAt = new DateTimeOffset(DateTime.SpecifyKind(startsAtLocal, DateTimeKind.Local)).ToUniversalTime();
            Db.Entry(match).Property(x => x.Status).CurrentValue = editing.Status;
            Db.Entry(match).Property(x => x.StartsAt).CurrentValue = startsAt;
            Db.Entry(match).Property(x => x.HomeTeamId).CurrentValue = editing.HomeTeamId;
            Db.Entry(match).Property(x => x.AwayTeamId).CurrentValue = editing.AwayTeamId;
            await Db.SaveChangesAsync();
            await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(match.Id);
            var selectedMatchId = editing.MatchId;
            await LoadMatchesAsync();
            await SelectMatchAsync(selectedMatchId);
            await NotifyMatchDataChangedAsync();

            successMessage = "Resultado actualizado correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo guardar el resultado. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LoadSelectedEventsAsync(Guid matchId)
    {
        selectedEvents.Clear();
        eventEdits.Clear();
        eventEditDiscipline.Clear();
        unavailableEventPlayerIds.Clear();
        selectedEvents.AddRange(await Db.MatchEvents
            .AsNoTracking()
            .Include(x => x.Team)!.ThenInclude(x => x!.Club)
            .Include(x => x.Player)
            .Where(x => x.MatchId == matchId)
            .OrderBy(x => x.Minute)
            .ThenBy(x => x.CreatedAt)
            .Select(x => new AdminMatchEventRow(
                x.Id,
                x.Type,
                x.Minute,
                x.TeamId,
                x.Team != null ? x.Team.Club!.ShortName : "Sin equipo",
                x.PlayerId,
                x.PlayerName != string.Empty ? x.PlayerName : x.Player != null ? x.Player.DisplayName : "Sin jugador",
                x.Notes))
            .ToListAsync());

        foreach (var item in selectedEvents)
        {
            eventEdits[item.Id] = new EventEditModel
            {
                EventType = item.EventType,
                Minute = item.Minute,
                TeamId = item.TeamId ?? editing?.HomeTeamId ?? Guid.Empty,
                PlayerId = item.PlayerId,
                PlayerName = item.PlayerName,
                Notes = item.Notes ?? string.Empty
            };
        }

        foreach (var playerId in ExpelledPlayerIdsFromEvents(selectedEvents))
        {
            unavailableEventPlayerIds.Add(playerId);
        }
    }

    private async Task CreateEventAsync()
    {
        if (editing is null || isSavingEvent)
        {
            return;
        }

        successMessage = null;
        errorMessage = Validate(eventForm, editing, eventPlayers);
        if (errorMessage is not null)
        {
            return;
        }

        if (!access.CanManageMatch(editing.HomeTeamId, editing.AwayTeamId))
        {
            errorMessage = "No tenes permisos para agregar eventos en este partido.";
            return;
        }

        var match = await Db.Matches
            .AsNoTracking()
            .Include(x => x.HomeTeam)
            .Include(x => x.AwayTeam)
            .FirstOrDefaultAsync(x => x.Id == editing.MatchId);

        errorMessage = ValidateMatchEventOperation(match, eventForm);
        if (errorMessage is not null)
        {
            return;
        }

        errorMessage = await ValidatePlayerAvailabilityForEventAsync(
            editing.MatchId,
            eventForm.PlayerId,
            eventForm.EventType,
            null);
        if (errorMessage is not null)
        {
            return;
        }

        isSavingEvent = true;
        try
        {
            if (!access.CanModerate)
            {
                if (access.UserId is not { } userId)
                {
                    errorMessage = "No se pudo identificar el usuario actual.";
                    return;
                }

                var payload = new MatchEventAddProposalPayload(
                    eventForm.EventType,
                    eventForm.Minute,
                    eventForm.TeamId,
                    eventForm.PlayerId,
                    eventForm.PlayerName.Trim(),
                    eventForm.Notes?.Trim());

                Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchEvent(
                    editing.MatchId,
                    userId,
                    ProposalChangeType.MatchEventAdd,
                    ToJson(payload)));

                await Db.SaveChangesAsync();
                eventForm.PlayerName = string.Empty;
                eventForm.PlayerId = null;
                eventForm.Notes = string.Empty;
                eventForm.Minute = 0;
                selectedEventPlayerDiscipline = null;
                await LoadPendingProposalsAsync();
                successMessage = "Propuesta enviada para revision.";
                return;
            }

            Db.MatchEvents.Add(new MatchEvent(
                editing.MatchId,
                eventForm.EventType,
                eventForm.Minute,
                eventForm.TeamId,
                eventForm.PlayerId,
                notes: eventForm.Notes?.Trim(),
                playerName: eventForm.PlayerName));

            await Db.SaveChangesAsync();
            if (eventForm.EventType == MatchEventType.Goal)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(editing.MatchId);
            }

            await LoadSelectedEventsAsync(editing.MatchId);
            var selectedMatchId = editing.MatchId;
            eventForm.PlayerName = string.Empty;
            eventForm.PlayerId = null;
            eventForm.Notes = string.Empty;
            eventForm.Minute = 0;
            selectedEventPlayerDiscipline = null;
            await LoadMatchesAsync();
            await SelectMatchAsync(selectedMatchId);
            await NotifyMatchDataChangedAsync();
            successMessage = "Evento agregado correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo agregar el evento. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isSavingEvent = false;
        }
    }

    private async Task DeleteEventAsync(Guid eventId)
    {
        if (editing is null)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        if (!access.CanManageMatch(editing.HomeTeamId, editing.AwayTeamId))
        {
            errorMessage = "No tenes permisos para eliminar eventos de este partido.";
            return;
        }

        var matchEvent = await Db.MatchEvents.FirstOrDefaultAsync(x => x.Id == eventId && x.MatchId == editing.MatchId);
        if (matchEvent is null)
        {
            errorMessage = "No se encontro el evento seleccionado.";
            return;
        }

        if (!access.CanModerate)
        {
            if (access.UserId is not { } userId)
            {
                errorMessage = "No se pudo identificar el usuario actual.";
                return;
            }

            var payload = new MatchEventDeleteProposalPayload(
                matchEvent.Id,
                matchEvent.Type,
                matchEvent.Minute,
                matchEvent.TeamId,
                !string.IsNullOrWhiteSpace(matchEvent.PlayerName) ? matchEvent.PlayerName : "Sin jugador");

            Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchEvent(
                editing.MatchId,
                userId,
                ProposalChangeType.MatchEventDelete,
                ToJson(payload)));

            await Db.SaveChangesAsync();
            await LoadPendingProposalsAsync();
            successMessage = "Propuesta enviada para revision.";
            return;
        }

        var deletedEventType = matchEvent.Type;
        Db.MatchEvents.Remove(matchEvent);
        await Db.SaveChangesAsync();
        if (deletedEventType == MatchEventType.Goal)
        {
            await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(editing.MatchId);
        }

        var selectedMatchId = editing.MatchId;
        await LoadMatchesAsync();
        await SelectMatchAsync(selectedMatchId);
        await LoadSelectedEventsAsync(editing.MatchId);
        await NotifyMatchDataChangedAsync();
        successMessage = "Evento eliminado correctamente.";
    }

    private async Task SaveEventEditAsync(Guid eventId)
    {
        if (editing is null || !access.CanModerate || isSavingEvent)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        if (!eventEdits.TryGetValue(eventId, out var edit))
        {
            errorMessage = "No se encontro la edicion del evento.";
            return;
        }

        errorMessage = Validate(edit, editing, EventPlayersForTeam(edit.TeamId, edit.PlayerId));
        if (errorMessage is not null)
        {
            return;
        }

        errorMessage = await ValidatePlayerAvailabilityForEventAsync(
            editing.MatchId,
            edit.PlayerId,
            edit.EventType,
            eventId);
        if (errorMessage is not null)
        {
            return;
        }

        if (!access.CanManageMatch(editing.HomeTeamId, editing.AwayTeamId))
        {
            errorMessage = "No tenes permisos para editar eventos de este partido.";
            return;
        }

        var matchEvent = await Db.MatchEvents.FirstOrDefaultAsync(x => x.Id == eventId && x.MatchId == editing.MatchId);
        if (matchEvent is null)
        {
            errorMessage = "No se encontro el evento seleccionado.";
            return;
        }

        var oldType = matchEvent.Type;
        isSavingEvent = true;
        try
        {
            Db.Entry(matchEvent).Property(x => x.Type).CurrentValue = edit.EventType;
            Db.Entry(matchEvent).Property(x => x.Minute).CurrentValue = edit.Minute;
            Db.Entry(matchEvent).Property(x => x.TeamId).CurrentValue = edit.TeamId;
            Db.Entry(matchEvent).Property(x => x.PlayerId).CurrentValue = edit.PlayerId;
            Db.Entry(matchEvent).Property(x => x.PlayerName).CurrentValue = edit.PlayerName.Trim();
            Db.Entry(matchEvent).Property(x => x.Notes).CurrentValue = string.IsNullOrWhiteSpace(edit.Notes) ? null : edit.Notes.Trim();
            await Db.SaveChangesAsync();

            if (oldType == MatchEventType.Goal || edit.EventType == MatchEventType.Goal)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(editing.MatchId);
            }

            var selectedMatchId = editing.MatchId;
            editingEventId = null;
            await LoadMatchesAsync();
            await SelectMatchAsync(selectedMatchId);
            await NotifyMatchDataChangedAsync();
            successMessage = "Evento actualizado correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo actualizar el evento. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isSavingEvent = false;
        }
    }

    private async Task NotifyMatchDataChangedAsync()
    {
        await MatchUpdates.Clients.All.SendAsync(MatchUpdatesHub.MatchDataChanged);
        Logger.LogInformation("SignalR notification {EventName} emitted.", MatchUpdatesHub.MatchDataChanged);
    }

    private async Task ApproveProposalAsync(Guid proposalId)
    {
        if (!access.CanModerate || isReviewingProposal)
        {
            return;
        }

        if (access.UserId is not { } reviewerId)
        {
            errorMessage = "No se pudo identificar el usuario moderador.";
            return;
        }

        successMessage = null;
        errorMessage = null;
        isReviewingProposal = true;

        try
        {
            var proposal = await Db.MatchUpdateProposals
                .Include(x => x.Match)
                .FirstOrDefaultAsync(x => x.Id == proposalId && x.Status == ProposalStatus.Pending);

            if (proposal is null)
            {
                errorMessage = "La propuesta ya no esta pendiente.";
                return;
            }

            var shouldRecalculateScoreAndStandings = await ApplyProposalAsync(proposal);
            proposal.Approve(reviewerId);
            await Db.SaveChangesAsync();

            if (shouldRecalculateScoreAndStandings)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(proposal.MatchId);
            }

            await LoadMatchesAsync();
            if (editing is not null)
            {
                await SelectMatchAsync(editing.MatchId);
            }

            await LoadPendingProposalsAsync();
            await NotifyMatchDataChangedAsync();
            successMessage = "Propuesta aprobada y aplicada correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo aprobar la propuesta. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isReviewingProposal = false;
        }
    }

    private async Task RejectProposalAsync(Guid proposalId)
    {
        if (!access.CanModerate || isReviewingProposal)
        {
            return;
        }

        if (access.UserId is not { } reviewerId)
        {
            errorMessage = "No se pudo identificar el usuario moderador.";
            return;
        }

        successMessage = null;
        errorMessage = null;
        isReviewingProposal = true;

        try
        {
            var proposal = await Db.MatchUpdateProposals
                .FirstOrDefaultAsync(x => x.Id == proposalId && x.Status == ProposalStatus.Pending);

            if (proposal is null)
            {
                errorMessage = "La propuesta ya no esta pendiente.";
                return;
            }

            var shouldRecalculateScoreAndStandings = proposal.ChangeType == ProposalChangeType.MatchEventDelete
                && FromJson<MatchEventDeleteProposalPayload>(proposal.PayloadJson).EventType == MatchEventType.Goal;

            proposal.Reject(reviewerId);
            await Db.SaveChangesAsync();
            if (shouldRecalculateScoreAndStandings)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(proposal.MatchId);
                await NotifyMatchDataChangedAsync();
            }

            await LoadPendingProposalsAsync();
            successMessage = "Propuesta rechazada.";
        }
        finally
        {
            isReviewingProposal = false;
        }
    }

    private async Task<bool> ApplyProposalAsync(MatchUpdateProposal proposal)
    {
        if (proposal.Match is null)
        {
            throw new InvalidOperationException("La propuesta no tiene partido asociado.");
        }

        switch (proposal.ChangeType)
        {
            case ProposalChangeType.MatchStatusAndResult:
                Db.Entry(proposal.Match).Property(x => x.Status).CurrentValue = proposal.ProposedStatus ?? proposal.Match.Status;
                return true;

            case ProposalChangeType.MatchEventAdd:
                var addPayload = FromJson<MatchEventAddProposalPayload>(proposal.PayloadJson);
                Db.MatchEvents.Add(new MatchEvent(
                    proposal.MatchId,
                    addPayload.EventType,
                    addPayload.Minute,
                    addPayload.TeamId,
                    addPayload.PlayerId,
                    notes: addPayload.Notes,
                    playerName: addPayload.PlayerName));
                return addPayload.EventType == MatchEventType.Goal;

            case ProposalChangeType.MatchEventDelete:
                var deletePayload = FromJson<MatchEventDeleteProposalPayload>(proposal.PayloadJson);
                var matchEvent = await Db.MatchEvents.FirstOrDefaultAsync(x => x.Id == deletePayload.EventId && x.MatchId == proposal.MatchId);
                if (matchEvent is not null)
                {
                    Db.MatchEvents.Remove(matchEvent);
                }

                return deletePayload.EventType == MatchEventType.Goal;

            default:
                throw new InvalidOperationException("Tipo de propuesta no soportado.");
        }
    }

    private async Task<string?> ValidateMatchEditAsync(AdminMatchEditModel model)
    {
        if (model.HomeTeamId == model.AwayTeamId)
        {
            return "Local y visitante deben ser distintos.";
        }

        if (!DateTime.TryParse(model.StartsAtInput, out var startsAtLocal))
        {
            return "Fecha/hora de partido invalida.";
        }

        if (!access.CanModerate)
        {
            return null;
        }

        var teamIds = await Db.Teams
            .AsNoTracking()
            .Where(x => x.CompetitionId == model.CompetitionId && x.IsActive && x.Club!.IsActive)
            .Select(x => x.Id)
            .ToListAsync();
        if (!teamIds.Contains(model.HomeTeamId) || !teamIds.Contains(model.AwayTeamId))
        {
            return "Ambos equipos deben pertenecer a la competencia y estar activos.";
        }

        var teamAlreadyPlays = await Db.Matches
            .AsNoTracking()
            .AnyAsync(x =>
                x.Id != model.MatchId &&
                x.CompetitionId == model.CompetitionId &&
                x.RoundId == model.RoundId &&
                (x.HomeTeamId == model.HomeTeamId ||
                    x.AwayTeamId == model.HomeTeamId ||
                    x.HomeTeamId == model.AwayTeamId ||
                    x.AwayTeamId == model.AwayTeamId));
        if (teamAlreadyPlays)
        {
            return "Un equipo no puede jugar mas de un partido en la misma jornada de la competencia.";
        }

        var startsAt = new DateTimeOffset(DateTime.SpecifyKind(startsAtLocal, DateTimeKind.Local)).ToUniversalTime();
        var duplicateMatch = await Db.Matches
            .AsNoTracking()
            .AnyAsync(x =>
                x.Id != model.MatchId &&
                x.CompetitionId == model.CompetitionId &&
                x.HomeTeamId == model.HomeTeamId &&
                x.AwayTeamId == model.AwayTeamId &&
                x.StartsAt == startsAt);
        if (duplicateMatch)
        {
            return "Ya existe un partido con el mismo local, visitante y fecha/hora.";
        }

        return null;
    }

    private static string? Validate(EventCreateModel model, AdminMatchEditModel match, IReadOnlyCollection<EventPlayerOption> teamPlayers)
    {
        if (model.Minute is < 0 or > 130)
        {
            return "El minuto debe estar entre 0 y 130.";
        }

        if (model.TeamId != match.HomeTeamId && model.TeamId != match.AwayTeamId)
        {
            return "El equipo seleccionado no pertenece al partido.";
        }

        if (!AllowedEventTypes.Contains(model.EventType))
        {
            return "El tipo de evento seleccionado no esta permitido.";
        }

        if (teamPlayers.Count > 0 && model.PlayerId is null)
        {
            return "Selecciona un jugador activo del plantel.";
        }

        if (model.PlayerId is not null && teamPlayers.All(x => x.Id != model.PlayerId))
        {
            return "El jugador seleccionado no pertenece al equipo o esta inactivo.";
        }

        if (teamPlayers.Count == 0 && string.IsNullOrWhiteSpace(model.PlayerName))
        {
            return "Indica el jugador del evento.";
        }

        if (model.PlayerId is not null && string.IsNullOrWhiteSpace(model.PlayerName))
        {
            return "No se pudo resolver el nombre snapshot del jugador.";
        }

        return null;
    }

