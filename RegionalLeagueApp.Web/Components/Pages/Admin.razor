@page "/admin"
@page "/admin/matches/{RouteMatchId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireContributor")]
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Collaboration
@using RegionalLeagueApp.Application.Discipline
@using RegionalLeagueApp.Application.Matches
@using RegionalLeagueApp.Domain.Collaboration
@using RegionalLeagueApp.Web.Hubs
@inject ApplicationDbContext Db
@inject IMatchAdministrationPermissionService PermissionService
@inject IMatchScoreRecalculationService MatchScoreRecalculationService
@inject IDisciplineQueryService DisciplineQueryService
@inject IHubContext<MatchUpdatesHub> MatchUpdates
@inject ILogger<Admin> Logger
@inject NavigationManager Navigation

<PageTitle>@(IsMatchAdminRoute ? "Administrar partido" : "Admin")</PageTitle>

@if (IsMatchAdminRoute)
{
    <PageBreadcrumb
        BackHref="@(editing is null ? "/admin" : $"/admin/leagues/{editing.LeagueId}")"
        ParentHref="/admin"
        ParentLabel="Admin"
        CurrentLabel="@AdminMatchBreadcrumbLabel" />
}

<div class="page-heading admin-heading">
    <div>
        <p class="eyebrow">Administracion</p>
        <h1>@(IsMatchAdminRoute ? "Gestion de partido" : "Panel general")</h1>
    </div>
    <span class="admin-badge">@access.RoleLabel</span>
</div>

@if (!IsMatchAdminRoute)
{
    <section class="panel admin-permissions">
        <div>
            <p class="eyebrow">Permisos actuales</p>
            <h2>@PermissionSummary</h2>
        </div>
        @if (access.IsContributor && !access.CanManageAllMatches)
        {
            <span>@access.AssignedTeamIds.Count equipo(s) asignado(s)</span>
        }
        else if (access.CanModerate)
        {
            <span>Puede moderar todos los partidos y eventos</span>
        }
    </section>

    @if (access.CanModerate)
    {
        <section class="panel admin-league-entry">
            <div>
                <p class="eyebrow">Estructura deportiva</p>
                <h2>Ligas, temporadas y competencias</h2>
                <span>Usa el contexto administrativo de cada liga para crear temporadas, competencias, equipos y partidos.</span>
            </div>
            <a class="leagues-button leagues-button--muted" href="/leagues">Gestionar ligas</a>
        </section>
    }
}

<FormMessage Message="@successMessage" Variant="success" />
<FormMessage Message="@errorMessage" Variant="danger" />

@if (!IsMatchAdminRoute && access.CanModerate)
{
    <section class="panel admin-proposals">
        <div class="panel-title-row">
            <div>
                <p class="eyebrow">Moderacion</p>
                <h2>Propuestas pendientes</h2>
            </div>
            <span>@pendingProposals.Count pendiente(s)</span>
        </div>

        @if (pendingProposals.Count == 0)
        {
            <EmptyState Text="No hay propuestas pendientes." />
        }
        else
        {
            <div class="admin-proposal-list">
                @foreach (var proposal in pendingProposals)
                {
                    <article class="admin-proposal-row">
                        <div>
                            <strong>@proposal.MatchLabel</strong>
                            <span>@proposal.Description</span>
                            <small>@proposal.ProposedBy - @proposal.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="admin-proposal-actions">
                            <button type="button" class="admin-link-button" disabled="@isReviewingProposal" @onclick="async () => await ApproveProposalAsync(proposal.Id)">Aprobar</button>
                            <button type="button" class="admin-link-button admin-link-button-muted" disabled="@isReviewingProposal" @onclick="async () => await RejectProposalAsync(proposal.Id)">Rechazar</button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
}

@if (IsMatchAdminRoute)
{
    @if (editing is null)
    {
        <EmptyState Text="No se pudo cargar el partido solicitado o no tenes permisos para gestionarlo." />
    }
    else
    {
        <section class="admin-match-shell">
            <article class="panel admin-match-header-card">
                <div class="admin-match-context">
                    <span>@editing.LeagueName</span>
                    <span>@editing.SeasonName</span>
                    <span>@editing.CompetitionName</span>
                    <span>@editing.RoundName</span>
                </div>
                <div class="admin-match-scoreboard">
                    <div>
                        <strong>@editing.HomeTeamName</strong>
                        <small>Local</small>
                    </div>
                    <div class="admin-match-score">
                        <StatusBadge MatchStatusValue="editing.Status" Compact="true" />
                        <strong>@ScoreText(editing.HomeScore, editing.AwayScore)</strong>
                        <small>@editing.StartsAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <div>
                        <strong>@editing.AwayTeamName</strong>
                        <small>Visitante</small>
                    </div>
                </div>
                <div class="admin-match-links">
                    <a class="admin-link-button admin-link-button-muted" href="/admin">Volver al admin</a>
                    <a class="admin-link-button" href="/matches/@editing.MatchId">Vista publica</a>
                </div>
            </article>

            <section class="admin-match-layout">
                <article class="panel admin-match-editor">
                    <div class="panel-title-row">
                        <PanelHeader Eyebrow="Partido" Title="Datos operativos" />
                    </div>

                    <EditForm Model="editing" OnValidSubmit="SaveAsync" class="admin-form" aria-busy="@isSaving">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="admin-match-edit-grid">
                            <label>
                                Estado
                                <InputSelect class="form-control" @bind-Value="editing.Status">
                                    @foreach (var status in Enum.GetValues<MatchStatus>())
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </InputSelect>
                            </label>
                            <label>
                                Fecha/hora
                                <input class="form-control" type="datetime-local" value="@editing.StartsAtInput" @oninput="e => editing.StartsAtInput = e.Value?.ToString() ?? string.Empty" disabled="@(!access.CanModerate)" />
                            </label>
                            <label>
                                Local
                                <InputSelect class="form-control" @bind-Value="editing.HomeTeamId" disabled="@(!access.CanModerate)">
                                    @foreach (var team in matchTeamOptions)
                                    {
                                        <option value="@team.Id">@team.Label</option>
                                    }
                                </InputSelect>
                            </label>
                            <label>
                                Visitante
                                <InputSelect class="form-control" @bind-Value="editing.AwayTeamId" disabled="@(!access.CanModerate)">
                                    @foreach (var team in matchTeamOptions)
                                    {
                                        <option value="@team.Id">@team.Label</option>
                                    }
                                </InputSelect>
                            </label>
                        </div>

                        <p class="admin-help-text">El marcador se calcula automaticamente desde los goles.</p>

                        <button class="btn btn-primary" type="submit" disabled="@isSaving">
                            @(isSaving ? "Guardando..." : access.CanModerate ? "Guardar cambios" : "Enviar propuesta")
                        </button>
                    </EditForm>
                </article>

                <article class="panel admin-events">
                    <div class="panel-title-row">
                        <PanelHeader Eyebrow="Eventos" Title="Linea de tiempo" Meta="@($"{selectedEvents.Count} eventos")" />
                    </div>

                    @if (selectedEvents.Count == 0)
                    {
                        <EmptyState Text="No hay eventos cargados para este partido." />
                    }
                    else
                    {
                        <div class="admin-event-list">
                            @foreach (var group in SelectedEventGroups)
                            {
                                <section class="admin-event-period">
                                    <h3>@group.Key</h3>
                                    <div class="admin-event-table-head" aria-hidden="true">
                                        <span>Min</span>
                                        <span>Evento</span>
                                        <span>Equipo</span>
                                        <span>Jugador</span>
                                        <span>Nota</span>
                                        <span>Acciones</span>
                                    </div>
                                    @foreach (var item in group)
                                    {
                                        var edit = GetEventEdit(item);
                                        <article class="admin-event-row @(editingEventId == item.Id ? "admin-event-row--editing" : string.Empty)">
                                            <div class="admin-event-main">
                                                <strong>@item.Minute'</strong>
                                                <span class="admin-event-kind">
                                                    <MatchEventIcon EventType="item.EventType" IsSecondYellow="IsSecondYellowCard(item)" Compact="true" />
                                                    @EventLabel(item)
                                                    @if (IsSecondYellowCard(item))
                                                    {
                                                        <small class="second-yellow-badge">2da amarilla</small>
                                                    }
                                                </span>
                                                <small>@item.TeamName</small>
                                                <small>@item.PlayerName</small>
                                                <span class="admin-event-note">@(!string.IsNullOrWhiteSpace(item.Notes) ? item.Notes : "-")</span>
                                                    <div class="admin-event-actions">
                                                        @if (access.CanModerate)
                                                        {
                                                            <button type="button" class="admin-link-button" @onclick="async () => await BeginEventEditAsync(item)">Editar</button>
                                                        }
                                                    <button type="button" class="admin-link-button admin-link-button-muted" @onclick="async () => await DeleteEventAsync(item.Id)">@(access.CanModerate ? "Quitar evento" : "Proponer quitar")</button>
                                                </div>
                                            </div>

                                            @if (editingEventId == item.Id && access.CanModerate)
                                            {
                                                <div class="admin-event-editor">
                                                    <div class="admin-event-editor-grid">
                                                        <label>Minuto <InputNumber class="form-control" min="0" max="130" @bind-Value="edit.Minute" /></label>
                                                        <label>
                                                            Evento
                                                            <InputSelect class="form-control" @bind-Value="edit.EventType">
                                                                @foreach (var eventType in AllowedEventTypes)
                                                                {
                                                                    <option value="@eventType">@EventLabel(eventType)</option>
                                                                }
                                                            </InputSelect>
                                                        </label>
                                                        <label>
                                                            Equipo
                                                            <InputSelect class="form-control" @bind-Value="edit.TeamId" @bind-Value:after="() => OnEventEditTeamChanged(edit)">
                                                                <option value="@editing.HomeTeamId">@editing.HomeTeamName</option>
                                                                <option value="@editing.AwayTeamId">@editing.AwayTeamName</option>
                                                            </InputSelect>
                                                        </label>
                                                        <label>
                                                            Jugador
                                                            @if (EventPlayersForTeam(edit.TeamId, edit.PlayerId).Count == 0)
                                                            {
                                                                <InputText class="form-control" @bind-Value="edit.PlayerName" placeholder="Nombre del jugador" />
                                                            }
                                                            else
                                                            {
                                                                <select class="form-control" value="@edit.PlayerId" @onchange="async e => await OnEventEditPlayerChangedAsync(item.Id, edit, e)">
                                                                    <option value="">Seleccionar jugador</option>
                                                                    @foreach (var player in EventPlayersForTeam(edit.TeamId, edit.PlayerId))
                                                                    {
                                                                        <option value="@player.Id">@player.Label</option>
                                                                    }
                                                                </select>
                                                                @if (eventEditDiscipline.GetValueOrDefault(item.Id)?.Status == DisciplineStatus.Suspended)
                                                                {
                                                                    <small class="admin-discipline-warning">Suspendido por acumulacion disciplinaria en esta competencia.</small>
                                                                }
                                                            }
                                                        </label>
                                                        <label>Nota <InputText class="form-control" @bind-Value="edit.Notes" /></label>
                                                    </div>
                                                    <div class="admin-event-actions admin-event-editor-actions">
                                                        <button type="button" class="admin-link-button" disabled="@isSavingEvent" @onclick="() => SaveEventEditAsync(item.Id)">Guardar</button>
                                                        <button type="button" class="admin-link-button admin-link-button-muted" disabled="@isSavingEvent" @onclick="CancelEventEdit">Cancelar</button>
                                                    </div>
                                                </div>
                                            }
                                        </article>
                                    }
                                </section>
                            }
                        </div>
                    }

                    <EditForm Model="eventForm" OnValidSubmit="CreateEventAsync" class="admin-form admin-event-form">
                        <DataAnnotationsValidator />

                        <div class="admin-event-editor-grid">
                            <label>
                                Evento
                                <InputSelect class="form-control" @bind-Value="eventForm.EventType">
                                    @foreach (var eventType in AllowedEventTypes)
                                    {
                                        <option value="@eventType">@EventLabel(eventType)</option>
                                    }
                                </InputSelect>
                            </label>
                            <label>
                                Equipo
                                <InputSelect class="form-control" @bind-Value="eventForm.TeamId" @bind-Value:after="OnEventTeamChangedAsync">
                                    <option value="@editing.HomeTeamId">@editing.HomeTeamName</option>
                                    <option value="@editing.AwayTeamId">@editing.AwayTeamName</option>
                                </InputSelect>
                            </label>
                            <label>
                                Jugador
                                @if (eventPlayers.Count == 0)
                                {
                                    <InputText class="form-control" @bind-Value="eventForm.PlayerName" placeholder="Nombre del jugador" />
                                    <ValidationMessage For="() => eventForm.PlayerName" />
                                }
                                else
                                {
                                    <InputSelect class="form-control" @bind-Value="eventForm.PlayerId" @bind-Value:after="OnEventPlayerChanged">
                                        <option value="">Seleccionar jugador</option>
                                        @foreach (var player in eventPlayers)
                                        {
                                            <option value="@player.Id">@player.Label</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => eventForm.PlayerId" />
                                    @if (selectedEventPlayerDiscipline?.Status == DisciplineStatus.Suspended)
                                    {
                                        <small class="admin-discipline-warning">Suspendido por acumulacion disciplinaria en esta competencia.</small>
                                    }
                                }
                            </label>
                            <label>
                                Minuto
                                <InputNumber class="form-control" min="0" max="130" @bind-Value="eventForm.Minute" />
                                <ValidationMessage For="() => eventForm.Minute" />
                            </label>
                            <label>
                                Nota
                                <InputText class="form-control" @bind-Value="eventForm.Notes" />
                            </label>
                        </div>

                        <button class="btn btn-primary" type="submit" disabled="@isSavingEvent">
                            @(isSavingEvent ? "Agregando..." : access.CanModerate ? "Agregar evento" : "Proponer evento")
                        </button>
                    </EditForm>
                </article>
            </section>
        </section>
    }
}
else
{
    <section class="panel admin-league-entry">
        <div>
            <p class="eyebrow">Partidos</p>
            <h2>Gestion por contexto</h2>
            <span>Para editar un partido, entra desde la liga administrativa o desde el Match Center publico. Esta vista ya no carga el fixture global.</span>
        </div>
        <a class="leagues-button leagues-button--muted" href="/leagues">Ir a ligas</a>
    </section>

    <section class="panel admin-league-entry">
        <div>
            <p class="eyebrow">Flujo recomendado</p>
            <h2>Liga -> competencia -> partido</h2>
            <span>La gestion operativa de eventos, estado y fecha vive en /admin/matches/{id}.</span>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid? RouteMatchId { get; set; }

    [SupplyParameterFromQuery(Name = "matchId")]
    public Guid? RequestedMatchId { get; set; }

    private readonly List<AdminMatchRow> matches = [];
    private MatchEditModel? editing;
    private EventCreateModel eventForm = new();
    private readonly List<AdminMatchEventRow> selectedEvents = [];
    private readonly List<EventPlayerOption> eventPlayers = [];
    private readonly List<EventPlayerOption> allMatchEventPlayers = [];
    private readonly HashSet<Guid> unavailableEventPlayerIds = [];
    private readonly Dictionary<Guid, EventEditModel> eventEdits = [];
    private readonly Dictionary<Guid, DisciplineRowDto?> eventEditDiscipline = [];
    private readonly List<PendingProposalRow> pendingProposals = [];
    private readonly List<TeamOption> matchTeamOptions = [];
    private MatchAdministrationAccess access = MatchAdministrationAccess.Empty;
    private bool isSaving;
    private bool isSavingEvent;
    private bool isReviewingProposal;
    private Guid? editingEventId;
    private DisciplineRowDto? selectedEventPlayerDiscipline;
    private string? successMessage;
    private string? errorMessage;
    private string statusFilter = string.Empty;
    private string roundFilter = string.Empty;
    private string clubFilter = string.Empty;
    private static readonly MatchEventType[] AllowedEventTypes =
    [
        MatchEventType.Goal,
        MatchEventType.YellowCard,
        MatchEventType.RedCard
    ];
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    private bool IsMatchAdminRoute => RouteMatchId is not null;

    private string AdminMatchBreadcrumbLabel => editing is null
        ? "Partido"
        : $"{editing.LeagueName} / {editing.CompetitionName} / {editing.HomeTeamName} vs {editing.AwayTeamName}";

    private string PermissionSummary => access.CanManageAllMatches
        ? "Puede editar cualquier partido y moderar eventos."
        : access.IsContributor
            ? "Puede enviar propuestas de resultados y eventos en partidos asignados."
            : "No tiene permisos para administrar partidos.";

    private List<AdminMatchRow> FilteredMatches => matches
        .Where(match => string.IsNullOrWhiteSpace(statusFilter) || match.Status.ToString() == statusFilter)
        .Where(match => string.IsNullOrWhiteSpace(roundFilter) || match.RoundName == roundFilter)
        .Where(match => string.IsNullOrWhiteSpace(clubFilter) || match.HomeTeamName == clubFilter || match.AwayTeamName == clubFilter)
        .ToList();

    private IEnumerable<IGrouping<string, AdminMatchEventRow>> SelectedEventGroups => selectedEvents
        .GroupBy(item => EventPeriod(item.Minute))
        .OrderBy(group => group.Min(item => item.Minute));

    private List<string> RoundOptions => matches
        .Select(match => match.RoundName)
        .Distinct()
        .OrderBy(roundName => roundName)
        .ToList();

    private List<string> ClubOptions => matches
        .SelectMany(match => new[] { match.HomeTeamName, match.AwayTeamName })
        .Distinct()
        .OrderBy(clubName => clubName)
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        access = await PermissionService.GetAccessAsync();

        if (IsMatchAdminRoute && RouteMatchId is { } routeMatchId)
        {
            await LoadMatchesAsync();
            await SelectMatchAsync(routeMatchId);
            return;
        }

        await LoadPendingProposalsAsync();

        if (RequestedMatchId is { } matchId)
        {
            Navigation.NavigateTo($"/admin/matches/{matchId}", replace: true);
        }
    }

    private async Task LoadMatchesAsync()
    {
        matches.Clear();
        if (!IsMatchAdminRoute || RouteMatchId is null)
        {
            return;
        }

        matches.AddRange(await Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)!.ThenInclude(x => x!.Season)!.ThenInclude(x => x!.League)
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Id == RouteMatchId && (access.CanManageAllMatches || access.AssignedTeamIds.Contains(x.HomeTeamId) || access.AssignedTeamIds.Contains(x.AwayTeamId)))
            .OrderByDescending(x => x.StartsAt)
            .Select(x => new AdminMatchRow(
                x.Id,
                x.CompetitionId,
                x.Competition!.Season!.LeagueId,
                x.Competition.Season.League!.Name,
                x.Competition.Season.Name,
                x.Competition!.Name,
                x.RoundId,
                x.Round!.Name,
                x.HomeTeamId,
                x.HomeTeam!.Club!.Name,
                x.AwayTeamId,
                x.AwayTeam!.Club!.Name,
                x.StartsAt,
                x.Status,
                x.HomeScore,
                x.AwayScore))
            .ToListAsync());
    }

    private async Task LoadPendingProposalsAsync()
    {
        pendingProposals.Clear();

        if (!access.CanModerate)
        {
            return;
        }

        var proposals = await Db.MatchUpdateProposals
            .AsNoTracking()
            .Include(x => x.ProposedByUser)
            .Include(x => x.Match)!.ThenInclude(x => x!.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Match)!.ThenInclude(x => x!.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == ProposalStatus.Pending)
            .OrderBy(x => x.CreatedAt)
            .Select(x => new
            {
                x.Id,
                x.ChangeType,
                x.PayloadJson,
                x.ProposedStatus,
                x.CreatedAt,
                ProposedBy = x.ProposedByUser != null ? x.ProposedByUser.DisplayName : "Usuario",
                HomeTeamName = x.Match != null && x.Match.HomeTeam != null ? x.Match.HomeTeam.Club!.Name : "Local",
                AwayTeamName = x.Match != null && x.Match.AwayTeam != null ? x.Match.AwayTeam.Club!.Name : "Visitante"
            })
            .ToListAsync();

        pendingProposals.AddRange(proposals.Select(x => new PendingProposalRow(
            x.Id,
            $"{x.HomeTeamName} vs {x.AwayTeamName}",
            x.ProposedBy,
            x.CreatedAt,
            ProposalDescription(x.ChangeType, x.PayloadJson, x.ProposedStatus))));
    }

    private async Task SelectMatchAsync(Guid matchId)
    {
        successMessage = null;
        errorMessage = null;

        var match = matches.FirstOrDefault(x => x.Id == matchId);
        if (match is null || !access.CanManageMatch(match.HomeTeamId, match.AwayTeamId))
        {
            editing = null;
            selectedEvents.Clear();
            errorMessage = "No tenes permisos para editar este partido.";
            return;
        }

        editing = new MatchEditModel
        {
            MatchId = match.Id,
            CompetitionId = match.CompetitionId,
            LeagueId = match.LeagueId,
            LeagueName = match.LeagueName,
            SeasonName = match.SeasonName,
            CompetitionName = match.CompetitionName,
            RoundId = match.RoundId,
            RoundName = match.RoundName,
            HomeTeamId = match.HomeTeamId,
            HomeTeamName = match.HomeTeamName,
            AwayTeamId = match.AwayTeamId,
            AwayTeamName = match.AwayTeamName,
            StartsAt = match.StartsAt,
            StartsAtInput = match.StartsAt.LocalDateTime.ToString("yyyy-MM-ddTHH:mm"),
            Status = match.Status,
            HomeScore = match.HomeScore,
            AwayScore = match.AwayScore
        };

        eventForm = new EventCreateModel
        {
            TeamId = match.HomeTeamId,
            EventType = MatchEventType.Goal
        };
        selectedEventPlayerDiscipline = null;

        await LoadMatchTeamOptionsAsync(match.CompetitionId);
        await LoadSelectedEventsAsync(match.Id);
        await LoadAllMatchEventPlayersAsync(match.HomeTeamId, match.AwayTeamId);
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private async Task LoadMatchTeamOptionsAsync(Guid competitionId)
    {
        matchTeamOptions.Clear();
        matchTeamOptions.AddRange(await Db.Teams
            .AsNoTracking()
            .Where(x => x.CompetitionId == competitionId && x.IsActive && x.Club!.IsActive)
            .OrderBy(x => x.Club!.Name)
            .ThenBy(x => x.Name)
            .Select(x => new TeamOption(x.Id, $"{x.Club!.Name} - {x.Name}"))
            .ToListAsync());
    }

    private void ClearFilters()
    {
        statusFilter = string.Empty;
        roundFilter = string.Empty;
        clubFilter = string.Empty;
    }

    private async Task OnEventTeamChangedAsync()
    {
        eventForm.PlayerId = null;
        eventForm.PlayerName = string.Empty;
        selectedEventPlayerDiscipline = null;
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private async Task OnEventPlayerChanged()
    {
        var selectedPlayer = eventPlayers.FirstOrDefault(x => x.Id == eventForm.PlayerId);
        eventForm.PlayerName = selectedPlayer?.DisplayName ?? string.Empty;
        selectedEventPlayerDiscipline = editing is not null && eventForm.PlayerId is { } playerId
            ? await DisciplineQueryService.GetPlayerDisciplineForMatchAsync(editing.MatchId, playerId)
            : null;
    }

    private List<EventPlayerOption> EventPlayersForTeam(Guid teamId, Guid? currentPlayerId = null) => allMatchEventPlayers
        .Where(x => x.TeamId == teamId)
        .Where(x => !unavailableEventPlayerIds.Contains(x.Id) || x.Id == currentPlayerId)
        .OrderBy(x => x.ShirtNumber ?? int.MaxValue)
        .ThenBy(x => x.DisplayName)
        .ToList();

    private EventEditModel GetEventEdit(AdminMatchEventRow item)
    {
        if (!eventEdits.TryGetValue(item.Id, out var edit))
        {
            edit = new EventEditModel
            {
                EventType = item.EventType,
                Minute = item.Minute,
                TeamId = item.TeamId ?? editing?.HomeTeamId ?? Guid.Empty,
                PlayerId = item.PlayerId,
                PlayerName = item.PlayerName,
                Notes = item.Notes ?? string.Empty
            };
            eventEdits[item.Id] = edit;
        }

        return edit;
    }

    private async Task BeginEventEditAsync(AdminMatchEventRow item)
    {
        editingEventId = item.Id;
        eventEdits[item.Id] = new EventEditModel
        {
            EventType = item.EventType,
            Minute = item.Minute,
