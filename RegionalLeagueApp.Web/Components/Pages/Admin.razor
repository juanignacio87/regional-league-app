@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireContributor")]
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR
@using Microsoft.EntityFrameworkCore
@using RegionalLeagueApp.Application.Collaboration
@using RegionalLeagueApp.Application.Matches
@using RegionalLeagueApp.Domain.Collaboration
@using RegionalLeagueApp.Web.Hubs
@inject ApplicationDbContext Db
@inject IMatchAdministrationPermissionService PermissionService
@inject IMatchScoreRecalculationService MatchScoreRecalculationService
@inject IHubContext<MatchUpdatesHub> MatchUpdates
@inject ILogger<Admin> Logger

<PageTitle>Admin</PageTitle>

<div class="page-heading admin-heading">
    <div>
        <p class="eyebrow">Administracion</p>
        <h1>Gestion de partidos</h1>
    </div>
    <span class="admin-badge">@access.RoleLabel</span>
</div>

<section class="panel admin-permissions">
    <div>
        <p class="eyebrow">Permisos actuales</p>
        <h2>@PermissionSummary</h2>
    </div>
    @if (access.IsContributor && !access.CanManageAllMatches)
    {
        <span>@access.AssignedTeamIds.Count equipo(s) asignado(s)</span>
    }
    else if (access.CanModerate)
    {
        <span>Puede moderar todos los partidos y eventos</span>
    }
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success admin-feedback" role="status" aria-live="polite">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger admin-feedback" role="alert">@errorMessage</div>
}

@if (access.CanModerate)
{
    <section class="panel admin-proposals">
        <div class="panel-title-row">
            <div>
                <p class="eyebrow">Moderacion</p>
                <h2>Propuestas pendientes</h2>
            </div>
            <span>@pendingProposals.Count pendiente(s)</span>
        </div>

        @if (pendingProposals.Count == 0)
        {
            <EmptyState Text="No hay propuestas pendientes." />
        }
        else
        {
            <div class="admin-proposal-list">
                @foreach (var proposal in pendingProposals)
                {
                    <article class="admin-proposal-row">
                        <div>
                            <strong>@proposal.MatchLabel</strong>
                            <span>@proposal.Description</span>
                            <small>@proposal.ProposedBy - @proposal.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="admin-proposal-actions">
                            <button type="button" class="admin-link-button" disabled="@isReviewingProposal" @onclick="async () => await ApproveProposalAsync(proposal.Id)">Aprobar</button>
                            <button type="button" class="admin-link-button admin-link-button-muted" disabled="@isReviewingProposal" @onclick="async () => await RejectProposalAsync(proposal.Id)">Rechazar</button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
}

@if (matches.Count == 0)
{
    <EmptyState Text="No hay partidos para administrar." />
}
else
{
    <section class="admin-grid">
        <article class="panel table-panel admin-match-list">
            <div class="panel-title-row">
                <div>
                    <p class="eyebrow">Partidos</p>
                    <h2>Fixture cargado</h2>
                </div>
                <span>@FilteredMatches.Count de @matches.Count partidos</span>
            </div>

            <div class="admin-filters">
                <div>
                    <label for="status-filter">Estado</label>
                    <select id="status-filter" class="form-control" @bind="statusFilter">
                        <option value="">Todos</option>
                        @foreach (var status in Enum.GetValues<MatchStatus>())
                        {
                            <option value="@status.ToString()">@status</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="round-filter">Fecha</label>
                    <select id="round-filter" class="form-control" @bind="roundFilter">
                        <option value="">Todas</option>
                        @foreach (var roundName in RoundOptions)
                        {
                            <option value="@roundName">@roundName</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="club-filter">Club / equipo</label>
                    <select id="club-filter" class="form-control" @bind="clubFilter">
                        <option value="">Todos</option>
                        @foreach (var clubName in ClubOptions)
                        {
                            <option value="@clubName">@clubName</option>
                        }
                    </select>
                </div>
                <button type="button" class="admin-link-button admin-clear-button" @onclick="ClearFilters">Limpiar</button>
            </div>

            @if (FilteredMatches.Count == 0)
            {
                <EmptyState Text="No hay partidos que coincidan con los filtros." />
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Partido</th>
                            <th>Estado</th>
                            <th>Resultado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var match in FilteredMatches)
                        {
                            <tr class="@(editing?.MatchId == match.Id ? "is-selected" : string.Empty)">
                                <td>
                                    <span class="table-kicker">@match.RoundName</span>
                                    @match.StartsAt.LocalDateTime.ToString("dd/MM HH:mm")
                                </td>
                                <td>
                                    <strong>@match.HomeTeamName</strong>
                                    <span class="muted-text">vs</span>
                                    <strong>@match.AwayTeamName</strong>
                                </td>
                                <td><span class="status-pill @StatusClass(match.Status)">@match.Status</span></td>
                                <td><strong>@ScoreText(match.HomeScore, match.AwayScore)</strong></td>
                                <td class="table-actions">
                                    <button type="button" class="admin-link-button" @onclick="async () => await SelectMatchAsync(match.Id)">Editar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>

        <aside class="panel admin-editor">
            @if (editing is null)
            {
                <EmptyState Text="Selecciona un partido para editar su estado y resultado." />
            }
            else
            {
                <div class="panel-title-row">
                    <div>
                        <p class="eyebrow">Edicion</p>
                        <h2>@editing.HomeTeamName vs @editing.AwayTeamName</h2>
                    </div>
                    <a href="matches/@editing.MatchId">Ver</a>
                </div>

                <dl class="detail-list compact">
                    <div><dt>Competencia</dt><dd>@editing.CompetitionName</dd></div>
                    <div><dt>Fecha</dt><dd>@editing.StartsAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</dd></div>
                    <div><dt>Local</dt><dd>@editing.HomeTeamName</dd></div>
                    <div><dt>Visitante</dt><dd>@editing.AwayTeamName</dd></div>
                </dl>

                <EditForm Model="editing" OnValidSubmit="SaveAsync" class="admin-form" aria-busy="@isSaving">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <label for="status">Estado</label>
                    <InputSelect id="status" class="form-control" @bind-Value="editing.Status">
                        @foreach (var status in Enum.GetValues<MatchStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>

                    <div class="score-edit-grid">
                        <div>
                            <label for="home-score">Goles local</label>
                            <InputNumber id="home-score" class="form-control" min="0" @bind-Value="editing.HomeScore" disabled />
                        </div>
                        <div>
                            <label for="away-score">Goles visitante</label>
                            <InputNumber id="away-score" class="form-control" min="0" @bind-Value="editing.AwayScore" disabled />
                        </div>
                    </div>
                    <p class="admin-help-text">El marcador se calcula automaticamente desde los goles.</p>

                    <button class="btn btn-primary" type="submit" disabled="@isSaving">
                        @(isSaving ? "Guardando..." : access.CanModerate ? "Guardar cambios" : "Enviar propuesta")
                    </button>
                </EditForm>

                <div class="admin-events">
                    <div class="panel-title-row">
                        <div>
                            <p class="eyebrow">Eventos</p>
                            <h2>Linea de tiempo</h2>
                        </div>
                        <span>@selectedEvents.Count eventos</span>
                    </div>

                    @if (selectedEvents.Count == 0)
                    {
                        <EmptyState Text="No hay eventos cargados para este partido." />
                    }
                    else
                    {
                        <div class="admin-event-list">
                            @foreach (var item in selectedEvents)
                            {
                                <div class="admin-event-row">
                                    <strong>@item.Minute'</strong>
                                    <span>@EventLabel(item.EventType)</span>
                                    <small>@item.TeamName - @item.PlayerName</small>
                                    <button type="button" class="admin-link-button" @onclick="async () => await DeleteEventAsync(item.Id)">@(access.CanModerate ? "Eliminar" : "Proponer eliminar")</button>
                                </div>
                            }
                        </div>
                    }

                    <EditForm Model="eventForm" OnValidSubmit="CreateEventAsync" class="admin-form admin-event-form">
                        <DataAnnotationsValidator />

                        <div class="score-edit-grid">
                            <div>
                                <label for="event-type">Evento</label>
                                <InputSelect id="event-type" class="form-control" @bind-Value="eventForm.EventType">
                                    @foreach (var eventType in AllowedEventTypes)
                                    {
                                        <option value="@eventType">@EventLabel(eventType)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div>
                                <label for="event-team">Equipo</label>
                                <InputSelect id="event-team" class="form-control" @bind-Value="eventForm.TeamId" @bind-Value:after="OnEventTeamChangedAsync">
                                    <option value="@editing.HomeTeamId">@editing.HomeTeamName</option>
                                    <option value="@editing.AwayTeamId">@editing.AwayTeamName</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="score-edit-grid">
                            <div>
                                <label for="event-player">Jugador</label>
                                @if (eventPlayers.Count == 0)
                                {
                                    <p class="admin-empty-hint">No hay jugadores activos cargados para este equipo.</p>
                                }
                                else
                                {
                                    <InputSelect id="event-player" class="form-control" @bind-Value="eventForm.PlayerId" @bind-Value:after="OnEventPlayerChanged">
                                        <option value="">Seleccionar jugador</option>
                                        @foreach (var player in eventPlayers)
                                        {
                                            <option value="@player.Id">@player.Label</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => eventForm.PlayerId" />
                                }
                            </div>
                            <div>
                                <label for="event-minute">Minuto</label>
                                <InputNumber id="event-minute" class="form-control" min="0" max="130" @bind-Value="eventForm.Minute" />
                                <ValidationMessage For="() => eventForm.Minute" />
                            </div>
                        </div>

                        <button class="btn btn-primary" type="submit" disabled="@isSavingEvent">
                            @(isSavingEvent ? "Agregando..." : access.CanModerate ? "Agregar evento" : "Proponer evento")
                        </button>
                    </EditForm>
                </div>
            }
        </aside>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "matchId")]
    public Guid? RequestedMatchId { get; set; }

    private readonly List<AdminMatchRow> matches = [];
    private MatchEditModel? editing;
    private EventCreateModel eventForm = new();
    private readonly List<AdminMatchEventRow> selectedEvents = [];
    private readonly List<EventPlayerOption> eventPlayers = [];
    private readonly List<PendingProposalRow> pendingProposals = [];
    private MatchAdministrationAccess access = MatchAdministrationAccess.Empty;
    private bool isSaving;
    private bool isSavingEvent;
    private bool isReviewingProposal;
    private string? successMessage;
    private string? errorMessage;
    private string statusFilter = string.Empty;
    private string roundFilter = string.Empty;
    private string clubFilter = string.Empty;
    private static readonly MatchEventType[] AllowedEventTypes =
    [
        MatchEventType.Goal,
        MatchEventType.YellowCard,
        MatchEventType.RedCard
    ];
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private string PermissionSummary => access.CanManageAllMatches
        ? "Puede editar cualquier partido y moderar eventos."
        : access.IsContributor
            ? "Puede enviar propuestas de resultados y eventos en partidos asignados."
            : "No tiene permisos para administrar partidos.";

    private List<AdminMatchRow> FilteredMatches => matches
        .Where(match => string.IsNullOrWhiteSpace(statusFilter) || match.Status.ToString() == statusFilter)
        .Where(match => string.IsNullOrWhiteSpace(roundFilter) || match.RoundName == roundFilter)
        .Where(match => string.IsNullOrWhiteSpace(clubFilter) || match.HomeTeamName == clubFilter || match.AwayTeamName == clubFilter)
        .ToList();

    private List<string> RoundOptions => matches
        .Select(match => match.RoundName)
        .Distinct()
        .OrderBy(roundName => roundName)
        .ToList();

    private List<string> ClubOptions => matches
        .SelectMany(match => new[] { match.HomeTeamName, match.AwayTeamName })
        .Distinct()
        .OrderBy(clubName => clubName)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        access = await PermissionService.GetAccessAsync();
        await LoadMatchesAsync();
        await LoadPendingProposalsAsync();

        if (RequestedMatchId is { } matchId)
        {
            await SelectMatchAsync(matchId);
        }
    }

    private async Task LoadMatchesAsync()
    {
        matches.Clear();
        matches.AddRange(await Db.Matches
            .AsNoTracking()
            .Include(x => x.Competition)
            .Include(x => x.Round)
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => access.CanManageAllMatches || access.AssignedTeamIds.Contains(x.HomeTeamId) || access.AssignedTeamIds.Contains(x.AwayTeamId))
            .OrderByDescending(x => x.StartsAt)
            .Select(x => new AdminMatchRow(
                x.Id,
                x.Competition!.Name,
                x.Round!.Name,
                x.HomeTeamId,
                x.HomeTeam!.Club!.Name,
                x.AwayTeamId,
                x.AwayTeam!.Club!.Name,
                x.StartsAt,
                x.Status,
                x.HomeScore,
                x.AwayScore))
            .ToListAsync());
    }

    private async Task LoadPendingProposalsAsync()
    {
        pendingProposals.Clear();

        if (!access.CanModerate)
        {
            return;
        }

        var proposals = await Db.MatchUpdateProposals
            .AsNoTracking()
            .Include(x => x.ProposedByUser)
            .Include(x => x.Match)!.ThenInclude(x => x!.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Match)!.ThenInclude(x => x!.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == ProposalStatus.Pending)
            .OrderBy(x => x.CreatedAt)
            .Select(x => new
            {
                x.Id,
                x.ChangeType,
                x.PayloadJson,
                x.ProposedStatus,
                x.CreatedAt,
                ProposedBy = x.ProposedByUser != null ? x.ProposedByUser.DisplayName : "Usuario",
                HomeTeamName = x.Match != null && x.Match.HomeTeam != null ? x.Match.HomeTeam.Club!.Name : "Local",
                AwayTeamName = x.Match != null && x.Match.AwayTeam != null ? x.Match.AwayTeam.Club!.Name : "Visitante"
            })
            .ToListAsync();

        pendingProposals.AddRange(proposals.Select(x => new PendingProposalRow(
            x.Id,
            $"{x.HomeTeamName} vs {x.AwayTeamName}",
            x.ProposedBy,
            x.CreatedAt,
            ProposalDescription(x.ChangeType, x.PayloadJson, x.ProposedStatus))));
    }

    private async Task SelectMatchAsync(Guid matchId)
    {
        successMessage = null;
        errorMessage = null;

        var match = matches.FirstOrDefault(x => x.Id == matchId);
        if (match is null || !access.CanManageMatch(match.HomeTeamId, match.AwayTeamId))
        {
            editing = null;
            selectedEvents.Clear();
            errorMessage = "No tenes permisos para editar este partido.";
            return;
        }

        editing = new MatchEditModel
        {
            MatchId = match.Id,
            CompetitionName = match.CompetitionName,
            RoundName = match.RoundName,
            HomeTeamId = match.HomeTeamId,
            HomeTeamName = match.HomeTeamName,
            AwayTeamId = match.AwayTeamId,
            AwayTeamName = match.AwayTeamName,
            StartsAt = match.StartsAt,
            Status = match.Status,
            HomeScore = match.HomeScore,
            AwayScore = match.AwayScore
        };

        eventForm = new EventCreateModel
        {
            TeamId = match.HomeTeamId,
            EventType = MatchEventType.Goal
        };

        await LoadSelectedEventsAsync(match.Id);
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private void ClearFilters()
    {
        statusFilter = string.Empty;
        roundFilter = string.Empty;
        clubFilter = string.Empty;
    }

    private async Task OnEventTeamChangedAsync()
    {
        eventForm.PlayerId = null;
        eventForm.PlayerName = string.Empty;
        await LoadEventPlayersAsync(eventForm.TeamId);
    }

    private void OnEventPlayerChanged()
    {
        var selectedPlayer = eventPlayers.FirstOrDefault(x => x.Id == eventForm.PlayerId);
        eventForm.PlayerName = selectedPlayer?.DisplayName ?? string.Empty;
    }

    private async Task LoadEventPlayersAsync(Guid teamId)
    {
        eventPlayers.Clear();
        eventPlayers.AddRange(await Db.Players
            .AsNoTracking()
            .Where(x => x.TeamId == teamId && x.IsActive)
            .OrderBy(x => x.ShirtNumber ?? int.MaxValue)
            .ThenBy(x => x.DisplayName)
            .Select(x => new EventPlayerOption(
                x.Id,
                x.DisplayName,
                x.ShirtNumber,
                x.ShirtNumber != null ? $"#{x.ShirtNumber} {x.DisplayName}" : x.DisplayName))
            .ToListAsync());
    }

    private async Task SaveAsync()
    {
        if (editing is null || isSaving)
        {
            return;
        }

        successMessage = null;
        errorMessage = Validate(editing);
        if (errorMessage is not null)
        {
            return;
        }

        isSaving = true;
        try
        {
            var match = await Db.Matches.FirstOrDefaultAsync(x => x.Id == editing.MatchId);
            if (match is null)
            {
                errorMessage = "No se encontro el partido seleccionado.";
                return;
            }

            if (!access.CanManageMatch(match.HomeTeamId, match.AwayTeamId))
            {
                errorMessage = "No tenes permisos para guardar cambios en este partido.";
                return;
            }

            if (!access.CanModerate)
            {
                if (access.UserId is not { } userId)
                {
                    errorMessage = "No se pudo identificar el usuario actual.";
                    return;
                }

                var payload = new MatchStatusAndResultProposalPayload(editing.Status);
                Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchStatusAndResult(
                    editing.MatchId,
                    userId,
                    editing.Status,
                    null,
                    null,
                    ToJson(payload)));

                await Db.SaveChangesAsync();
                await LoadPendingProposalsAsync();
                successMessage = "Propuesta enviada para revision.";
                return;
            }

            Db.Entry(match).Property(x => x.Status).CurrentValue = editing.Status;
            await Db.SaveChangesAsync();
            await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(match.Id);
            var selectedMatchId = editing.MatchId;
            await LoadMatchesAsync();
            await SelectMatchAsync(selectedMatchId);
            await NotifyMatchDataChangedAsync();

            successMessage = "Resultado actualizado correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo guardar el resultado. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LoadSelectedEventsAsync(Guid matchId)
    {
        selectedEvents.Clear();
        selectedEvents.AddRange(await Db.MatchEvents
            .AsNoTracking()
            .Include(x => x.Team)!.ThenInclude(x => x!.Club)
            .Include(x => x.Player)
            .Where(x => x.MatchId == matchId)
            .OrderBy(x => x.Minute)
            .ThenBy(x => x.CreatedAt)
            .Select(x => new AdminMatchEventRow(
                x.Id,
                x.Type,
                x.Minute,
                x.Team != null ? x.Team.Club!.ShortName : "Sin equipo",
                x.PlayerName != string.Empty ? x.PlayerName : x.Player != null ? x.Player.DisplayName : "Sin jugador"))
            .ToListAsync());
    }

    private async Task CreateEventAsync()
    {
        if (editing is null || isSavingEvent)
        {
            return;
        }

        successMessage = null;
        errorMessage = Validate(eventForm, editing);
        if (errorMessage is not null)
        {
            return;
        }

        if (!access.CanManageMatch(editing.HomeTeamId, editing.AwayTeamId))
        {
            errorMessage = "No tenes permisos para agregar eventos en este partido.";
            return;
        }

        isSavingEvent = true;
        try
        {
            if (!access.CanModerate)
            {
                if (access.UserId is not { } userId)
                {
                    errorMessage = "No se pudo identificar el usuario actual.";
                    return;
                }

                var payload = new MatchEventAddProposalPayload(
                    eventForm.EventType,
                    eventForm.Minute,
                    eventForm.TeamId,
                    eventForm.PlayerId!.Value,
                    eventForm.PlayerName.Trim());

                Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchEvent(
                    editing.MatchId,
                    userId,
                    ProposalChangeType.MatchEventAdd,
                    ToJson(payload)));

                await Db.SaveChangesAsync();
                eventForm.PlayerName = string.Empty;
                eventForm.PlayerId = null;
                eventForm.Minute = 0;
                await LoadPendingProposalsAsync();
                successMessage = "Propuesta enviada para revision.";
                return;
            }

            Db.MatchEvents.Add(new MatchEvent(
                editing.MatchId,
                eventForm.EventType,
                eventForm.Minute,
                eventForm.TeamId,
                eventForm.PlayerId,
                playerName: eventForm.PlayerName));

            await Db.SaveChangesAsync();
            if (eventForm.EventType == MatchEventType.Goal)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(editing.MatchId);
            }

            await LoadSelectedEventsAsync(editing.MatchId);
            var selectedMatchId = editing.MatchId;
            eventForm.PlayerName = string.Empty;
            eventForm.PlayerId = null;
            eventForm.Minute = 0;
            await LoadMatchesAsync();
            await SelectMatchAsync(selectedMatchId);
            await NotifyMatchDataChangedAsync();
            successMessage = "Evento agregado correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo agregar el evento. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isSavingEvent = false;
        }
    }

    private async Task DeleteEventAsync(Guid eventId)
    {
        if (editing is null)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        if (!access.CanManageMatch(editing.HomeTeamId, editing.AwayTeamId))
        {
            errorMessage = "No tenes permisos para eliminar eventos de este partido.";
            return;
        }

        var matchEvent = await Db.MatchEvents.FirstOrDefaultAsync(x => x.Id == eventId && x.MatchId == editing.MatchId);
        if (matchEvent is null)
        {
            errorMessage = "No se encontro el evento seleccionado.";
            return;
        }

        if (!access.CanModerate)
        {
            if (access.UserId is not { } userId)
            {
                errorMessage = "No se pudo identificar el usuario actual.";
                return;
            }

            var payload = new MatchEventDeleteProposalPayload(
                matchEvent.Id,
                matchEvent.Type,
                matchEvent.Minute,
                matchEvent.TeamId,
                !string.IsNullOrWhiteSpace(matchEvent.PlayerName) ? matchEvent.PlayerName : "Sin jugador");

            Db.MatchUpdateProposals.Add(MatchUpdateProposal.ForMatchEvent(
                editing.MatchId,
                userId,
                ProposalChangeType.MatchEventDelete,
                ToJson(payload)));

            await Db.SaveChangesAsync();
            await LoadPendingProposalsAsync();
            successMessage = "Propuesta enviada para revision.";
            return;
        }

        var deletedEventType = matchEvent.Type;
        Db.MatchEvents.Remove(matchEvent);
        await Db.SaveChangesAsync();
        if (deletedEventType == MatchEventType.Goal)
        {
            await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(editing.MatchId);
        }

        var selectedMatchId = editing.MatchId;
        await LoadMatchesAsync();
        await SelectMatchAsync(selectedMatchId);
        await LoadSelectedEventsAsync(editing.MatchId);
        await NotifyMatchDataChangedAsync();
        successMessage = "Evento eliminado correctamente.";
    }

    private async Task NotifyMatchDataChangedAsync()
    {
        await MatchUpdates.Clients.All.SendAsync(MatchUpdatesHub.MatchDataChanged);
        Logger.LogInformation("SignalR notification {EventName} emitted.", MatchUpdatesHub.MatchDataChanged);
    }

    private async Task ApproveProposalAsync(Guid proposalId)
    {
        if (!access.CanModerate || isReviewingProposal)
        {
            return;
        }

        if (access.UserId is not { } reviewerId)
        {
            errorMessage = "No se pudo identificar el usuario moderador.";
            return;
        }

        successMessage = null;
        errorMessage = null;
        isReviewingProposal = true;

        try
        {
            var proposal = await Db.MatchUpdateProposals
                .Include(x => x.Match)
                .FirstOrDefaultAsync(x => x.Id == proposalId && x.Status == ProposalStatus.Pending);

            if (proposal is null)
            {
                errorMessage = "La propuesta ya no esta pendiente.";
                return;
            }

            var shouldRecalculateScoreAndStandings = await ApplyProposalAsync(proposal);
            proposal.Approve(reviewerId);
            await Db.SaveChangesAsync();

            if (shouldRecalculateScoreAndStandings)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(proposal.MatchId);
            }

            await LoadMatchesAsync();
            if (editing is not null)
            {
                await SelectMatchAsync(editing.MatchId);
            }

            await LoadPendingProposalsAsync();
            await NotifyMatchDataChangedAsync();
            successMessage = "Propuesta aprobada y aplicada correctamente.";
        }
        catch (Exception)
        {
            errorMessage = "No se pudo aprobar la propuesta. Revisa los datos e intenta nuevamente.";
        }
        finally
        {
            isReviewingProposal = false;
        }
    }

    private async Task RejectProposalAsync(Guid proposalId)
    {
        if (!access.CanModerate || isReviewingProposal)
        {
            return;
        }

        if (access.UserId is not { } reviewerId)
        {
            errorMessage = "No se pudo identificar el usuario moderador.";
            return;
        }

        successMessage = null;
        errorMessage = null;
        isReviewingProposal = true;

        try
        {
            var proposal = await Db.MatchUpdateProposals
                .FirstOrDefaultAsync(x => x.Id == proposalId && x.Status == ProposalStatus.Pending);

            if (proposal is null)
            {
                errorMessage = "La propuesta ya no esta pendiente.";
                return;
            }

            var shouldRecalculateScoreAndStandings = proposal.ChangeType == ProposalChangeType.MatchEventDelete
                && FromJson<MatchEventDeleteProposalPayload>(proposal.PayloadJson).EventType == MatchEventType.Goal;

            proposal.Reject(reviewerId);
            await Db.SaveChangesAsync();
            if (shouldRecalculateScoreAndStandings)
            {
                await MatchScoreRecalculationService.RecalculateMatchScoreAndStandingsAsync(proposal.MatchId);
                await NotifyMatchDataChangedAsync();
            }

            await LoadPendingProposalsAsync();
            successMessage = "Propuesta rechazada.";
        }
        finally
        {
            isReviewingProposal = false;
        }
    }

    private async Task<bool> ApplyProposalAsync(MatchUpdateProposal proposal)
    {
        if (proposal.Match is null)
        {
            throw new InvalidOperationException("La propuesta no tiene partido asociado.");
        }

        switch (proposal.ChangeType)
        {
            case ProposalChangeType.MatchStatusAndResult:
                Db.Entry(proposal.Match).Property(x => x.Status).CurrentValue = proposal.ProposedStatus ?? proposal.Match.Status;
                return true;

            case ProposalChangeType.MatchEventAdd:
                var addPayload = FromJson<MatchEventAddProposalPayload>(proposal.PayloadJson);
                Db.MatchEvents.Add(new MatchEvent(
                    proposal.MatchId,
                    addPayload.EventType,
                    addPayload.Minute,
                    addPayload.TeamId,
                    addPayload.PlayerId,
                    playerName: addPayload.PlayerName));
                return addPayload.EventType == MatchEventType.Goal;

            case ProposalChangeType.MatchEventDelete:
                var deletePayload = FromJson<MatchEventDeleteProposalPayload>(proposal.PayloadJson);
                var matchEvent = await Db.MatchEvents.FirstOrDefaultAsync(x => x.Id == deletePayload.EventId && x.MatchId == proposal.MatchId);
                if (matchEvent is not null)
                {
                    Db.MatchEvents.Remove(matchEvent);
                }

                return deletePayload.EventType == MatchEventType.Goal;

            default:
                throw new InvalidOperationException("Tipo de propuesta no soportado.");
        }
    }

    private static string? Validate(MatchEditModel model)
    {
        return null;
    }

    private static string? Validate(EventCreateModel model, MatchEditModel match)
    {
        if (model.PlayerId is null || string.IsNullOrWhiteSpace(model.PlayerName))
        {
            return "Selecciona un jugador del plantel.";
        }

        if (model.Minute is < 0 or > 130)
        {
            return "El minuto debe estar entre 0 y 130.";
        }

        if (model.TeamId != match.HomeTeamId && model.TeamId != match.AwayTeamId)
        {
            return "El equipo seleccionado no pertenece al partido.";
        }

        if (!AllowedEventTypes.Contains(model.EventType))
        {
            return "El tipo de evento seleccionado no esta permitido.";
        }

        return null;
    }

    private static string ScoreText(int? homeScore, int? awayScore) =>
        homeScore is null || awayScore is null ? "vs" : $"{homeScore}-{awayScore}";

    private static string StatusClass(MatchStatus status) => status is MatchStatus.Live or MatchStatus.HalfTime
        ? "status-live"
        : string.Empty;

    private static string EventLabel(MatchEventType eventType) => eventType switch
    {
        MatchEventType.Goal => "Gol",
        MatchEventType.YellowCard => "Tarjeta amarilla",
        MatchEventType.RedCard => "Tarjeta roja",
        _ => eventType.ToString()
    };

    private static string ToJson<T>(T value) => JsonSerializer.Serialize(value, JsonOptions);

    private static T FromJson<T>(string json) =>
        JsonSerializer.Deserialize<T>(json, JsonOptions)
        ?? throw new InvalidOperationException("Payload de propuesta invalido.");

    private static string ProposalDescription(
        ProposalChangeType changeType,
        string payloadJson,
        MatchStatus? proposedStatus)
    {
        return changeType switch
        {
            ProposalChangeType.MatchStatusAndResult =>
                $"Cambiar estado a {proposedStatus}. El marcador se calcula desde goles.",
            ProposalChangeType.MatchEventAdd => EventAddDescription(payloadJson),
            ProposalChangeType.MatchEventDelete => EventDeleteDescription(payloadJson),
            _ => changeType.ToString()
        };
    }

    private static string EventAddDescription(string payloadJson)
    {
        var payload = FromJson<MatchEventAddProposalPayload>(payloadJson);
        return $"Agregar {EventLabel(payload.EventType)} - {payload.PlayerName} ({payload.Minute}')";
    }

    private static string EventDeleteDescription(string payloadJson)
    {
        var payload = FromJson<MatchEventDeleteProposalPayload>(payloadJson);
        return $"Eliminar {EventLabel(payload.EventType)} - {payload.PlayerName} ({payload.Minute}')";
    }

