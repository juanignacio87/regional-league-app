@page "/moderation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{AppRoles.Moderator},{AppRoles.Admin}")]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject ProposalService Proposals
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Moderacion</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">Moderation</p>
        <h1>Propuestas pendientes</h1>
    </div>
</div>

<section class="panel">
    @if (pending.Count == 0)
    {
        <p class="muted">No hay propuestas pendientes.</p>
    }
    @foreach (var proposal in pending)
    {
        <div class="proposal-row">
            <div>
                <strong>@proposal.Match?.HomeTeam?.Club?.ShortName @proposal.HomeScore - @proposal.AwayScore @proposal.Match?.AwayTeam?.Club?.ShortName</strong>
                <small>@proposal.Notes</small>
            </div>
            <button class="btn btn-primary" @onclick="() => ApproveAsync(proposal.Id)">Aprobar</button>
            <button class="btn btn-outline-secondary" @onclick="() => RejectAsync(proposal.Id)">Rechazar</button>
        </div>
    }
</section>

@code {
    private List<MatchUpdateProposal> pending = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        pending = await Db.MatchUpdateProposals
            .AsNoTracking()
            .Include(x => x.Match)!.ThenInclude(x => x!.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.Match)!.ThenInclude(x => x!.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.StatusReview == ProposalStatus.Pending)
            .OrderBy(x => x.CreatedAt)
            .ToListAsync();
    }

    private async Task ApproveAsync(int id)
    {
        var userId = await CurrentUserIdAsync();
        await Proposals.ApproveAsync(id, userId);
        await LoadAsync();
    }

    private async Task RejectAsync(int id)
    {
        var userId = await CurrentUserIdAsync();
        await Proposals.RejectAsync(id, userId);
        await LoadAsync();
    }

    private async Task<string> CurrentUserIdAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        return auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
    }
}
