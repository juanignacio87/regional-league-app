@page "/"
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Liga Regional</PageTitle>

<section class="hero-band">
    <div>
        <p class="eyebrow">Liga Regional Norte</p>
        <h1>Fixture, resultados y tabla en una sola app.</h1>
        <p>Una base monolitica modular para gestionar clubes, planteles, partidos y colaboracion autorizada.</p>
    </div>
    <div class="score-tile">
        <span>Proximo partido</span>
        @if (nextMatch is not null)
        {
            <strong>@nextMatch.HomeTeam?.Club?.ShortName vs @nextMatch.AwayTeam?.Club?.ShortName</strong>
            <small>@nextMatch.StartsAt.LocalDateTime.ToString("dd/MM HH:mm")</small>
        }
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel">
        <div class="panel-title">
            <h2>Ultimos resultados</h2>
            <a href="matches">Ver fixture</a>
        </div>
        @foreach (var match in finishedMatches)
        {
            <a class="match-row" href="matches/@match.Id">
                <span>@match.HomeTeam?.Club?.ShortName</span>
                <strong>@match.HomeScore - @match.AwayScore</strong>
                <span>@match.AwayTeam?.Club?.ShortName</span>
            </a>
        }
    </article>

    <article class="panel">
        <div class="panel-title">
            <h2>Tabla</h2>
            <a href="standings">Completa</a>
        </div>
        @foreach (var row in standings)
        {
            <div class="standing-row">
                <span>@row.Team?.Club?.ShortName</span>
                <small>@row.Played PJ</small>
                <strong>@row.Points pts</strong>
            </div>
        }
    </article>

    <article class="panel">
        <div class="panel-title">
            <h2>Clubes</h2>
            <a href="clubs">Planteles</a>
        </div>
        <div class="club-list">
            @foreach (var club in clubs)
            {
                <a href="clubs/@club.Id" class="club-chip">
                    <span style="background:@club.PrimaryColor"></span>
                    @club.ShortName
                </a>
            }
        </div>
    </article>
</section>

@code {
    private List<Match> finishedMatches = [];
    private List<Standing> standings = [];
    private List<Club> clubs = [];
    private Match? nextMatch;

    protected override async Task OnInitializedAsync()
    {
        finishedMatches = await Db.Matches
            .AsNoTracking()
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == MatchStatus.Finished)
            .OrderByDescending(x => x.StartsAt)
            .Take(4)
            .ToListAsync();

        nextMatch = await Db.Matches
            .AsNoTracking()
            .Include(x => x.HomeTeam)!.ThenInclude(x => x!.Club)
            .Include(x => x.AwayTeam)!.ThenInclude(x => x!.Club)
            .Where(x => x.Status == MatchStatus.Scheduled)
            .OrderBy(x => x.StartsAt)
            .FirstOrDefaultAsync();

        standings = await Db.Standings
            .AsNoTracking()
            .Include(x => x.Team)!.ThenInclude(x => x!.Club)
            .OrderByDescending(x => x.Points)
            .ThenByDescending(x => x.GoalDifference)
            .Take(6)
            .ToListAsync();

        clubs = await Db.Clubs.AsNoTracking().OrderBy(x => x.Name).ToListAsync();
    }
}
