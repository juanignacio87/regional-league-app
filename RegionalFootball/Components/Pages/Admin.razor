@page "/admin"
@attribute [Authorize(Roles = AppRoles.Admin)]
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Admin</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Panel administrativo</h1>
    </div>
</div>

<section class="dashboard-grid">
    <article class="panel metric">
        <span>Clubes</span>
        <strong>@clubs</strong>
    </article>
    <article class="panel metric">
        <span>Jugadores</span>
        <strong>@players</strong>
    </article>
    <article class="panel metric">
        <span>Partidos</span>
        <strong>@matches</strong>
    </article>
    <article class="panel metric">
        <span>Propuestas pendientes</span>
        <strong>@pendingProposals</strong>
    </article>
</section>

<section class="panel">
    <h2>Alcance del panel</h2>
    <p class="muted">Esta base deja listos los permisos, entidades y tablero. Las altas/ediciones CRUD pueden crecer por modulo sin separar servicios ni duplicar contexto de datos.</p>
</section>

@code {
    private int clubs;
    private int players;
    private int matches;
    private int pendingProposals;

    protected override async Task OnInitializedAsync()
    {
        clubs = await Db.Clubs.CountAsync();
        players = await Db.Players.CountAsync();
        matches = await Db.Matches.CountAsync();
        pendingProposals = await Db.MatchUpdateProposals.CountAsync(x => x.StatusReview == ProposalStatus.Pending);
    }
}
